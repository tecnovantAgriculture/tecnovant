WEBODM_URL=http://IP_PUBLICA_DE_GOOGLE:8000
WEBODM_PUBLIC_URL=http://IP_PUBLICA_DE_GOOGLE:8000
WEBODM_USERNAME=Tecnovan
WEBODM_PASSWORD=CAMBIAR_PASSWORD_WEBODM
WEBODM_PROJECT_NAME=Tecnovan
WEBODM_REQUEST_TIMEOUT_SECONDS=60
WEBODM_UPLOAD_TIMEOUT_SECONDS=7200
WEBODM_READY_TIMEOUT_SECONDS=900
WEBODM_STATUS_POLL_SECONDS=60

# Perfil por defecto para ortofoto 2D nitida rapida.
WEBODM_PROCESSING_PROFILE=fast_2d
WEBODM_FEATURE_QUALITY=medium
WEBODM_PC_QUALITY=lowest
WEBODM_MATCHER_NEIGHBORS=8
WEBODM_MATCHER_ORDER=8
WEBODM_MIN_NUM_FEATURES=10000
WEBODM_ORTHOPHOTO_RESOLUTION=3.5

# Encendido/apagado automatico de la VM grande de WebODM.
WEBODM_AUTOSTART=true
WEBODM_AUTOSTOP=true
GCP_PROJECT_ID=PROYECTO_DONDE_ESTA_LA_VM
GCP_ZONE=us-central1-b
GCP_WEBODM_INSTANCE=webodm-ortofotos
GCP_SERVICE_ACCOUNT_FILE=/app/secrets/gcp-vm-manager.json
GCP_OPERATION_TIMEOUT_SECONDS=600

# Solo usar si la calidad queda floja y queremos limitar la imagen original antes de WebODM.
# WEBODM_RESIZE_TO=4000
