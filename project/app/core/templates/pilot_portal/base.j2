<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#111111">
  <title>{{ title|default("Portal piloto") }} - {{ site_title|default("TecnoVant") }}</title>
  <link rel="stylesheet" type="text/css" href="/css/fontawesome.min.css">
  <style>
    :root {
      --ink: #111111;
      --ink-soft: #242424;
      --surface: #ffffff;
      --surface-soft: #f4f4f2;
      --line: #e7e7e2;
      --text: #141414;
      --muted: #76766f;
      --bg: #f1f1ee;
      --danger: #c52626;
      --warning: #8a6418;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at top left, rgba(255,255,255,.95), rgba(255,255,255,0) 28rem),
        var(--bg);
      color: var(--text);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      letter-spacing: 0;
    }

    a { color: inherit; text-decoration: none; }

    .pilot-shell {
      max-width: 520px;
      min-height: 100vh;
      margin: 0 auto;
      padding: 16px 14px 132px;
    }

    .pilot-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 8px 2px 18px;
    }

    .pilot-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
    }

    .pilot-brand-mark {
      display: grid;
      width: 44px;
      height: 44px;
      place-items: center;
      border-radius: 16px;
      background: var(--ink);
      color: #fff;
      box-shadow: 0 14px 30px rgba(17, 17, 17, .18);
    }

    .pilot-eyebrow {
      margin: 0 0 3px;
      color: #5c5c56;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .pilot-title {
      margin: 0;
      font-size: 23px;
      font-weight: 780;
      line-height: 1.1;
    }

    .pilot-muted {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .pilot-card {
      width: 100%;
      max-width: 100%;
      overflow: hidden;
      margin-bottom: 14px;
      padding: 17px;
      border: 1px solid var(--line);
      border-radius: 24px;
      background: rgba(255, 255, 255, .92);
      box-shadow: 0 18px 42px rgba(20, 20, 20, .07);
    }

    .pilot-card h2,
    .pilot-card h3 {
      margin: 0 0 12px;
      font-size: 17px;
      font-weight: 740;
    }

    .app-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 0 2px 16px;
    }

    .app-title {
      margin: 0;
      font-size: 24px;
      font-weight: 820;
      letter-spacing: 0;
    }

    .app-subtitle {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 13px;
    }

    .icon-button {
      display: grid;
      width: 38px;
      height: 38px;
      place-items: center;
      border: 1px solid var(--line);
      border-radius: 50%;
      background: #fff;
      color: #111;
      box-shadow: 0 10px 24px rgba(20, 20, 20, .06);
    }

    .avatar {
      display: grid;
      width: 52px;
      height: 52px;
      place-items: center;
      border-radius: 19px;
      background: #111;
      color: #fff;
      font-size: 17px;
      font-weight: 850;
      box-shadow: 0 18px 38px rgba(0, 0, 0, .18);
    }

    .login-logo {
      display: grid;
      width: 86px;
      height: 62px;
      place-items: center;
      padding: 8px;
      border: 1px solid var(--line);
      border-radius: 20px;
      background: #fff;
      box-shadow: 0 16px 34px rgba(20, 20, 20, .08);
    }

    .login-logo img {
      display: block;
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
    }

    .hero-profile {
      position: relative;
      overflow: hidden;
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: 30px;
      background:
        linear-gradient(135deg, rgba(255,255,255,.86), rgba(245,245,240,.98)),
        #fff;
      box-shadow: 0 20px 48px rgba(20, 20, 20, .08);
    }

    .hero-profile::after {
      content: "";
      position: absolute;
      right: -38px;
      top: -42px;
      width: 150px;
      height: 150px;
      border-radius: 999px;
      background: rgba(17, 17, 17, .06);
    }

    .hero-profile-head {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      gap: 13px;
    }

    .hero-profile h2 {
      margin: 0;
      font-size: 21px;
      font-weight: 820;
    }

    .hero-profile p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 13px;
    }

    .metric-strip {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 18px;
    }

    .metric-pill {
      min-width: 0;
      padding: 11px 10px;
      border-radius: 18px;
      background: rgba(255, 255, 255, .8);
      border: 1px solid rgba(224, 224, 218, .9);
    }

    .metric-pill span {
      display: block;
      color: var(--muted);
      font-size: 9px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .metric-pill strong {
      display: block;
      margin-top: 5px;
      font-size: 18px;
      font-weight: 830;
    }

    .segmented {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding: 2px 0 14px;
      scrollbar-width: none;
    }

    .segmented::-webkit-scrollbar,
    .date-strip::-webkit-scrollbar {
      display: none;
    }

    .chip {
      flex: 0 0 auto;
      min-height: 34px;
      padding: 8px 13px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: #fff;
      color: #4f4f49;
      font-size: 12px;
      font-weight: 800;
      white-space: nowrap;
    }

    .chip.is-active {
      border-color: #111;
      background: #111;
      color: #fff;
    }

    .section-title {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 12px;
      margin: 18px 2px 10px;
    }

    .section-title h2 {
      margin: 0;
      font-size: 18px;
      font-weight: 830;
    }

    .section-title a,
    .section-title span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
    }

    .task-card {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 12px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 24px;
      background: #fff;
      box-shadow: 0 14px 32px rgba(20, 20, 20, .06);
    }

    .task-card + .task-card {
      margin-top: 10px;
    }

    .task-time {
      display: grid;
      align-content: center;
      min-width: 58px;
      color: #222;
      font-size: 11px;
      font-weight: 800;
      line-height: 1.35;
    }

    .task-main {
      min-width: 0;
    }

    .task-main strong {
      display: block;
      color: #111;
      font-size: 15px;
      font-weight: 830;
      line-height: 1.25;
    }

    .task-main small {
      display: block;
      margin-top: 5px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.35;
    }

    .task-card[data-status="in_progress"] {
      background: #111;
      border-color: #111;
      color: #fff;
    }

    .task-card[data-status="in_progress"] .task-main strong,
    .task-card[data-status="in_progress"] .task-time {
      color: #fff;
    }

    .task-card[data-status="in_progress"] .task-main small {
      color: rgba(255, 255, 255, .72);
    }

    .date-strip {
      display: flex;
      gap: 9px;
      overflow-x: auto;
      padding: 2px 0 16px;
      scrollbar-width: none;
    }

    .date-pill {
      flex: 0 0 auto;
      display: grid;
      width: 54px;
      min-height: 64px;
      place-items: center;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: #fff;
      color: #111;
      box-shadow: 0 10px 22px rgba(20, 20, 20, .045);
    }

    .date-pill span {
      color: var(--muted);
      font-size: 9px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .date-pill strong {
      font-size: 17px;
      font-weight: 850;
    }

    .date-pill.is-active {
      background: #111;
      border-color: #111;
      color: #fff;
    }

    .date-pill.is-active span {
      color: rgba(255, 255, 255, .72);
    }

    .month-card {
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 28px;
      background: #fff;
      box-shadow: 0 16px 36px rgba(20, 20, 20, .06);
    }

    .month-grid {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      gap: 6px;
    }

    .month-weekday {
      display: grid;
      min-height: 24px;
      place-items: center;
      color: var(--muted);
      font-size: 9px;
      font-weight: 850;
      text-transform: uppercase;
    }

    .month-day {
      position: relative;
      display: grid;
      min-height: 42px;
      place-items: center;
      border: 1px solid transparent;
      border-radius: 15px;
      color: #111;
      font-size: 13px;
      font-weight: 820;
    }

    .month-day.is-muted {
      color: #bebeb8;
    }

    .month-day.is-today {
      border-color: #111;
    }

    .month-day.has-events {
      background: #111;
      color: #fff;
    }

    .month-dot {
      position: absolute;
      right: 7px;
      bottom: 6px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
    }

    .detail-hero {
      padding: 18px;
      border-radius: 30px;
      background: #111;
      color: #fff;
      box-shadow: 0 24px 52px rgba(0, 0, 0, .24);
    }

    .detail-hero h1 {
      margin: 12px 0 8px;
      font-size: 24px;
      font-weight: 850;
      line-height: 1.12;
    }

    .detail-hero p {
      margin: 0;
      color: rgba(255, 255, 255, .72);
      font-size: 13px;
      line-height: 1.45;
    }

    .detail-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .detail-tile {
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: #fff;
    }

    .detail-tile span {
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .detail-tile strong {
      display: block;
      margin-top: 6px;
      color: #111;
      font-size: 14px;
      font-weight: 820;
      line-height: 1.28;
    }

    .empty-state {
      padding: 22px;
      border: 1px dashed #cfcfc8;
      border-radius: 26px;
      background: rgba(255,255,255,.58);
      color: var(--muted);
      text-align: center;
      font-size: 13px;
      font-weight: 700;
    }

    .pilot-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .pilot-stat {
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: var(--surface);
      box-shadow: 0 12px 28px rgba(20, 20, 20, .045);
    }

    .pilot-stat span {
      display: block;
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .pilot-stat strong {
      display: block;
      margin-top: 8px;
      font-size: 23px;
      font-weight: 780;
    }

    .pilot-list {
      display: grid;
      gap: 10px;
    }

    .pilot-item {
      display: block;
      padding: 15px;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: var(--surface);
      box-shadow: 0 10px 26px rgba(20, 20, 20, .04);
    }

    .pilot-item-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 8px;
    }

    .pilot-item strong {
      font-size: 15px;
      font-weight: 750;
    }

    .pilot-badge {
      display: inline-flex;
      align-items: center;
      min-height: 25px;
      padding: 4px 9px;
      border: 1px solid #d5d5ce;
      border-radius: 999px;
      background: #f2f2ef;
      color: #1d1d1b;
      font-size: 11px;
      font-weight: 800;
      white-space: nowrap;
    }

    .pilot-badge[data-status="in_progress"] { border-color: #d9d2bf; background: #fbf3df; color: var(--warning); }
    .pilot-badge[data-status="completed"] { border-color: #d6d6d1; background: #111; color: #fff; }
    .pilot-badge[data-status="cancelled"] { border-color: #ffc4c4; background: #fff0f0; color: var(--danger); }

    .pilot-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 42px;
      padding: 10px 14px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: #fff;
      color: var(--ink);
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 10px 22px rgba(20, 20, 20, .045);
      transition: transform 140ms ease, background 140ms ease, color 140ms ease, border-color 140ms ease;
    }

    .pilot-btn:hover,
    .pilot-btn:focus {
      border-color: #cfcfc8;
      background: #f8f8f6;
      transform: translateY(-1px);
    }

    .pilot-btn-primary {
      border-color: var(--ink);
      background: var(--ink);
      color: #fff;
    }

    .pilot-btn-primary:hover,
    .pilot-btn-primary:focus,
    .pilot-btn-primary:active {
      border-color: var(--ink-soft);
      background: var(--ink-soft);
      color: #fff;
    }

    .pilot-btn-danger {
      border-color: #ffc4c4;
      color: var(--danger);
    }

    .pilot-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 9px;
      margin-top: 12px;
    }

    .pilot-form {
      display: grid;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      gap: 12px;
    }

    .pilot-field {
      width: 100%;
      max-width: 100%;
      min-width: 0;
    }

    .pilot-field label {
      display: block;
      margin-bottom: 6px;
      color: #222;
      font-size: 12px;
      font-weight: 800;
    }

    .pilot-field input,
    .pilot-field select,
    .pilot-field textarea {
      box-sizing: border-box;
      display: block;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      min-height: 44px;
      padding: 10px 12px;
      border: 1px solid #d8d8d2;
      border-radius: 16px;
      background: #fff;
      color: var(--text);
      font: inherit;
      font-size: 14px;
      outline: none;
    }

    .pilot-field input[type="date"],
    .pilot-field input[type="time"],
    .pilot-field input[type="number"] {
      -webkit-appearance: none;
      appearance: none;
      line-height: 1.2;
    }

    .pilot-field textarea {
      min-height: 92px;
      resize: vertical;
    }

    .pilot-form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .pilot-alerts {
      display: grid;
      gap: 8px;
      margin-bottom: 12px;
    }

    .pilot-alert {
      padding: 12px 13px;
      border-radius: 14px;
      font-size: 13px;
      font-weight: 650;
    }


    .upload-drop {
      display: grid;
      gap: 10px;
      place-items: center;
      min-height: 132px;
      padding: 18px;
      border: 1px dashed #cfcfca;
      border-radius: 22px;
      background: #fafafa;
      text-align: center;
    }

    .upload-drop i {
      display: grid;
      width: 46px;
      height: 46px;
      place-items: center;
      border-radius: 50%;
      background: var(--ink);
      color: #fff;
      font-size: 18px;
    }

    .upload-drop strong {
      display: block;
      font-size: 15px;
    }

    .upload-drop span {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.35;
    }

    .upload-drop input {
      width: 100%;
      max-width: 100%;
      font-size: 12px;
    }

    .mission-summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 12px 0;
      border-top: 1px solid var(--line);
    }

    .mission-summary:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .mission-summary strong,
    .mission-summary small {
      display: block;
    }

    .mission-summary small {
      color: var(--muted);
      font-size: 12px;
      margin-top: 3px;
    }

    .pilot-alert-success { border: 1px solid #4ade80; background: #d9fbe8; color: #05703a; }
    .pilot-alert-error { border: 1px solid #ffb4b4; background: #fff0f0; color: #b91c1c; }

    .pilot-nav {
      position: fixed;
      right: 0;
      bottom: 34px;
      left: 0;
      z-index: 20;
      max-width: 520px;
      margin: 0 auto;
      padding: 8px 20px;
      border-top: 0;
      background: transparent;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }

    .pilot-nav::before {
      content: "";
      position: absolute;
      inset: 8px 20px;
      z-index: -1;
      border-radius: 26px;
      background: rgba(17, 17, 17, .96);
      box-shadow: 0 18px 42px rgba(0, 0, 0, .28);
    }

    .pilot-nav a {
      display: grid;
      place-items: center;
      gap: 3px;
      min-height: 44px;
      border-radius: 20px;
      color: rgba(255, 255, 255, .62);
      font-size: 9px;
      font-weight: 750;
    }

    .pilot-nav a.is-active {
      background: transparent;
      color: #fff;
    }

    .pilot-nav i {
      display: grid;
      width: 28px;
      height: 28px;
      place-items: center;
      border-radius: 50%;
      font-size: 14px;
    }

    .pilot-nav a.is-active i {
      background: #fff;
      color: var(--ink);
    }

    .pilot-login {
      display: grid;
      min-height: 100vh;
      place-items: center;
      padding: 20px 14px;
      background:
        radial-gradient(circle at 50% 10%, #ffffff 0, rgba(255,255,255,0) 18rem),
        linear-gradient(180deg, #f6f6f3, #e9e9e5);
    }

    .pilot-login-panel {
      width: min(100%, 420px);
      padding: 24px;
      border: 1px solid var(--line);
      border-radius: 30px;
      background: #fff;
      box-shadow: 0 24px 56px rgba(17, 17, 17, .12);
    }

    @media (max-width: 430px) {
      .pilot-form-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (min-width: 760px) {
      .pilot-shell,
      .pilot-nav {
        border-right: 1px solid var(--line);
        border-left: 1px solid var(--line);
      }
    }
  </style>
</head>
<body>
  {% block body %}{% endblock %}
</body>
</html>

