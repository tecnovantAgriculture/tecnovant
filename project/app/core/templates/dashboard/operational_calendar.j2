{% extends "base.j2" %}
{% set flush_content_shell = true %}

{% block extra_css %}
{{ super() }}
<style>
  .ops-calendar {
    display: grid;
    gap: 18px;
    color: #17221e;
  }

  .ops-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 18px;
  }

  .ops-eyebrow {
    color: #0f8a5f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  .ops-head h1 {
    margin: 6px 0 0;
    color: #10201b;
    font-size: 28px;
    font-weight: 600;
    line-height: 1.12;
  }

  .ops-muted {
    color: #6b766f;
    font-size: 13px;
    line-height: 1.5;
  }

  .ops-top-actions {
    display: flex;
    justify-content: flex-end;
  }

  .ops-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .ops-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid #dbe6dd;
    border-radius: 999px;
    background: #fff;
    color: #173f36;
    font-size: 13px;
    font-weight: 650;
    transition: background 140ms ease, border-color 140ms ease, transform 140ms ease;
  }

  .ops-btn:hover {
    border-color: #b8dfae;
    background: #f5fbf2;
    transform: translateY(-1px);
  }

  .ops-btn-primary {
    border-color: #173f36;
    background: #173f36;
    color: #f7fff7;
  }

  .ops-btn-primary:hover,
  .ops-btn-primary:focus,
  .ops-btn-primary:active {
    border-color: #235446;
    background: #235446;
    color: #f7fff7;
  }

  .ops-btn-danger {
    border-color: #fecaca;
    background: #fff7f7;
    color: #b91c1c;
  }

  .ops-stats {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
  }

  .ops-card {
    border: 1px solid #dfe8df;
    border-radius: 16px;
    background: rgba(255, 255, 255, .96);
    box-shadow: 0 10px 24px rgba(15, 23, 42, .05);
  }

  .ops-stat {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px;
  }

  .ops-stat-icon {
    display: inline-flex;
    width: 42px;
    height: 42px;
    min-width: 42px;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: #eef8ee;
    color: #173f36;
    font-size: 17px;
  }

  .ops-stat-icon[data-tone="blue"] { background: #eaf5ff; color: #075985; }
  .ops-stat-icon[data-tone="amber"] { background: #fff7e6; color: #9a5b05; }
  .ops-stat-icon[data-tone="green"] { background: #eaf9ef; color: #166534; }
  .ops-stat-icon[data-tone="red"] { background: #fff1f2; color: #be123c; }

  .ops-stat span {
    color: #7a867f;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .03em;
    text-transform: uppercase;
  }

  .ops-stat strong {
    display: block;
    margin-top: 8px;
    color: #10201b;
    font-size: 25px;
    font-weight: 600;
    line-height: 1;
  }

  .ops-stat {
    --kpi-accent: #173f36;
    --kpi-soft: #eef8ee;
    --kpi-progress: 0%;
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    min-height: 132px;
    overflow: hidden;
    padding: 18px;
    transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  }

  .ops-stat::before {
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: var(--kpi-accent);
    content: '';
  }

  .ops-stat:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--kpi-accent) 25%, #dfe8df);
    box-shadow: 0 14px 30px rgba(15, 23, 42, .09);
  }

  .ops-stat:nth-child(2) { --kpi-accent: #0875a5; --kpi-soft: #eaf5ff; }
  .ops-stat:nth-child(3) { --kpi-accent: #b66c06; --kpi-soft: #fff7e6; }
  .ops-stat:nth-child(4) { --kpi-accent: #168044; --kpi-soft: #eaf9ef; }
  .ops-stat:nth-child(5) { --kpi-accent: #d41f4b; --kpi-soft: #fff1f2; }

  .ops-stat .ops-stat-icon {
    background: var(--kpi-soft);
    color: var(--kpi-accent);
  }

  .ops-stat > div {
    min-width: 0;
  }

  .ops-stat strong {
    margin-top: 5px;
    font-size: clamp(27px, 2vw, 34px);
    font-weight: 750;
    letter-spacing: -.035em;
  }

  .ops-stat-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: 10px;
    color: #68766e;
    font-size: 10px;
    font-weight: 650;
  }

  .ops-stat-rate {
    color: var(--kpi-accent);
    font-size: 11px;
    font-weight: 800;
  }

  .ops-stat-progress {
    position: relative;
    grid-column: 1 / -1;
    height: 4px;
    margin-top: 4px;
    overflow: hidden;
    border-radius: 999px;
    background: #e8eee9;
  }

  .ops-stat-progress::after {
    position: absolute;
    inset: 0 auto 0 0;
    width: var(--kpi-progress);
    border-radius: inherit;
    background: var(--kpi-accent);
    content: '';
    transition: width .35s ease;
  }

  /* KPI compactos, consistentes con la pantalla de Facturacion */
  .ops-stats {
    gap: 8px;
  }

  .ops-stat {
    position: relative;
    display: block;
    min-height: 98px;
    overflow: visible;
    padding: 12px;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, .08);
    transition: box-shadow .2s ease, border-color .2s ease;
  }

  .ops-stat::before,
  .ops-stat-progress {
    display: none;
  }

  .ops-stat:hover {
    transform: none;
    border-color: #d1d5db;
    box-shadow: 0 4px 12px rgba(15, 23, 42, .08);
  }

  .ops-stat .ops-stat-icon {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    min-width: 32px;
    border-radius: 12px;
    font-size: 14px;
  }

  .ops-stat > div {
    min-width: 0;
    padding-right: 42px;
  }

  .ops-stat span {
    font-size: 10px;
    font-weight: 650;
    letter-spacing: .04em;
  }

  .ops-stat strong {
    margin-top: 20px;
    font-size: 19px;
    font-weight: 650;
    letter-spacing: 0;
  }

  .ops-stat-meta {
    display: block;
    margin-top: 8px;
    color: #6b7280;
    font-size: 10px;
    font-weight: 400;
  }

  .ops-stat-rate {
    display: none;
  }
  .ops-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 16px;
    align-items: start;
  }

  .ops-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px;
    border-bottom: 1px solid #edf2ed;
  }

  .ops-period {
    color: #10201b;
    font-size: 17px;
    font-weight: 600;
  }

  .ops-segment {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    border: 1px solid #dfe8df;
    border-radius: 999px;
    background: #f8faf8;
  }

  .ops-segment button {
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    color: #657168;
    font-size: 12px;
    font-weight: 650;
  }

  .ops-segment button.is-active {
    background: #173f36;
    color: #fff;
  }

  .ops-calendar-body {
    padding: 16px;
  }

  .ops-month-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    border-top: 1px solid #edf2ed;
    border-left: 1px solid #edf2ed;
  }

  .ops-month-week {
    position: relative;
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
  }

  .ops-month-week .ops-day {
    grid-row: 1;
    min-width: 0;
  }

  .ops-range-event {
    z-index: 2;
    align-self: start;
    margin: 0 3px;
    min-width: 0;
    overflow: hidden;
    border-radius: 7px;
    box-shadow: 0 1px 2px rgba(22, 101, 52, .12);
  }

  .ops-range-event.is-range-start {
    margin-left: 10px;
  }

  .ops-range-event.is-range-end {
    margin-right: 10px;
  }

  .ops-range-event:not(.is-range-start) {
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
  }

  .ops-range-event:not(.is-range-end) {
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
  }

  .ops-range-event .ops-event__title,
  .ops-range-event .ops-event__detail {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ops-weekday {
    padding: 10px;
    border-right: 1px solid #edf2ed;
    color: #7a867f;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .ops-day {
    min-height: 118px;
    padding: 10px;
    border-right: 1px solid #edf2ed;
    border-bottom: 1px solid #edf2ed;
    background: #fff;
    cursor: pointer;
  }

  .ops-day:hover {
    background: #f8fbf7;
  }

  .ops-day.is-muted {
    background: #fafafa;
    color: #a0a8a3;
  }

  .ops-day-number {
    font-size: 12px;
    font-weight: 650;
  }

  .ops-event {
    margin-top: 7px;
    padding: 7px 8px;
    border-radius: 9px;
    background: #ecfdf3;
    color: #166534;
    font-size: 11px;
    font-weight: 650;
    line-height: 1.25;
    cursor: pointer;
  }

  .ops-event__title,
  .ops-event__detail {
    display: block;
  }

  .ops-event__detail {
    margin-top: 2px;
    font-size: 10px;
    font-weight: 550;
    opacity: .82;
  }

  .ops-event__timeline {
    position: relative;
    display: block;
    height: 4px;
    margin-top: 6px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(22, 101, 52, .16);
  }

  .ops-event__timeline > span {
    position: absolute;
    top: 0;
    bottom: 0;
    min-width: 4px;
    border-radius: inherit;
    background: currentColor;
  }

  .ops-event__time {
    display: flex;
    justify-content: space-between;
    margin-top: 3px;
    font-size: 9px;
    font-weight: 650;
    opacity: .82;
  }
  .ops-event[data-status="completed"] {
    background: #edf7ed;
    color: #267142;
  }

  .ops-event[data-status="cancelled"] {
    background: #fff1f2;
    color: #be123c;
  }

  .ops-event[data-status="in_progress"] {
    background: #fff7ed;
    color: #c2410c;
  }

  .ops-time-list {
    display: grid;
    gap: 8px;
  }

  .ops-time-row {
    display: grid;
    grid-template-columns: 76px minmax(0, 1fr);
    gap: 10px;
    min-height: 52px;
    border-bottom: 1px solid #edf2ed;
  }

  .ops-time-slot {
    color: #7a867f;
    font-size: 12px;
    font-weight: 650;
    padding-top: 10px;
  }

  .ops-time-drop {
    padding: 8px;
    cursor: pointer;
  }

  .ops-side {
    display: grid;
    gap: 14px;
  }

  .ops-side-head {
    padding: 16px 16px 0;
  }

  .ops-side-list {
    display: grid;
    gap: 8px;
    padding: 12px 16px 16px;
  }

  .ops-list-item {
    display: grid;
    gap: 5px;
    padding: 11px;
    border: 1px solid #edf2ed;
    border-radius: 12px;
    background: #fff;
    cursor: pointer;
  }

  .ops-list-item strong {
    color: #17221e;
    font-size: 13px;
    font-weight: 650;
  }

  .ops-badge {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    min-height: 24px;
    padding: 0 9px;
    border-radius: 999px;
    background: #eef4ed;
    color: #526158;
    font-size: 11px;
    font-weight: 650;
  }

  .ops-badge[data-status="completed"] {
    background: #dcfce7;
    color: #166534;
  }

  .ops-badge[data-status="cancelled"] {
    background: #ffe4e6;
    color: #be123c;
  }

  .ops-badge[data-status="scheduled"] {
    background: #e0f2fe;
    color: #075985;
  }

  .ops-modal {
    position: fixed;
    inset: 0;
    z-index: 70;
    display: none;
    overflow-y: auto;
    padding: 24px;
  }

  .ops-modal.is-open {
    display: grid;
    place-items: center;
  }

  .ops-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, .48);
    backdrop-filter: blur(4px);
  }

  .ops-modal-panel {
    position: relative;
    width: min(100%, 760px);
    border: 1px solid #dfe8df;
    border-radius: 16px;
    background: #fff;
    padding: 20px;
    box-shadow: 0 24px 70px rgba(15, 23, 42, .22);
  }

  .ops-modal-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    padding-bottom: 16px;
    border-bottom: 1px solid #edf2ed;
  }

  .ops-modal-head h2 {
    margin: 0;
    color: #17221e;
    font-size: 19px;
    font-weight: 650;
  }

  .ops-form {
    display: grid;
    gap: 14px;
    margin-top: 16px;
  }

  .ops-form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .ops-field {
    display: grid;
    gap: 7px;
  }

  .ops-field label {
    color: #46564d;
    font-size: 12px;
    font-weight: 650;
  }

  .ops-field input,
  .ops-field select,
  .ops-field textarea {
    width: 100%;
    min-height: 40px;
    border: 1px solid #d6e0d8;
    border-radius: 10px;
    background: #fff;
    padding: 0 12px;
    color: #17221e;
    font-size: 13px;
    outline: none;
  }

  .ops-field textarea {
    min-height: 78px;
    padding-top: 10px;
    resize: vertical;
  }

  .ops-form-alert {
    display: none;
    border: 1px solid #fecaca;
    border-radius: 10px;
    background: #fff7f7;
    padding: 10px 12px;
    color: #b91c1c;
    font-size: 13px;
  }

  .ops-form-alert.is-open {
    display: block;
  }

  .ops-modal-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 4px;
  }

  @media (max-width: 1100px) {
    /* KPI compactos, consistentes con la pantalla de Facturacion */
  .ops-stats {
    gap: 8px;
  }

  .ops-stat {
    position: relative;
    display: block;
    min-height: 98px;
    overflow: visible;
    padding: 12px;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, .08);
    transition: box-shadow .2s ease, border-color .2s ease;
  }

  .ops-stat::before,
  .ops-stat-progress {
    display: none;
  }

  .ops-stat:hover {
    transform: none;
    border-color: #d1d5db;
    box-shadow: 0 4px 12px rgba(15, 23, 42, .08);
  }

  .ops-stat .ops-stat-icon {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    min-width: 32px;
    border-radius: 12px;
    font-size: 14px;
  }

  .ops-stat > div {
    min-width: 0;
    padding-right: 42px;
  }

  .ops-stat span {
    font-size: 10px;
    font-weight: 650;
    letter-spacing: .04em;
  }

  .ops-stat strong {
    margin-top: 20px;
    font-size: 19px;
    font-weight: 650;
    letter-spacing: 0;
  }

  .ops-stat-meta {
    display: block;
    margin-top: 8px;
    color: #6b7280;
    font-size: 10px;
    font-weight: 400;
  }

  .ops-stat-rate {
    display: none;
  }
  .ops-shell {
      grid-template-columns: 1fr;
    }

    .ops-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .ops-head,
    .ops-toolbar,
    .ops-form-grid {
      grid-template-columns: 1fr;
      align-items: flex-start;
      flex-direction: column;
    }

    .ops-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
{% endblock %}

{% block content %}
<div class="ops-calendar"
     data-create-activity-url="{{ url_for('core.operational_calendar_create_activity') }}"
     data-create-pilot-url="{{ url_for('core.operational_calendar_create_pilot') }}">
    <section class="ops-top-actions">
    <div class="ops-actions">
      <a class="ops-btn" href="{{ url_for('core.operation_executions') }}">
        <i class="fas fa-tasks"></i>
        Ejecuciones
      </a>
      <button type="button" class="ops-btn" data-open-pilot>
        <i class="fas fa-user-plus"></i>
        Registrar piloto
      </button>
      <button type="button" class="ops-btn ops-btn-primary" data-open-activity>
        <i class="fas fa-plus"></i>
        Nueva solicitud
      </button>
    </div>
  </section>
<section class="ops-stats">
    <article class="ops-card ops-stat">
      <i class="ops-stat-icon fas fa-calendar-day"></i>
      <div><span>Hoy</span><strong data-stat="today">{{ stats.today }}</strong></div>
    </article>
    <article class="ops-card ops-stat">
      <i class="ops-stat-icon fas fa-calendar-week" data-tone="blue"></i>
      <div><span>Semana</span><strong data-stat="week">{{ stats.week }}</strong></div>
    </article>
    <article class="ops-card ops-stat">
      <i class="ops-stat-icon fas fa-hourglass-half" data-tone="amber"></i>
      <div><span>Pendientes</span><strong data-stat="pending">{{ stats.pending }}</strong></div>
    </article>
    <article class="ops-card ops-stat">
      <i class="ops-stat-icon fas fa-check-circle" data-tone="green"></i>
      <div><span>Finalizadas</span><strong data-stat="completed">{{ stats.completed }}</strong></div>
    </article>
    <article class="ops-card ops-stat">
      <i class="ops-stat-icon fas fa-ban" data-tone="red"></i>
      <div><span>Canceladas</span><strong data-stat="cancelled">{{ stats.cancelled }}</strong></div>
    </article>
  </section>

  <section class="ops-shell">
    <article class="ops-card">
      <div class="ops-toolbar">
        <div class="ops-actions">
          <button type="button" class="ops-btn" data-calendar-prev><i class="fas fa-chevron-left"></i></button>
          <button type="button" class="ops-btn" data-calendar-today>Hoy</button>
          <button type="button" class="ops-btn" data-calendar-next><i class="fas fa-chevron-right"></i></button>
        </div>
        <div class="ops-period" data-calendar-title></div>
        <div class="ops-actions">
          <div class="ops-segment">
            <button type="button" data-calendar-view="day">Dia</button>
            <button type="button" data-calendar-view="week">Semana</button>
            <button type="button" data-calendar-view="month" class="is-active">Mes</button>
          </div>
        </div>
      </div>
      <div class="ops-calendar-body" data-calendar-body></div>
    </article>
  </section>
</div>

<div id="activity-modal" class="ops-modal" aria-hidden="true" role="dialog" aria-labelledby="activity-modal-title">
  <div class="ops-modal-backdrop" data-close-modal></div>
  <div class="ops-modal-panel">
    <div class="ops-modal-head">
      <div>
        <p class="ops-eyebrow">Agenda</p>
        <h2 id="activity-modal-title">Nueva solicitud</h2>
      </div>
      <button type="button" class="ops-btn" data-close-modal><i class="fas fa-times"></i></button>
    </div>
    <form id="activity-form" class="ops-form">
      <input type="hidden" name="activity_id" id="activity_id">
      <div id="activity-alert" class="ops-form-alert"></div>
      <div class="ops-form-grid">
        <div class="ops-field">
          <label for="activity_title">Titulo</label>
          <input id="activity_title" name="title" required placeholder="Ej: Vuelo finca La Esperanza">
        </div>
        <div class="ops-field">
          <label for="operation_type">Tipo de operacion</label>
          <select id="operation_type" name="operation_type" required>
            <option value="">Seleccionar</option>
            <option>Vuelo fotogrametrico</option>
            <option>Inspeccion</option>
            <option>Aplicacion agricola</option>
            <option>Fumigacion agricola</option>
            <option>Levantamiento topografico</option>
            <option>Visita tecnica</option>
          </select>
        </div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field">
          <label for="start_date">Fecha de inicio</label>
          <input id="start_date" name="start_date" required type="date">
        </div>
        <div class="ops-field">
          <label for="end_date">Fecha fin</label>
          <input id="end_date" name="end_date" required type="date">
        </div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field">
          <label for="start_time">Hora inicio</label>
          <input id="start_time" name="start_time" required type="time">
        </div>
        <div class="ops-field">
          <label for="end_time">Hora fin</label>
          <input id="end_time" name="end_time" required type="time">
        </div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field">
          <label for="place">Lugar</label>
          <input id="place" name="place" required placeholder="Municipio / finca / zona">
        </div>
        <div class="ops-field">
          <label for="organization_id">Cliente</label>
          <select id="organization_id" name="organization_id" required>
            <option value="">Seleccionar cliente</option>
            {% for client in clients %}
              <option value="{{ client.id }}">{{ client.name }}</option>
            {% endfor %}
          </select>
          <input id="client_project" name="client_project" type="hidden">
        </div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field">
          <label for="farm_id" style="display:flex;align-items:center;justify-content:space-between;">
            <span>Finca</span>
            <button type="button" id="calendar-new-farm-toggle" class="ops-btn" style="min-height:26px;padding:0 8px;" title="Crear nueva finca"><i class="fas fa-pencil-alt"></i></button>
          </label>
          <select id="farm_id" name="farm_id">
            <option value="">Seleccionar finca</option>
          </select>
          <input id="farm_name_manual" placeholder="Escribir finca">
          <input id="farm_name" name="farm_name" type="hidden" required>
        </div>
        <div class="ops-field">
          <label for="lot_id" style="display:flex;align-items:center;justify-content:space-between;">
            <span>Potrero (lote)</span>
            <button type="button" id="calendar-new-lot-toggle" class="ops-btn" style="min-height:26px;padding:0 8px;" title="Crear nuevo potrero"><i class="fas fa-pencil-alt"></i></button>
          </label>
          <select id="lot_id" name="lot_id">
            <option value="">Seleccionar lote</option>
          </select>
          <input id="lot_code_manual" placeholder="Nombre del nuevo potrero">
          <input id="lot_code" name="lot_code" type="hidden">
        </div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field">
          <label for="area_hectares">Area</label>
          <input id="area_hectares" name="area_hectares" inputmode="decimal" placeholder="Ej: 9,9">
        </div>
        <div class="ops-field">
          <label for="unit_price">Valor por hectarea</label>
          <input id="unit_price" name="unit_price" type="number" min="0" step="0.01" placeholder="Ej: 150000">
        </div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field">
          <label for="rest_days">Dias de descanso</label>
          <input id="rest_days" name="rest_days" type="number" min="0" step="1" placeholder="Ej: 10">
        </div>
      </div>
      <div class="ops-field">
        <label for="paddocks">Potreros</label>
        <textarea id="paddocks" name="paddocks" placeholder="Ej: 42, 41, 9, 8, 7, 20, 15, 14, 12"></textarea>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field">
          <label for="pilot_id">Piloto</label>
          <select id="pilot_id" name="pilot_id" required>
            <option value="">Seleccionar piloto</option>
            {% for pilot in pilots %}
              <option value="{{ pilot.id }}">{{ pilot.full_name }} - {{ pilot.certification_status }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="ops-field">
          <label for="drone_id">Dron</label>
          <select id="drone_id" name="drone_id" required>
            <option value="">Seleccionar dron</option>
            {% for drone in drones %}
              <option value="{{ drone.id }}">{{ drone.brand }} {{ drone.model }} - {{ drone.serial_number }}{% if drone.status != "Aeronavegable" %} ({{ drone.status }}){% endif %}</option>
            {% endfor %}
          </select>
        </div>
      </div>
      <div class="ops-field">
        <label for="pilot_portal_link">Comparte este link con el piloto para que pueda ingresar a su panel</label>
        <input id="pilot_portal_link" readonly value="{{ url_for('core.pilot_login', _external=True) }}">
      </div>
      <div class="ops-form-grid">
        <div class="ops-field">
          <label for="activity_status">Estado</label>
          <select id="activity_status" name="status">
            <option value="scheduled">Pendiente</option>
            <option value="in_progress">En proceso</option>
          </select>
        </div>
        <div class="ops-field">
          <label>Duracion</label>
          <input id="duration_preview" readonly value="0 min">
        </div>
      </div>
      <div class="ops-field">
        <label for="observations">Observaciones</label>
        <textarea id="observations" name="observations" placeholder="Notas operativas, restricciones o detalles del vuelo"></textarea>
      </div>
      <div class="ops-modal-actions">
        <button type="button" class="ops-btn ops-btn-danger hidden" data-cancel-activity>Cancelar solicitud</button>
        <button type="button" class="ops-btn hidden" data-complete-activity>Finalizar</button>
        <button type="button" class="ops-btn" data-close-modal>Cerrar</button>
        <button type="submit" class="ops-btn ops-btn-primary">Guardar solicitud</button>
      </div>
    </form>
  </div>
</div>

<div id="pilot-modal" class="ops-modal" aria-hidden="true" role="dialog" aria-labelledby="pilot-modal-title">
  <div class="ops-modal-backdrop" data-close-pilot></div>
  <div class="ops-modal-panel">
    <div class="ops-modal-head">
      <div>
        <p class="ops-eyebrow">Pilotos</p>
        <h2 id="pilot-modal-title">Registrar piloto</h2>
      </div>
      <button type="button" class="ops-btn" data-close-pilot><i class="fas fa-times"></i></button>
    </div>
    <form id="pilot-form" class="ops-form">
      <div id="pilot-alert" class="ops-form-alert"></div>
      <div class="ops-form-grid">
        <div class="ops-field"><label for="pilot_username">Usuario</label><input id="pilot_username" name="username" required></div>
        <div class="ops-field"><label for="pilot_password">Clave</label><input id="pilot_password" name="password" required type="password"></div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field"><label for="first_name">Nombres</label><input id="first_name" name="first_name" required></div>
        <div class="ops-field"><label for="last_name">Apellidos</label><input id="last_name" name="last_name" required></div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field"><label for="document_number">Documento</label><input id="document_number" name="document_number"></div>
        <div class="ops-field"><label for="pilot_role">Rol</label><input id="pilot_role" name="role" value="pilot"></div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field"><label for="pilot_phone">Telefono</label><input id="pilot_phone" name="phone"></div>
        <div class="ops-field"><label for="pilot_email">Email</label><input id="pilot_email" name="email" type="email"></div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field"><label for="certification_name">Certificacion</label><input id="certification_name" name="certification_name" placeholder="UAS / UAEAC / DJI"></div>
        <div class="ops-field"><label for="certificate_number">Numero certificado</label><input id="certificate_number" name="certificate_number"></div>
      </div>
      <div class="ops-form-grid">
        <div class="ops-field"><label for="certification_issuer">Emisor</label><input id="certification_issuer" name="certification_issuer"></div>
        <div class="ops-field"><label for="certification_expires_at">Vence</label><input id="certification_expires_at" name="certification_expires_at" type="date"></div>
      </div>
      <div class="ops-modal-actions">
        <button type="button" class="ops-btn" data-close-pilot>Cerrar</button>
        <button type="submit" class="ops-btn ops-btn-primary">Guardar piloto</button>
      </div>
    </form>
  </div>
</div>
{% endblock %}

{% block extra_js %}
{{ super() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
  let activities = {{ activities_json | tojson }};
  const clients = {{ clients_json | tojson }};
  const farms = {{ farms_json | tojson }};
  const lots = {{ lots_json | tojson }};
  let currentDate = new Date();
  let currentView = 'month';
  let activeActivity = null;

  const root = document.querySelector('.ops-calendar');
  const calendarBody = document.querySelector('[data-calendar-body]');
  const calendarTitle = document.querySelector('[data-calendar-title]');
  const activityModal = document.getElementById('activity-modal');
  const pilotModal = document.getElementById('pilot-modal');
  const activityForm = document.getElementById('activity-form');
  const pilotForm = document.getElementById('pilot-form');
  const activityAlert = document.getElementById('activity-alert');
  const pilotAlert = document.getElementById('pilot-alert');
  const cancelBtn = document.querySelector('[data-cancel-activity]');
  const completeBtn = document.querySelector('[data-complete-activity]');
  const organizationSelect = document.getElementById('organization_id');
  const farmSelect = document.getElementById('farm_id');
  const lotSelect = document.getElementById('lot_id');
  const clientProjectInput = document.getElementById('client_project');
  const farmNameInput = document.getElementById('farm_name');
  const farmNameManual = document.getElementById('farm_name_manual');
  const lotCodeInput = document.getElementById('lot_code');
  const lotCodeManual = document.getElementById('lot_code_manual');
  const newFarmToggle = document.getElementById('calendar-new-farm-toggle');
  const newLotToggle = document.getElementById('calendar-new-lot-toggle');
  let forceNewFarm = false;
  let forceNewLot = false;

  function pad(value) { return String(value).padStart(2, '0'); }
  function dateKey(date) { return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`; }
  function parseDate(value) {
    const parts = value.split('-').map(Number);
    return new Date(parts[0], parts[1] - 1, parts[2]);
  }
  function prettyMonth(date) {
    return date.toLocaleDateString('es-CO', { month: 'long', year: 'numeric' });
  }
  function showAlert(element, message) {
    element.textContent = message;
    element.classList.add('is-open');
  }
  function clearAlert(element) {
    element.textContent = '';
    element.classList.remove('is-open');
  }
  function optionText(select) {
    const option = select.options[select.selectedIndex];
    return option && option.value ? option.textContent.trim() : '';
  }
  function findClientId(name) {
    const match = clients.find(item => item.name === name);
    return match ? String(match.id) : '';
  }
  function findFarmId(name, organizationId) {
    const match = farms.find(item => item.name === name && String(item.organization_id) === String(organizationId));
    return match ? String(match.id) : '';
  }
  function findLotId(name, farmId) {
    const match = lots.find(item => item.name === name && String(item.farm_id) === String(farmId));
    return match ? String(match.id) : '';
  }
  function renderFarmOptions(organizationId, selectedId) {
    const available = farms.filter(item => String(item.organization_id) === String(organizationId));
    farmSelect.innerHTML = '<option value="">Seleccionar finca</option>' + available.map(item => `<option value="${item.id}">${item.name}</option>`).join('');
    farmSelect.value = selectedId ? String(selectedId) : '';
    const manualMode = forceNewFarm || available.length === 0;
    farmSelect.style.display = manualMode ? 'none' : '';
    farmSelect.disabled = manualMode;
    farmNameManual.style.display = manualMode ? '' : 'none';
    farmNameManual.required = manualMode;
    if (!manualMode) farmNameManual.value = '';
    farmNameInput.value = manualMode ? farmNameManual.value.trim() : optionText(farmSelect);
  }
  function renderLotOptions(farmId, selectedId) {
    const available = lots.filter(item => String(item.farm_id) === String(farmId));
    lotSelect.innerHTML = '<option value="">Seleccionar lote</option>' + available.map(item => `<option value="${item.id}" data-area="${item.area || ''}">${item.name}</option>`).join('');
    lotSelect.value = selectedId ? String(selectedId) : '';
    const manualMode = forceNewLot || available.length === 0;
    lotSelect.style.display = manualMode ? 'none' : '';
    lotSelect.disabled = manualMode;
    lotCodeManual.style.display = manualMode ? '' : 'none';
    lotCodeManual.required = manualMode;
    if (!manualMode) lotCodeManual.value = '';
    lotCodeInput.value = manualMode ? lotCodeManual.value.trim() : optionText(lotSelect);
  }
  function syncCatalogFields() {
    clientProjectInput.value = optionText(organizationSelect);
    farmNameInput.value = farmSelect.style.display === 'none' ? farmNameManual.value.trim() : optionText(farmSelect);
    lotCodeInput.value = lotSelect.style.display === 'none' ? lotCodeManual.value.trim() : optionText(lotSelect);
  }
  function csrfToken() {
    if (typeof getCsrfToken === 'function') return getCsrfToken();
    const meta = document.querySelector('meta[name="csrf-token"]');
    return meta ? meta.content : '';
  }
  async function postForm(url, form) {
    const response = await fetch(url, {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'X-CSRF-TOKEN': csrfToken(), 'X-Requested-With': 'XMLHttpRequest' },
      body: new FormData(form)
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok || !data.success) throw new Error(data.message || 'No se pudo guardar.');
    return data;
  }
  function eventsForDay(day) {
    return activities.filter(item => item.date === day).sort((a, b) => a.start_time.localeCompare(b.start_time));
  }
  function eventHtml(event) {
    const lot = event.lot_code || event.paddocks || 'Sin lote/potrero';
    const client = event.final_client || '';
    return `<div class="ops-event" data-activity-id="${event.id}" data-status="${event.status}">
      <span class="ops-event__title">${event.farm_name || event.title}</span>
      <span class="ops-event__detail">${lot}${client ? ` · ${client}` : ''}</span>
      <span class="ops-event__time"><span>${event.start_time}</span><span>${event.end_time}</span></span>
    </div>`;
  }

  function addDays(date, amount) {
    const result = new Date(date);
    result.setDate(result.getDate() + amount);
    return result;
  }

  function dayDistance(from, to) {
    return Math.round((parseDate(to) - parseDate(from)) / 86400000);
  }

  function rangeEventHtml(event, weekStart, weekEnd, track) {
    const rangeStart = event.program_start || event.start_date || event.date;
    const rangeEnd = event.program_end || event.end_date || rangeStart;
    const clippedStart = rangeStart < weekStart ? weekStart : rangeStart;
    const clippedEnd = rangeEnd > weekEnd ? weekEnd : rangeEnd;
    const startColumn = dayDistance(weekStart, clippedStart) + 1;
    const endColumn = dayDistance(weekStart, clippedEnd) + 2;
    const lot = event.lot_code || event.paddocks || 'Sin lote/potrero';
    const client = event.final_client || '';
    const startClass = rangeStart >= weekStart ? ' is-range-start' : '';
    const endClass = rangeEnd <= weekEnd ? ' is-range-end' : '';
    return `<div class="ops-event ops-range-event${startClass}${endClass}" data-activity-id="${event.id}" data-status="${event.status}" style="grid-column:${startColumn}/${endColumn};grid-row:1;margin-top:${34 + track * 58}px">
      <span class="ops-event__title">${event.farm_name || event.title}</span>
      <span class="ops-event__detail">${lot}${client ? ` · ${client}` : ''} · ${rangeStart} a ${rangeEnd}</span>
    </div>`;
  }

  function renderMonth() {
    const first = new Date(currentDate.getFullYear(), currentDate.getMonth(), 1);
    const calendarStart = new Date(first);
    calendarStart.setDate(first.getDate() - ((first.getDay() + 6) % 7));
    calendarTitle.textContent = prettyMonth(currentDate);
    let html = '<div class="ops-month-grid">';
    ['Lun', 'Mar', 'Mie', 'Jue', 'Vie', 'Sab', 'Dom'].forEach(day => html += `<div class="ops-weekday">${day}</div>`);
    html += '</div>';

    for (let week = 0; week < 6; week++) {
      const weekStartDate = addDays(calendarStart, week * 7);
      const weekEndDate = addDays(weekStartDate, 6);
      const weekStart = dateKey(weekStartDate);
      const weekEnd = dateKey(weekEndDate);
      const weekEvents = activities
        .filter(event => {
          const rangeStart = event.program_start || event.start_date || event.date;
          const rangeEnd = event.program_end || event.end_date || rangeStart;
          return rangeStart <= weekEnd && rangeEnd >= weekStart;
        })
        .sort((a, b) => {
          const startCompare = (a.program_start || a.start_date || a.date).localeCompare(b.program_start || b.start_date || b.date);
          return startCompare || (a.program_end || a.end_date || a.date).localeCompare(b.program_end || b.end_date || b.date);
        });
      const tracks = [];
      const positioned = weekEvents.map(event => {
        const clippedStart = [event.program_start || event.start_date || event.date, weekStart].sort().pop();
        const clippedEnd = [event.program_end || event.end_date || event.date, weekEnd].sort()[0];
        let track = tracks.findIndex(occupiedUntil => occupiedUntil < clippedStart);
        if (track < 0) {
          track = tracks.length;
          tracks.push(clippedEnd);
        } else {
          tracks[track] = clippedEnd;
        }
        return { event, track };
      });
      const weekHeight = Math.max(118, 42 + tracks.length * 58);
      html += '<div class="ops-month-week">';
      for (let dayIndex = 0; dayIndex < 7; dayIndex++) {
        const cell = addDays(weekStartDate, dayIndex);
        const key = dateKey(cell);
        const muted = cell.getMonth() !== currentDate.getMonth() ? ' is-muted' : '';
        html += `<div class="ops-day${muted}" data-day="${key}" data-time="08:00" style="grid-column:${dayIndex + 1};min-height:${weekHeight}px">
          <div class="ops-day-number">${cell.getDate()}</div>
        </div>`;
      }
      positioned.forEach(item => html += rangeEventHtml(item.event, weekStart, weekEnd, item.track));
      html += '</div>';
    }
    calendarBody.innerHTML = html;
  }

  function renderTimeList(days) {
    calendarTitle.textContent = days.length === 1
      ? days[0].toLocaleDateString('es-CO', { weekday: 'long', day: 'numeric', month: 'long' })
      : `${days[0].toLocaleDateString('es-CO', { day: 'numeric', month: 'short' })} - ${days[days.length - 1].toLocaleDateString('es-CO', { day: 'numeric', month: 'short' })}`;
    let html = '<div class="ops-time-list">';
    days.forEach(day => {
      html += `<div class="ops-weekday">${day.toLocaleDateString('es-CO', { weekday: 'long', day: 'numeric', month: 'short' })}</div>`;
      for (let hour = 6; hour <= 18; hour++) {
        const key = dateKey(day);
        const time = `${pad(hour)}:00`;
        const matching = eventsForDay(key).filter(event => event.start_time.slice(0, 2) === pad(hour));
        html += `<div class="ops-time-row">
          <div class="ops-time-slot">${time}</div>
          <div class="ops-time-drop" data-day="${key}" data-time="${time}">
            ${matching.map(eventHtml).join('')}
          </div>
        </div>`;
      }
    });
    html += '</div>';
    calendarBody.innerHTML = html;
  }
  function statusLabel(status) {
    return { scheduled: 'Pendiente', in_progress: 'En proceso', completed: 'Finalizada', cancelled: 'Cancelada' }[status] || status;
  }
  function enhanceStats() {
    const descriptions = [
      'Agenda del día',
      'Carga semanal',
      'Por ejecutar',
      'Operaciones completadas',
      'Operaciones canceladas'
    ];
    document.querySelectorAll('.ops-stat').forEach((card, index) => {
      let meta = card.querySelector('.ops-stat-meta');
      if (!meta) {
        meta = document.createElement('div');
        meta.className = 'ops-stat-meta';
        card.querySelector('div').appendChild(meta);
      }
      meta.textContent = descriptions[index] || '';
      const progress = card.querySelector('.ops-stat-progress');
      if (progress) progress.remove();
    });
  }
  function renderStats() {
    const today = dateKey(new Date());
    const now = new Date();
    const weekStart = new Date(now);
    weekStart.setDate(now.getDate() - ((now.getDay() + 6) % 7));
    const weekEnd = new Date(weekStart);
    weekEnd.setDate(weekStart.getDate() + 7);
    document.querySelector('[data-stat="today"]').textContent = activities.filter(item => item.date === today).length;
    document.querySelector('[data-stat="week"]').textContent = activities.filter(item => {
      const date = parseDate(item.date);
      return date >= weekStart && date < weekEnd;
    }).length;
    document.querySelector('[data-stat="pending"]').textContent = activities.filter(item => item.status === 'scheduled').length;
    document.querySelector('[data-stat="completed"]').textContent = activities.filter(item => item.status === 'completed').length;
    document.querySelector('[data-stat="cancelled"]').textContent = activities.filter(item => item.status === 'cancelled').length;
    enhanceStats();
  }
  function render() {
    document.querySelectorAll('[data-calendar-view]').forEach(button => button.classList.toggle('is-active', button.dataset.calendarView === currentView));
    if (currentView === 'month') renderMonth();
    if (currentView === 'day') renderTimeList([currentDate]);
    if (currentView === 'week') {
      const start = new Date(currentDate);
      start.setDate(currentDate.getDate() - ((currentDate.getDay() + 6) % 7));
      renderTimeList(Array.from({ length: 7 }, (_, index) => {
        const day = new Date(start);
        day.setDate(start.getDate() + index);
        return day;
      }));
    }
    renderStats();
  }
  function openActivityModal(date, time, event) {
    clearAlert(activityAlert);
    activityForm.reset();
    forceNewFarm = false;
    forceNewLot = false;
    activeActivity = event || null;
    organizationSelect.value = '';
    renderFarmOptions('', '');
    renderLotOptions('', '');
    syncCatalogFields();
    document.getElementById('activity-modal-title').textContent = event ? 'Editar solicitud' : 'Nueva solicitud';
    document.getElementById('activity_id').value = event ? event.id : '';
    document.getElementById('start_date').value = event ? event.start_date : (date || dateKey(currentDate));
    document.getElementById('end_date').value = event ? event.end_date : (date || dateKey(currentDate));
    document.getElementById('start_time').value = event ? event.start_time : (time || '08:00');
    document.getElementById('end_time').value = event ? event.end_time : '09:00';
    if (event) {
      document.getElementById('activity_title').value = event.title;
      document.getElementById('operation_type').value = event.operation_type;
      document.getElementById('place').value = event.place;
      const organizationId = event.organization_id || findClientId(event.client_project);
      organizationSelect.value = organizationId ? String(organizationId) : '';
      const farmId = event.farm_id || findFarmId(event.farm_name || '', organizationSelect.value);
      forceNewFarm = !farmId && Boolean(event.farm_name);
      renderFarmOptions(organizationSelect.value, farmId);
      if (!farmId) farmNameManual.value = event.farm_name || '';
      const lotId = event.lot_id || findLotId(event.lot_code || '', farmSelect.value);
      forceNewLot = !lotId && Boolean(event.lot_code);
      renderLotOptions(farmSelect.value, lotId);
      if (!lotId) lotCodeManual.value = event.lot_code || '';
      syncCatalogFields();
      document.getElementById('area_hectares').value = event.area_hectares || '';
      document.getElementById('unit_price').value = event.unit_price || '';
      document.getElementById('rest_days').value = event.rest_days || '';
      document.getElementById('paddocks').value = event.paddocks || '';
      document.getElementById('pilot_id').value = event.pilot_id;
      document.getElementById('drone_id').value = event.drone_id;
      document.getElementById('activity_status').value = event.status;
      document.getElementById('observations').value = event.observations;
    }
    cancelBtn.classList.toggle('hidden', !event || event.status === 'cancelled' || event.status === 'completed');
    completeBtn.classList.toggle('hidden', !event || event.status === 'cancelled' || event.status === 'completed');
    updateDuration();
    activityModal.classList.add('is-open');
    activityModal.setAttribute('aria-hidden', 'false');
  }
  function closeActivityModal() {
    activityModal.classList.remove('is-open');
    activityModal.setAttribute('aria-hidden', 'true');
  }
  function updateDuration() {
    const startDate = document.getElementById('start_date').value;
    const endDate = document.getElementById('end_date').value;
    const start = document.getElementById('start_time').value;
    const end = document.getElementById('end_time').value;
    if (!startDate || !endDate || !start || !end) return;
    const startAt = new Date(`${startDate}T${start}:00`);
    const endAt = new Date(`${endDate}T${end}:00`);
    const minutes = Math.max(0, Math.round((endAt - startAt) / 60000));
    document.getElementById('duration_preview').value = `${minutes} min`;
  }
  function upsertActivity(activity) {
    const index = activities.findIndex(item => item.id === activity.id);
    if (index >= 0) activities[index] = activity;
    else activities.push(activity);
    render();
  }

  document.querySelector('[data-open-activity]').addEventListener('click', () => openActivityModal(dateKey(currentDate), '08:00'));
  document.querySelector('[data-open-pilot]').addEventListener('click', () => { clearAlert(pilotAlert); pilotForm.reset(); pilotModal.classList.add('is-open'); });
  document.querySelectorAll('[data-close-modal]').forEach(button => button.addEventListener('click', closeActivityModal));
  document.querySelectorAll('[data-close-pilot]').forEach(button => button.addEventListener('click', () => pilotModal.classList.remove('is-open')));
  document.querySelector('[data-calendar-prev]').addEventListener('click', () => {
    currentDate.setDate(currentDate.getDate() + (currentView === 'month' ? -30 : currentView === 'week' ? -7 : -1));
    render();
  });
  document.querySelector('[data-calendar-next]').addEventListener('click', () => {
    currentDate.setDate(currentDate.getDate() + (currentView === 'month' ? 30 : currentView === 'week' ? 7 : 1));
    render();
  });
  document.querySelector('[data-calendar-today]').addEventListener('click', () => { currentDate = new Date(); render(); });
  document.querySelectorAll('[data-calendar-view]').forEach(button => button.addEventListener('click', () => { currentView = button.dataset.calendarView; render(); }));
  calendarBody.addEventListener('click', function (event) {
    const eventElement = event.target.closest('[data-activity-id]');
    if (eventElement) {
      event.stopPropagation();
      openActivityModal(null, null, activities.find(item => item.id === Number(eventElement.dataset.activityId)));
      return;
    }
    const target = event.target.closest('[data-day]');
    if (target) openActivityModal(target.dataset.day, target.dataset.time || '08:00');
  });
  document.getElementById('start_date').addEventListener('change', function () {
    if (!document.getElementById('end_date').value) document.getElementById('end_date').value = this.value;
    updateDuration();
  });
  document.getElementById('end_date').addEventListener('change', updateDuration);
  document.getElementById('start_time').addEventListener('change', updateDuration);
  document.getElementById('end_time').addEventListener('change', updateDuration);
  organizationSelect.addEventListener('change', function () {
    forceNewFarm = false;
    forceNewLot = false;
    renderFarmOptions(this.value, '');
    renderLotOptions('', '');
    syncCatalogFields();
    const client = clients.find(item => String(item.id) === String(this.value));
    document.getElementById('unit_price').value = client ? (client.unit_price || '') : '';
  });
  farmSelect.addEventListener('change', function () {
    forceNewLot = false;
    renderLotOptions(this.value, '');
    syncCatalogFields();
    if (!document.getElementById('place').value) document.getElementById('place').value = farmNameInput.value;
  });
  lotSelect.addEventListener('change', function () {
    syncCatalogFields();
    const area = this.selectedOptions[0] ? this.selectedOptions[0].dataset.area : '';
    if (area) document.getElementById('area_hectares').value = area;
  });
  farmNameManual.addEventListener('input', syncCatalogFields);
  lotCodeManual.addEventListener('input', syncCatalogFields);
  newFarmToggle.addEventListener('click', function () {
    forceNewFarm = !forceNewFarm;
    forceNewLot = forceNewFarm;
    renderFarmOptions(organizationSelect.value, '');
    renderLotOptions('', '');
    syncCatalogFields();
  });
  newLotToggle.addEventListener('click', function () {
    forceNewLot = !forceNewLot;
    renderLotOptions(farmSelect.value, '');
    syncCatalogFields();
  });

  activityForm.addEventListener('submit', async function (event) {
    event.preventDefault();
    clearAlert(activityAlert);
    syncCatalogFields();
    const id = document.getElementById('activity_id').value;
    const url = id ? `${root.dataset.createActivityUrl}/${id}` : root.dataset.createActivityUrl;
    try {
      const data = await postForm(url, activityForm);
      upsertActivity(data.activity);
      closeActivityModal();
    } catch (error) {
      showAlert(activityAlert, error.message);
    }
  });
  pilotForm.addEventListener('submit', async function (event) {
    event.preventDefault();
    clearAlert(pilotAlert);
    try {
      const data = await postForm(root.dataset.createPilotUrl, pilotForm);
      const option = document.createElement('option');
      option.value = data.pilot.id;
      option.textContent = data.pilot.name;
      document.getElementById('pilot_id').appendChild(option);
      pilotModal.classList.remove('is-open');
      window.location.reload();
    } catch (error) {
      showAlert(pilotAlert, error.message);
    }
  });
  cancelBtn.addEventListener('click', async function () {
    if (!activeActivity) return;
    try {
      const data = await postForm(`${root.dataset.createActivityUrl}/${activeActivity.id}/cancelar`, document.createElement('form'));
      upsertActivity(data.activity);
      closeActivityModal();
    } catch (error) { showAlert(activityAlert, error.message); }
  });
  completeBtn.addEventListener('click', async function () {
    if (!activeActivity) return;
    try {
      const data = await postForm(`${root.dataset.createActivityUrl}/${activeActivity.id}/finalizar`, document.createElement('form'));
      upsertActivity(data.activity);
      closeActivityModal();
    } catch (error) { showAlert(activityAlert, error.message); }
  });

  render();
});
</script>
{% endblock %}

