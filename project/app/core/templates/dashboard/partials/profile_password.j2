{# profile_password.j2 - Password change form #}
{% from "settings/_ui_class.j2" import card_base, base_button_classes, button_bg_color, base_input_classes %}

<!-- Sección Cambio de Contraseña -->
<div class="{{ card_base }}">
    <div class="border-b border-gray-100 dark:border-gray-700 pb-4 mb-5">
        <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
            <i class="fas fa-key text-emerald-600"></i>
            Cambiar Contraseña
        </h2>
    </div>
    <div id="password-alerts"></div>
    <form id="passwordForm" autocomplete="off">
        <div class="space-y-4 max-w-md">
            <div>
                <label for="current_password" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                    Contraseña Actual
                </label>
                <input type="password"
                       id="current_password"
                       name="current_password"
                       autocomplete="current-password"
                       required
                       class="{{ base_input_classes }}">
            </div>
            <div>
                <label for="new_password" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                    Nueva Contraseña
                </label>
                <input type="password"
                       id="new_password"
                       name="new_password"
                       autocomplete="new-password"
                       required
                       class="{{ base_input_classes }}">
            </div>
            <div>
                <label for="confirm_password" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                    Confirmar Nueva Contraseña
                </label>
                <input type="password"
                       id="confirm_password"
                       name="confirm_password"
                       autocomplete="new-password"
                       required
                       class="{{ base_input_classes }}">
            </div>
        </div>
        <div class="mt-5 pt-4 border-t border-gray-100 dark:border-gray-700 flex justify-end">
            <button type="submit"
                    id="updatePasswordBtn"
                    class="{{ base_button_classes }} {{ button_bg_color }} text-white"
                    aria-label="Actualizar contraseña">
                <i class="fas fa-lock mr-1.5"></i>Cambiar contraseña
            </button>
        </div>
    </form>
</div>
