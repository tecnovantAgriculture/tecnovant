{# profile_avatar_upload.j2 - Avatar upload form #}
{% from "settings/_ui_class.j2" import card_base, base_button_classes, button_bg_color, border_color, text_color, base_input_classes %}

<!-- Sección Avatar Upload (hidden by default) -->
<div id="avatar-upload-section" class="hidden {{ card_base }}">
    <div class="border-b border-gray-100 dark:border-gray-700 pb-4 mb-5">
        <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
            <i class="fas fa-portrait text-emerald-600"></i>
            Cambiar Avatar
        </h2>
    </div>
    <div id="avatar-alerts"></div>
    <form id="avatarForm" enctype="multipart/form-data">
        <div class="space-y-5">
            <div>
                <label for="avatar-file" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                    Seleccionar imagen
                </label>
                <input type="file"
                       id="avatar-file"
                       name="file"
                       accept="image/jpeg,image/png,image/webp"
                       aria-describedby="avatar-file-help"
                       class="block w-full text-sm text-gray-600 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100 dark:file:bg-emerald-900/30 dark:file:text-emerald-300 cursor-pointer">
                <p id="avatar-file-help" class="mt-1.5 text-xs text-gray-400 dark:text-gray-500">
                    Formatos permitidos: JPEG, PNG, WEBP · Máximo 5 MB
                </p>
            </div>
            <div>
                <p class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Vista previa</p>
                <div class="flex items-center gap-5">
                    <img id="avatar-preview"
                         src="{{ avatar_url or avatar_default }}"
                         alt="Vista previa"
                         class="w-20 h-20 rounded-full border border-gray-200 dark:border-gray-600 object-cover flex-shrink-0">
                    <div class="text-sm text-gray-500 dark:text-gray-400 space-y-1">
                        <p>La imagen se mostrará recortada en círculo.</p>
                        <p class="text-xs text-gray-400 dark:text-gray-500">Tamaño recomendado: 256 × 256 px.</p>
                    </div>
                </div>
            </div>
            <div class="flex gap-3 pt-1 border-t border-gray-100 dark:border-gray-700">
                <button type="submit"
                        id="upload-avatar-btn"
                        class="{{ base_button_classes }} {{ button_bg_color }} text-white mt-4"
                        aria-label="Subir avatar">
                    <i class="fas fa-upload mr-1.5"></i>Subir Avatar
                </button>
                <button type="button"
                        id="cancel-avatar-btn"
                        class="{{ base_button_classes }} border {{ border_color }} {{ text_color }} mt-4"
                        aria-label="Cancelar cambio de avatar">
                    Cancelar
                </button>
            </div>
        </div>
    </form>
</div>
