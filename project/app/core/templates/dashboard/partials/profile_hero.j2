{# profile_hero.j2 - Avatar and user information header #}
{% from "settings/_ui_class.j2" import card_base %}

<!-- Hero: Encabezado del Perfil -->
<div>
    <div class="h-40 rounded-t-2xl bg-gradient-to-r from-emerald-600 to-sky-600"></div>
    <div class="bg-white dark:bg-gray-800 rounded-b-2xl border border-t-0 border-gray-100 dark:border-gray-700 px-6 pb-6">
        <div class="flex flex-col sm:flex-row sm:items-end gap-4 -mt-12">

            <!-- Avatar con botón de cámara -->
            <div class="flex-shrink-0">
                <div class="relative inline-block">
                    <img id="avatar-image"
                         src="{{ avatar_url or avatar_default }}"
                         alt="Avatar de {{ full_name }}"
                         class="w-24 h-24 rounded-full border-4 border-white dark:border-gray-800 bg-gray-200 dark:bg-gray-700 object-cover shadow-md">
                    <button type="button"
                            id="change-avatar-btn"
                            class="absolute bottom-0 right-0 w-7 h-7 rounded-full bg-emerald-600 hover:bg-emerald-700 text-white flex items-center justify-center shadow-sm transition"
                            aria-label="Cambiar avatar">
                        <i class="fas fa-camera text-[10px]"></i>
                    </button>
                </div>
            </div>

            <!-- Información del usuario -->
            <div class="flex-1 min-w-0 pb-2 sm:pb-0">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 pt-4 sm:pt-2">
                    <div class="min-w-0">
                        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100 truncate">{{ full_name }}</h1>
                        <p class="text-sm text-gray-500 dark:text-gray-400">@{{ username }}</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 sm:pt-1">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300 whitespace-nowrap">
                            {{ role }}
                        </span>
                        {% if avatar_url %}
                        <button type="button"
                                id="remove-avatar-btn"
                                class="inline-flex items-center gap-1 text-xs text-red-600 dark:text-red-400 hover:underline"
                                aria-label="Eliminar avatar">
                            <i class="fas fa-trash-alt text-[10px]"></i>Eliminar foto
                        </button>
                        {% endif %}
                    </div>
                </div>
                <p class="mt-1.5 text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1.5">
                    <i class="fas fa-clock text-[10px]"></i>
                    Último acceso:
                    {% if formatted_last_access %}
                        <span id="last-access" class="font-medium text-gray-700 dark:text-gray-300">{{ formatted_last_access }}</span>
                    {% else %}
                        <span class="italic">Nunca</span>
                    {% endif %}
                </p>
            </div>

        </div>
    </div>
</div>
