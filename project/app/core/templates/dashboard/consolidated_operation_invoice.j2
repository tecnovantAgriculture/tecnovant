<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Factura consolidada - {{ filters.cliente }}</title>
  <style>
    :root { --brand:#0875a5; --ink:#111827; --muted:#6b7280; --line:#dbe3ea; --soft:#f3f7fa; }
    * { box-sizing:border-box; }
    body { margin:0; background:#edf2f5; color:var(--ink); font-family:Arial,Helvetica,sans-serif; font-size:12px; }
    .actions { position:sticky; top:0; z-index:2; display:flex; justify-content:flex-end; gap:8px; padding:12px 24px; background:#fff; border-bottom:1px solid var(--line); }
    .btn { display:inline-flex; align-items:center; min-height:34px; padding:0 14px; border:1px solid var(--line); border-radius:7px; background:#fff; color:#334155; font-weight:700; text-decoration:none; cursor:pointer; }
    .btn-primary { border-color:var(--brand); background:var(--brand); color:#fff; }
    .sheet { width:210mm; min-height:297mm; margin:20px auto; padding:16mm; background:#fff; box-shadow:0 10px 30px rgba(15,23,42,.12); }
    header { display:flex; justify-content:space-between; gap:30px; align-items:flex-start; }
    .brand { display:flex; gap:14px; align-items:center; }
    .brand img { width:110px; max-height:70px; object-fit:contain; }
    h1 { margin:0; font-size:27px; }
    h2 { margin:0 0 8px; font-size:14px; }
    .meta { text-align:right; line-height:1.7; }
    .muted { color:var(--muted); }
    .parties { display:grid; grid-template-columns:1fr 1fr; gap:28px; margin:35px 0 24px; }
    .party { line-height:1.55; }
    .summary { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin:18px 0; }
    .summary article { padding:12px; border:1px solid var(--line); border-radius:8px; background:var(--soft); }
    .summary small { display:block; color:var(--muted); font-size:10px; text-transform:uppercase; }
    .summary strong { display:block; margin-top:7px; font-size:18px; }
    table { width:100%; border-collapse:collapse; margin-top:14px; }
    th { padding:9px 7px; background:var(--brand); color:#fff; font-size:9px; text-align:left; text-transform:uppercase; }
    td { padding:8px 7px; border-bottom:1px solid var(--line); vertical-align:top; }
    tbody tr:nth-child(even) { background:var(--soft); }
    .num { text-align:right; white-space:nowrap; }
    .pilot-summary { margin-top:24px; }
    .totals { width:330px; margin:24px 0 0 auto; }
    .totals div { display:flex; justify-content:space-between; gap:20px; padding:6px 10px; }
    .totals .grand { margin-top:5px; padding:11px 10px; background:var(--soft); font-size:16px; font-weight:800; }
    .note { margin-top:35px; padding-top:14px; border-top:1px solid var(--line); color:var(--muted); font-size:10px; line-height:1.5; }
    @page { size:A4; margin:8mm; }
    @media print {
      body { background:#fff; }
      .actions { display:none; }
      .sheet { width:auto; min-height:auto; margin:0; padding:8mm; box-shadow:none; }
    }
  </style>
</head>
<body>
  <nav class="actions">
    <a class="btn" href="{{ url_for('core.completed_operation_billing', finca=filters.finca, cliente=filters.cliente, piloto=filters.piloto, mes=filters.mes, factura='pendientes') }}">Volver</a>
    <button class="btn btn-primary" type="button" onclick="window.print()">Imprimir / Guardar PDF</button>
  </nav>
  <main class="sheet">
    <header>
      <div class="brand">
        <img src="/img/logo.png" alt="Tecnovant">
        <div><div class="muted">TECNOLOGÍA PARA EL CAMPO</div><strong>Servicios de operación agrícola</strong></div>
      </div>
      <div class="meta">
        <h1>Factura consolidada</h1>
        <div><span class="muted">Referencia:</span> {{ reference }}</div>
        <div><span class="muted">Fecha:</span> {{ generated_at.strftime('%d/%m/%Y') }}</div>
        <div><span class="muted">Estado:</span> Borrador</div>
      </div>
    </header>

    <section class="parties">
      <div class="party">
        <h2>Prestador</h2>
        <strong>Tecnovant</strong><br>
        Tecnología y servicios para el campo
      </div>
      <div class="party">
        <h2>Facturar a</h2>
        <strong>{{ filters.cliente }}</strong><br>
        {% if organization %}
          {% if organization.nit %}NIT: {{ organization.nit }}<br>{% endif %}
          {% if organization.contact %}Contacto: {{ organization.contact }}<br>{% endif %}
          {% if organization.address %}{{ organization.address }}<br>{% endif %}
          {% if organization.phone %}Tel: {{ organization.phone }}{% endif %}
        {% else %}
          <span class="muted">Cliente tomado de las operaciones importadas</span>
        {% endif %}
      </div>
    </section>

    <section class="summary">
      <article><small>Operaciones agrupadas</small><strong>{{ records|length }}</strong></article>
      <article><small>Hectáreas voladas</small><strong>{{ '%.2f'|format(total_area) }} ha</strong></article>
      <article><small>Valor consolidado</small><strong>$ {{ '{:,.0f}'.format(total_value) }}</strong></article>
    </section>

    <h2>Detalle de operaciones pendientes</h2>
    <table>
      <thead><tr><th>Fecha</th><th>Finca / Potrero</th><th>Piloto</th><th class="num">Hectáreas</th><th class="num">Precio/ha</th><th class="num">Subtotal</th></tr></thead>
      <tbody>
        {% for record in records %}
        <tr>
          <td>{{ record.executed_date.strftime('%d/%m/%Y') if record.executed_date else '' }}</td>
          <td><strong>{{ record.farm_name or 'Sin finca' }}</strong>{% if record.paddock_name %}<br><span class="muted">{{ record.paddock_name }}</span>{% endif %}</td>
          <td>{{ record.pilot_name or 'Sin piloto' }}</td>
          <td class="num">{{ '%.2f'|format(record.area_hectares or 0) }}</td>
          <td class="num">$ {{ '{:,.0f}'.format(record.unit_price or 0) }}</td>
          <td class="num"><strong>$ {{ '{:,.0f}'.format(record.invoice_total or 0) }}</strong></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>

    <section class="pilot-summary">
      <h2>Resumen por piloto</h2>
      <table>
        <thead><tr><th>Piloto</th><th class="num">Operaciones</th><th class="num">Hectáreas</th><th class="num">Valor</th></tr></thead>
        <tbody>{% for pilot in pilots %}<tr><td>{{ pilot.name }}</td><td class="num">{{ pilot.operations }}</td><td class="num">{{ '%.2f'|format(pilot.area) }} ha</td><td class="num">$ {{ '{:,.0f}'.format(pilot.total) }}</td></tr>{% endfor %}</tbody>
      </table>
    </section>

    <section class="totals">
      <div><span>Total de hectáreas</span><strong>{{ '%.2f'|format(total_area) }} ha</strong></div>
      <div class="grand"><span>Total</span><span>$ {{ '{:,.0f}'.format(total_value) }}</span></div>
    </section>
    <p class="note">Documento interno generado desde las operaciones pendientes de facturación. Este borrador no reemplaza la factura electrónica ni modifica el número de factura de los registros incluidos.</p>
  </main>
</body>
</html>