{% extends "base.j2" %}

{% set bg_color = "bg-transparent" %}
{% set rounded = "" %}
{% set shadow = "" %}
{% set padding = "" %}
{% set main_clases = "flex-grow overflow-y-auto w-full px-0 py-0" %}

{% block extra_css %}
{{ super() }}
<style>
    .tv-home,
    .tv-home * {
        box-sizing: border-box;
    }

    .tv-home {
        height: 100%;
        min-height: 0;
        overflow: hidden;
        padding: 0;
        background: transparent;
        color: #17221e;
        font-family: inherit;
    }

    .dark .tv-home {
        background: transparent;
        color: #eef8f1;
    }

    body.tv-dashboard-fixed {
        overflow: hidden !important;
    }

    body.tv-dashboard-fixed > .flex.flex-grow {
        height: calc(100vh - 4rem);
        min-height: 0;
        overflow: hidden !important;
    }

    body.tv-dashboard-fixed #main-content {
        height: 100%;
        min-height: 0;
        overflow: hidden !important;
    }

    body.tv-dashboard-fixed #main-content > div {
        height: 100%;
        min-height: 0;
        padding: 0 !important;
        border-radius: 0 !important;
        background: transparent !important;
        box-shadow: none !important;
        overflow: hidden !important;
    }

    .tv-home h1,
    .tv-home h2,
    .tv-home h3,
    .tv-home p {
        margin: 0;
        padding: 0;
    }

    .tv-home-shell {
        height: 100%;
        width: 100%;
        margin: 0 auto;
        overflow: hidden;
        padding: 14px 16px;
    }

    .tv-home-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 16px;
    }

    .tv-home-title h1 {
        color: #17221e;
        font-size: 24px;
        font-weight: 600;
        line-height: 1.1;
    }

    .dark .tv-home-title h1 {
        color: #f4fbf5;
    }

    .tv-home-title p {
        margin-top: 6px;
        color: #6b766f;
        font-size: 13px;
        line-height: 1.45;
    }

    .dark .tv-home-title p {
        color: #a9b8ae;
    }

    .tv-home-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 36px;
        padding: 0 14px;
        border: 1px solid #dbe6dd;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.72);
        color: #33423a;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
    }

    .dark .tv-home-chip {
        border-color: rgba(148, 163, 184, 0.18);
        background: rgba(31, 41, 55, 0.72);
        color: #d9e8dd;
    }

    .tv-home-grid {
        display: grid;
        grid-template-columns: minmax(260px, 0.82fr) minmax(420px, 1.54fr) minmax(280px, 0.9fr);
        gap: 14px;
        align-items: stretch;
        height: calc(100% - 58px);
        overflow: hidden;
    }

    .tv-home-grid > main {
        display: grid;
        grid-template-rows: auto minmax(230px, 1.25fr) minmax(170px, 0.95fr);
        gap: 12px;
        height: 100%;
        min-height: 0;
        overflow: hidden;
    }

    .tv-card {
        border: 1px solid #dfe8df;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.92);
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
    }

    .dark .tv-card {
        border-color: rgba(148, 163, 184, 0.14);
        background: rgba(22, 32, 27, 0.94);
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
    }

    .tv-card-pad {
        padding: 18px;
    }

    .tv-primary-card {
        position: relative;
        min-height: 188px;
        overflow: hidden;
        border: 0;
        background: #173f36;
        color: #f7fff7;
    }

    .tv-primary-card::after {
        content: "";
        position: absolute;
        right: -44px;
        bottom: -48px;
        width: 170px;
        height: 170px;
        border: 28px solid rgba(185, 255, 138, 0.16);
        border-radius: 999px;
    }

    .tv-primary-card a {
        position: relative;
        z-index: 1;
        display: flex;
        min-height: 188px;
        flex-direction: column;
        justify-content: space-between;
        padding: 20px;
        color: inherit;
        text-decoration: none;
    }

    .tv-primary-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .tv-primary-mark {
        display: grid;
        width: 34px;
        height: 34px;
        place-items: center;
        border-radius: 10px;
        background: #c8fb8d;
        color: #173f36;
    }

    .tv-primary-card h2 {
        margin-top: 16px;
        max-width: 220px;
        font-size: 20px;
        font-weight: 600;
        line-height: 1.15;
    }

    .tv-primary-card p {
        margin-top: 10px;
        max-width: 260px;
        color: rgba(247, 255, 247, 0.72);
        font-size: 12px;
        line-height: 1.5;
    }

    .tv-link-line {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #173f36;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
    }

    .tv-primary-card .tv-link-line {
        color: #c8fb8d;
    }

    .tv-stack {
        display: grid;
        gap: 12px;
        height: 100%;
        min-height: 0;
        overflow: hidden;
    }

    .tv-home-grid > aside.tv-stack:first-child {
        grid-template-rows: auto auto auto minmax(0, 1fr);
    }

    .tv-home-grid > aside.tv-stack:last-child {
        grid-template-rows: minmax(0, 1.28fr) minmax(0, 0.72fr);
    }

    .tv-mini-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 14px;
        color: inherit;
        text-decoration: none;
        transition: transform 140ms ease, border-color 140ms ease;
    }

    .tv-mini-link:hover {
        transform: translateY(-2px);
        border-color: #b8dfae;
    }

    .tv-mini-left {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .tv-icon {
        display: grid;
        width: 34px;
        height: 34px;
        flex: 0 0 auto;
        place-items: center;
        border-radius: 11px;
        background: #e8f7dd;
        color: #235446;
    }

    .tv-icon-blue {
        background: #e4f4f6;
        color: #08758a;
    }

    .tv-icon-amber {
        background: #fff1d8;
        color: #a96009;
    }

    .tv-mini-link h3 {
        color: #17221e;
        font-size: 13px;
        font-weight: 600;
    }

    .dark .tv-mini-link h3 {
        color: #f4fbf5;
    }

    .tv-mini-link p {
        margin-top: 3px;
        color: #7a867f;
        font-size: 11px;
        line-height: 1.35;
    }

    .dark .tv-mini-link p {
        color: #a9b8ae;
    }

    .tv-kpis {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .tv-kpi {
        padding: 14px;
        min-height: 86px;
    }

    .tv-kpi-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .tv-kpi-label {
        color: #7a867f;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.03em;
        text-transform: uppercase;
    }

    .dark .tv-kpi-label {
        color: #a9b8ae;
    }

    .tv-kpi-value {
        margin-top: 14px;
        color: #15251f;
        font-size: 24px;
        font-weight: 600;
        line-height: 1;
    }

    .dark .tv-kpi-value {
        color: #f4fbf5;
    }

    .tv-kpi-note {
        margin-top: 6px;
        color: #8b978f;
        font-size: 11px;
    }

    .tv-section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 10px;
    }

    .tv-section-head h2 {
        color: #17221e;
        font-size: 14px;
        font-weight: 600;
    }

    .dark .tv-section-head h2 {
        color: #f4fbf5;
    }

    .tv-section-head span,
    .tv-section-head a {
        color: #6f7b73;
        font-size: 11px;
        font-weight: 500;
        text-decoration: none;
    }

    .dark .tv-section-head span,
    .dark .tv-section-head a {
        color: #a9b8ae;
    }

    .tv-chart-card {
        margin-top: 0;
        padding: 16px 18px;
        min-height: 0;
    }

    .tv-chart-wrap {
        position: relative;
        height: calc(100% - 34px);
        min-height: 190px;
    }

    .tv-compare-chart {
        min-height: 252px;
    }

    .tv-compare-chart .tv-chart-wrap {
        height: 178px;
        min-height: 178px;
    }

    .tv-chart-total {
        color: #173f36;
        font-size: 12px;
        font-weight: 650;
    }

    .dark .tv-chart-total {
        color: #d9f99d;
    }

    .tv-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 0;
        min-height: 0;
    }

    .tv-two-col > .tv-card {
        min-height: 0;
        overflow: hidden;
    }

    .tv-list {
        display: grid;
        gap: 6px;
    }

    .tv-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        min-height: 48px;
        padding: 7px 0;
        border-bottom: 1px solid #edf2ed;
    }

    .tv-row:last-child {
        border-bottom: 0;
    }

    .dark .tv-row {
        border-bottom-color: rgba(148, 163, 184, 0.12);
    }

    .tv-row-main {
        min-width: 0;
    }

    .tv-row-title {
        overflow: hidden;
        color: #17221e;
        font-size: 12px;
        font-weight: 600;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .dark .tv-row-title {
        color: #f4fbf5;
    }

    .tv-row-sub {
        margin-top: 4px;
        overflow: hidden;
        color: #7a867f;
        font-size: 11px;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .dark .tv-row-sub {
        color: #a9b8ae;
    }

    .tv-row-meta {
        flex: 0 0 auto;
        color: #7a867f;
        font-size: 11px;
        font-weight: 500;
    }

    .tv-empty {
        display: grid;
        min-height: 96px;
        place-items: center;
        border: 1px dashed #d7e3d8;
        border-radius: 14px;
        color: #7a867f;
        font-size: 12px;
        text-align: center;
    }

    .dark .tv-empty {
        border-color: rgba(148, 163, 184, 0.24);
        color: #a9b8ae;
    }

    .tv-stat-card {
        padding: 18px;
        min-height: 0;
        overflow: hidden;
    }

    .tv-donut-wrap {
        position: relative;
        width: clamp(150px, 17vw, 185px);
        height: clamp(150px, 17vw, 185px);
        margin: 0 auto 10px;
    }

    .tv-donut-center {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        pointer-events: none;
        text-align: center;
    }

    .tv-donut-center strong {
        display: block;
        color: #173f36;
        font-size: 26px;
        font-weight: 600;
        line-height: 1;
    }

    .dark .tv-donut-center strong {
        color: #f4fbf5;
    }

    .tv-donut-center span {
        display: block;
        margin-top: 6px;
        color: #7a867f;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .tv-stat-line {
        display: grid;
        grid-template-columns: 22px 1fr auto;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        color: #34443b;
        font-size: 12px;
        font-weight: 500;
    }

    .dark .tv-stat-line {
        color: #d9e8dd;
    }

    .tv-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: #c8fb8d;
    }

    .tv-dot-dark {
        background: #173f36;
    }

    .tv-dot-blue {
        background: #80d9e7;
    }

    .tv-status-note {
        margin-top: 8px;
        padding: 10px 12px;
        border-radius: 14px;
        background: #f3f8f1;
        color: #657168;
        font-size: 11px;
        line-height: 1.45;
    }

    .dark .tv-status-note {
        background: rgba(200, 251, 141, 0.08);
        color: #a9b8ae;
    }

    .tv-insight-card {
        padding: 16px;
        display: flex;
        min-height: 0;
        flex-direction: column;
        overflow: hidden;
    }

    .tv-mini-chart-wrap {
        position: relative;
        flex: 1;
        min-height: 120px;
    }

    .tv-ratio-grid {
        display: grid;
        gap: 10px;
        margin-top: auto;
        margin-bottom: auto;
    }

    .tv-ratio-item {
        display: grid;
        gap: 6px;
    }

    .tv-ratio-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: #34443b;
        font-size: 11px;
        font-weight: 600;
    }

    .dark .tv-ratio-head {
        color: #d9e8dd;
    }

    .tv-ratio-head strong {
        color: #173f36;
        font-size: 12px;
    }

    .dark .tv-ratio-head strong {
        color: #c8fb8d;
    }

    .tv-ratio-track {
        height: 8px;
        overflow: hidden;
        border-radius: 999px;
        background: #eef4ed;
    }

    .dark .tv-ratio-track {
        background: rgba(148, 163, 184, 0.14);
    }

    .tv-ratio-fill {
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #173f36, #80d9e7);
    }

    .tv-ratio-fill-lime {
        background: linear-gradient(90deg, #c8fb8d, #173f36);
    }

    .tv-ratio-fill-amber {
        background: linear-gradient(90deg, #ffd38a, #d97806);
    }

    @media (max-height: 860px), (max-width: 1440px) {
        body.tv-dashboard-fixed {
            overflow-y: auto !important;
            overflow-x: hidden !important;
        }

        body.tv-dashboard-fixed > .flex.flex-grow,
        body.tv-dashboard-fixed #main-content,
        body.tv-dashboard-fixed #main-content > div {
            height: auto;
            min-height: calc(100vh - 4rem);
            overflow: visible !important;
        }

        .tv-home {
            height: auto;
            min-height: calc(100vh - 4rem);
            overflow: visible;
        }

        .tv-home-shell,
        .tv-home-grid,
        .tv-home-grid > main,
        .tv-stack {
            height: auto;
            overflow: visible;
        }

        .tv-home-shell {
            padding: 12px 14px 22px;
        }

        .tv-home-grid {
            align-items: start;
        }

        .tv-home-grid > main,
        .tv-home-grid > aside.tv-stack:first-child,
        .tv-home-grid > aside.tv-stack:last-child {
            grid-template-rows: none;
        }

        .tv-primary-card,
        .tv-primary-card a {
            min-height: 168px;
        }

        .tv-card-pad {
            padding: 15px;
        }
    }
    @media (max-width: 1280px) {
        .tv-home-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 820px) {
        .tv-home {
            height: auto;
            min-height: calc(100vh - 4rem);
            overflow: visible;
            padding: 0;
        }

        .tv-home-shell,
        .tv-home-grid {
            height: auto;
            overflow: visible;
        }

        .tv-home-shell {
            padding: 18px;
        }

        body.tv-dashboard-fixed,
        body.tv-dashboard-fixed > .flex.flex-grow,
        body.tv-dashboard-fixed #main-content,
        body.tv-dashboard-fixed #main-content > div {
            height: auto;
            overflow: visible !important;
        }

        .tv-home-topbar,
        .tv-section-head {
            align-items: flex-start;
            flex-direction: column;
        }

        .tv-kpis,
        .tv-two-col {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block content %}
{% set greeting_name = user_full_name or username or "Usuario" %}
{% set total_operation = operation_stats.lots_analyzed + operation_stats.recommendations_generated + operation_stats.reports_exported %}

<div class="tv-home">
    <div class="tv-home-shell">

        <div class="tv-home-grid">
            <aside class="tv-stack">
                <article class="tv-card tv-primary-card">
                    <a href="{{ url_for('agrovista.hello') }}">
                        <div>
                            <div class="tv-primary-top">
                                <span class="tv-primary-mark">
                                    <i class="fas fa-satellite-dish"></i>
                                </span>
                                <span class="tv-link-line">NDVI / VARI <i class="fas fa-arrow-right"></i></span>
                            </div>
                            <h2>Nuevo análisis desde ortofoto</h2>
                            <p>Sube una ortofoto TIFF/GeoTIFF, define la finca y genera el mapa de índice de vegetación.</p>
                        </div>
                        <span class="tv-link-line">Ir a módulo NDVI / VARI <i class="fas fa-arrow-right"></i></span>
                    </a>
                </article>

                <a href="{{ url_for('foliage.amd_farms') }}" class="tv-card tv-mini-link">
                    <div class="tv-mini-left">
                        <span class="tv-icon tv-icon-blue">
                            <i class="fas fa-tractor"></i>
                        </span>
                        <div>
                            <h3>Fincas y lotes recientes</h3>
                            <p>Acceso rápido a las últimas zonas de trabajo.</p>
                        </div>
                    </div>
                    <i class="fas fa-chevron-right"></i>
                </a>

                <a href="{{ url_for('foliage_report.listar_reportes') }}" class="tv-card tv-mini-link">
                    <div class="tv-mini-left">
                        <span class="tv-icon tv-icon-amber">
                            <i class="fas fa-play"></i>
                        </span>
                        <div>
                            <h3>Continuar último análisis</h3>
                            <p>
                                {% if last_analysis_summary %}
                                    {{ last_analysis_summary.farm_name }} · {{ last_analysis_summary.lot_name }}
                                {% else %}
                                    Sin análisis recientes
                                {% endif %}
                            </p>
                        </div>
                    </div>
                    <i class="fas fa-chevron-right"></i>
                </a>

                <section class="tv-card tv-insight-card">
                    <div class="tv-section-head">
                        <h2>Flujo de plataforma</h2>
                        <span>Datos activos</span>
                    </div>
                    <div class="tv-mini-chart-wrap">
                        <canvas id="tvHomeFlowChart"></canvas>
                    </div>
                </section>
            </aside>

            <main>
                <section class="tv-kpis">
                    <article class="tv-card tv-kpi">
                        <div class="tv-kpi-head">
                            <span class="tv-kpi-label">Análisis este mes</span>
                            <span class="tv-icon"><i class="fas fa-chart-line"></i></span>
                        </div>
                        <div class="tv-kpi-value">{{ kpis.analyses_month }}</div>
                        <p class="tv-kpi-note">Actividad mensual</p>
                    </article>
                    <article class="tv-card tv-kpi">
                        <div class="tv-kpi-head">
                            <span class="tv-kpi-label">Fincas activas</span>
                            <span class="tv-icon tv-icon-blue"><i class="fas fa-seedling"></i></span>
                        </div>
                        <div class="tv-kpi-value">{{ kpis.farms_active }}</div>
                        <p class="tv-kpi-note">Unidades disponibles</p>
                    </article>
                    <article class="tv-card tv-kpi">
                        <div class="tv-kpi-head">
                            <span class="tv-kpi-label">Imágenes procesadas</span>
                            <span class="tv-icon tv-icon-amber"><i class="fas fa-image"></i></span>
                        </div>
                        <div class="tv-kpi-value">{{ kpis.images_processed }}</div>
                        <p class="tv-kpi-note">Ortofotos registradas</p>
                    </article>
                </section>

                <section class="tv-card tv-chart-card">
                    <div class="tv-section-head">
                        <h2>Actividad del panel</h2>
                        <span>Resumen actual</span>
                    </div>
                    <div class="tv-chart-wrap">
                        <canvas id="tvHomeActivityChart"></canvas>
                    </div>
                </section>

                <section class="tv-two-col">
                    <article class="tv-card tv-card-pad tv-compare-chart">
                        <div class="tv-section-head">
                            <h2>Hectáreas voladas por día</h2>
                            <span class="tv-chart-total">{{ hectares_chart.current_total }} ha este mes</span>
                        </div>
                        <div class="tv-chart-wrap">
                            <canvas id="tvHomeHectaresDailyChart"></canvas>
                        </div>
                    </article>

                    <article class="tv-card tv-card-pad tv-compare-chart">
                        <div class="tv-section-head">
                            <h2>Acumulado de hectáreas</h2>
                            <span class="tv-chart-total">{{ hectares_chart.previous_total }} ha mes anterior</span>
                        </div>
                        <div class="tv-chart-wrap">
                            <canvas id="tvHomeHectaresCumulativeChart"></canvas>
                        </div>
                    </article>
                </section>
            </main>

            <aside class="tv-stack">
                <section class="tv-card tv-stat-card">
                    <div class="tv-section-head">
                        <h2>Estado general</h2>
                        <span>Operación</span>
                    </div>
                    <div class="tv-donut-wrap">
                        <canvas id="tvHomeOperationChart"></canvas>
                        <div class="tv-donut-center">
                            <div>
                                <strong>{{ total_operation }}</strong>
                                <span>Total</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        <div class="tv-stat-line">
                            <span class="tv-dot"></span>
                            <span>Lotes analizados</span>
                            <strong>{{ operation_stats.lots_analyzed }}</strong>
                        </div>
                        <div class="tv-stat-line">
                            <span class="tv-dot tv-dot-dark"></span>
                            <span>Recomendaciones</span>
                            <strong>{{ operation_stats.recommendations_generated }}</strong>
                        </div>
                        <div class="tv-stat-line">
                            <span class="tv-dot tv-dot-blue"></span>
                            <span>Reportes exportados</span>
                            <strong>{{ operation_stats.reports_exported }}</strong>
                        </div>
                    </div>
                    <p class="tv-status-note">
                        Resumen rápido de cómo se está comportando tu operación agrícola según los análisis registrados.
                    </p>
                </section>

                <section class="tv-card tv-insight-card">
                    <div class="tv-section-head">
                        <h2>Productividad operativa</h2>
                        <span>Indicadores</span>
                    </div>
                    <div class="tv-ratio-grid">
                        <div class="tv-ratio-item">
                            <div class="tv-ratio-head">
                                <span>Imagenes por finca</span>
                                <strong>{{ (kpis.images_processed / (kpis.farms_active if kpis.farms_active else 1)) | round(1) }}</strong>
                            </div>
                            <div class="tv-ratio-track">
                                <div class="tv-ratio-fill" style="width: {{ [((kpis.images_processed / (kpis.farms_active if kpis.farms_active else 1)) * 25), 100] | min }}%;"></div>
                            </div>
                        </div>
                        <div class="tv-ratio-item">
                            <div class="tv-ratio-head">
                                <span>Reportes por recomendacion</span>
                                <strong>{{ (operation_stats.reports_exported / (operation_stats.recommendations_generated if operation_stats.recommendations_generated else 1)) | round(1) }}</strong>
                            </div>
                            <div class="tv-ratio-track">
                                <div class="tv-ratio-fill tv-ratio-fill-lime" style="width: {{ [((operation_stats.reports_exported / (operation_stats.recommendations_generated if operation_stats.recommendations_generated else 1)) * 100), 100] | min }}%;"></div>
                            </div>
                        </div>
                        <div class="tv-ratio-item">
                            <div class="tv-ratio-head">
                                <span>Analisis del mes</span>
                                <strong>{{ kpis.analyses_month }}</strong>
                            </div>
                            <div class="tv-ratio-track">
                                <div class="tv-ratio-fill tv-ratio-fill-amber" style="width: {{ [(kpis.analyses_month * 10), 100] | min }}%;"></div>
                            </div>
                        </div>
                    </div>
                </section>
            </aside>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
{{ super() }}
<script src="/js/chart.js"></script>
<script>
    (function () {
        document.body.classList.add("tv-dashboard-fixed");

        const dashboardData = {
            kpis: {{ kpis | tojson }},
            operation: {{ operation_stats | tojson }},
            hectares: {{ hectares_chart | tojson }}
        };

        function getThemeColors() {
            const isDark = document.documentElement.classList.contains("dark");
            return {
                grid: isDark ? "rgba(216, 232, 221, 0.10)" : "rgba(23, 63, 54, 0.09)",
                text: isDark ? "#d9e8dd" : "#536158"
            };
        }

        function drawCharts() {
            if (!window.Chart) {
                return;
            }

            const theme = getThemeColors();
            const flowCanvas = document.getElementById("tvHomeFlowChart");
            const activityCanvas = document.getElementById("tvHomeActivityChart");
            const operationCanvas = document.getElementById("tvHomeOperationChart");
            const hectaresDailyCanvas = document.getElementById("tvHomeHectaresDailyChart");
            const hectaresCumulativeCanvas = document.getElementById("tvHomeHectaresCumulativeChart");


            function drawHectaresLine(canvas, currentValues, previousValues, labelSuffix) {
                if (!canvas) return;
                new Chart(canvas, {
                    type: "line",
                    data: {
                        labels: dashboardData.hectares.labels,
                        datasets: [
                            {
                                label: dashboardData.hectares.current_month,
                                data: currentValues,
                                borderColor: "#16a34a",
                                backgroundColor: "rgba(22, 163, 74, 0.10)",
                                pointBackgroundColor: "#16a34a",
                                pointBorderWidth: 0,
                                pointRadius: 2.5,
                                borderWidth: 2.5,
                                tension: 0.36,
                                fill: true
                            },
                            {
                                label: dashboardData.hectares.previous_month,
                                data: previousValues,
                                borderColor: "#0ea5e9",
                                backgroundColor: "rgba(14, 165, 233, 0.08)",
                                pointBackgroundColor: "#0ea5e9",
                                pointBorderWidth: 0,
                                pointRadius: 2.5,
                                borderWidth: 2.5,
                                tension: 0.36,
                                fill: true
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: "bottom",
                                labels: { boxWidth: 10, boxHeight: 10, color: theme.text, font: { size: 11 } }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        const value = context.parsed.y || 0;
                                        return `${context.dataset.label}: ${value.toLocaleString("es-CO")} ${labelSuffix}`;
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { display: false },
                                ticks: { color: theme.text, maxTicksLimit: 8 }
                            },
                            y: {
                                beginAtZero: true,
                                grace: "18%",
                                suggestedMax: 10,
                                grid: { color: theme.grid },
                                ticks: {
                                    color: theme.text,
                                    callback: function (value) { return `${value} ha`; }
                                }
                            }
                        }
                    }
                });
            }

            drawHectaresLine(hectaresDailyCanvas, dashboardData.hectares.current_daily, dashboardData.hectares.previous_daily, "ha");
            drawHectaresLine(hectaresCumulativeCanvas, dashboardData.hectares.current_cumulative, dashboardData.hectares.previous_cumulative, "ha acumuladas");
            if (flowCanvas) {
                new Chart(flowCanvas, {
                    type: "line",
                    data: {
                        labels: ["Fincas", "Imagenes", "Analisis", "Reportes"],
                        datasets: [{
                            data: [
                                dashboardData.kpis.farms_active || 0,
                                dashboardData.kpis.images_processed || 0,
                                dashboardData.kpis.analyses_month || 0,
                                dashboardData.operation.reports_exported || 0
                            ],
                            borderColor: "#173f36",
                            backgroundColor: "rgba(128, 217, 231, 0.24)",
                            pointBackgroundColor: ["#c8fb8d", "#80d9e7", "#173f36", "#ffd38a"],
                            pointBorderWidth: 0,
                            pointRadius: 4,
                            tension: 0.42,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: "#173f36",
                                displayColors: false,
                                padding: 10
                            }
                        },
                        scales: {
                            x: {
                                grid: { display: false },
                                ticks: { color: theme.text, font: { size: 10, weight: "600" } }
                            },
                            y: {
                                beginAtZero: true,
                                grace: "25%",
                                grid: { color: theme.grid },
                                ticks: { display: false, precision: 0 }
                            }
                        }
                    }
                });
            }

            if (activityCanvas) {
                new Chart(activityCanvas, {
                    type: "bar",
                    data: {
                        labels: ["Análisis", "Fincas", "Imágenes"],
                        datasets: [{
                            label: "Cantidad",
                            data: [
                                dashboardData.kpis.analyses_month || 0,
                                dashboardData.kpis.farms_active || 0,
                                dashboardData.kpis.images_processed || 0
                            ],
                            backgroundColor: ["#173f36", "#c8fb8d", "#80d9e7"],
                            borderRadius: 12,
                            maxBarThickness: 58
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: "#173f36",
                                displayColors: false,
                                padding: 10
                            }
                        },
                        scales: {
                            x: {
                                grid: { display: false },
                                ticks: { color: theme.text, font: { size: 11, weight: "700" } }
                            },
                            y: {
                                beginAtZero: true,
                                grace: "20%",
                                grid: { color: theme.grid },
                                ticks: { color: theme.text, precision: 0 }
                            }
                        }
                    }
                });
            }

            if (operationCanvas) {
                const values = [
                    dashboardData.operation.lots_analyzed || 0,
                    dashboardData.operation.recommendations_generated || 0,
                    dashboardData.operation.reports_exported || 0
                ];
                const hasData = values.some(function (value) { return value > 0; });

                new Chart(operationCanvas, {
                    type: "doughnut",
                    data: {
                        labels: ["Lotes analizados", "Recomendaciones", "Reportes"],
                        datasets: [{
                            data: hasData ? values : [1, 1, 1],
                            backgroundColor: ["#c8fb8d", "#173f36", "#80d9e7"],
                            borderColor: "#ffffff",
                            borderWidth: 4,
                            hoverOffset: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: "70%",
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                enabled: hasData,
                                backgroundColor: "#173f36",
                                displayColors: false,
                                padding: 10
                            }
                        }
                    }
                });
            }
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", drawCharts);
        } else {
            drawCharts();
        }
    })();
</script>
{% endblock %}
