 <aside id="sidebar" class="tv-sidebar z-10 w-100 md:w-64 flex-shrink-0 h-full overflow-y-auto sidebar-hidden md:block mobile-drawer sidebar-transition text-gray-900 dark:text-white transition-colors duration-150"
    aria-label="Sidebar">
    <div class="h-full px-4 py-5 overflow-y-auto tv-sidebar-inner">
    {% if sidebar_menu %}
        <div class="sidebar-brand">
            <img src="/img/logo.png" alt="TecnoVant" class="sidebar-brand__logo">
        </div>
        <ul class="space-y-2 font-medium sidebar-menu-list">
            {% for item in sidebar_menu.menu %}
                {% set is_active = false %}
                  {% if item.submenu %}
                       {% set ns = namespace(match_count=0) %}
                      {% for submenu_item in item.submenu %}
                          {% set normalized_request = request.path.rstrip('/') %}
                          {% set normalized_submenu = submenu_item.url.rstrip('/') %}
                          {% set is_match = normalized_request == normalized_submenu %}
                          {% if is_match %}
                              {% set ns.match_count = ns.match_count + 1 %}
                          {% endif %}


                      {% endfor %}
                      {% set is_active = ns.match_count > 0 %}

                {% else %}
                    {% set normalized_request = request.path.rstrip('/') %}
                    {% set normalized_link = item.url.rstrip('/') %}
                    {% if normalized_request == normalized_link %}
                        {% set is_active = true %}
                    {% endif %}
                {% endif %}
                <li class="sidebar__item" data-title="{{ item.name }}" data-visible="{% if item.submenu %}{{ item.visible|default('onClick') }}{% endif %}">
                    {% if item.submenu %}
                        {% set icon_svg = item.icon %}
                        {% set chevron_svg = icon_caret_down %}
                        {% if is_active %}
                            {% set icon_svg = icon_svg|replace('text-gray-500', 'text-gray-700')|replace('dark:text-gray-400', 'dark:text-gray-400')|replace('group-hover:text-gray-900', 'group-hover:text-gray-700')|replace('dark:group-hover:text-white', 'dark:group-hover:text-gray-400') %}
                            {% set chevron_svg = chevron_svg|replace('text-gray-500', 'text-gray-700')|replace('dark:text-gray-400', 'dark:text-gray-400')|replace('group-hover:text-gray-900', 'group-hover:text-gray-700')|replace('dark:group-hover:text-white', 'dark:group-hover:text-gray-400') %}
                        {% endif %}

                            <button type="button" data-active="{{ is_active }}" class="z-40 flex items-center w-full p-2 rounded-lg {% if not is_active %}hover:bg-gray-100 dark:hover:bg-gray-700{% endif %} group text-left transition-colors duration-150 {% if is_active %}bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-gray-100{% else %}text-gray-900 dark:text-white{% endif %}">
                             {{ icon_svg|safe }}
                               <span class="sidebar__label flex-1 ms-3 whitespace-nowrap {% if is_active %}font-medium text-gray-900 dark:text-gray-100{% else %}{% if is_active %}font-medium text-gray-900 dark:text-white{% endif %}{% endif %}">{{ item.name }}</span>
                            {{ chevron_svg|safe }}
                        </button>
                         <ul class="hidden pl-1 mt-2 space-y-2 rounded-lg bg-gray-100 dark:bg-gray-800">
                            {% for submenu_item in item.submenu %}
                                {% set normalized_request = request.path.rstrip('/') %}
                                {% set normalized_submenu = submenu_item.url.rstrip('/') %}
                                {% set is_sub_active = normalized_request == normalized_submenu %}
                                <li>
                                      <a href="{{ submenu_item.url }}" class="flex p-2 rounded-lg dark:text-white hover:bg-gray-300 dark:hover:bg-gray-700 group transition-colors duration-150 {% if is_sub_active %}bg-gray-200 dark:bg-gray-700 font-medium text-gray-900 dark:text-gray-100{% else %}text-gray-900{% endif %}">
                                         <span class="sidebar__label flex-1 ms-3 whitespace-nowrap">{{ submenu_item.name }}</span>
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        {% set normalized_request = request.path.rstrip('/') %}
                        {% set normalized_link = item.url.rstrip('/') %}
                        {% set is_link_active = normalized_request == normalized_link %}
                         <a href="{{ item.url }}" data-active="{{ is_link_active }}" class="flex items-center p-2 rounded-lg {% if not is_link_active %}hover:bg-gray-100 dark:hover:bg-gray-700{% endif %} group transition-colors duration-150 {% if is_link_active %}bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-gray-100{% else %}text-gray-900 dark:text-white{% endif %}">
                              {% set icon_svg = item.icon %}
                              {% if is_link_active %}
                                  {% set icon_svg = icon_svg|replace('text-gray-500', 'text-gray-700')|replace('dark:text-gray-400', 'dark:text-gray-400') %}
                              {% endif %}
                              {{ icon_svg|safe }}
                                <span class="sidebar__label flex-1 ms-3 whitespace-nowrap {% if is_link_active %}font-medium text-gray-900 dark:text-gray-100{% else %}{% if is_link_active %}font-medium text-gray-900 dark:text-white{% endif %}{% endif %}">{{ item.name }}</span>
                            {% if item.pro %}
                                <span class="inline-flex items-center justify-center px-2 ms-3 text-sm font-medium text-gray-800 bg-gray-300 rounded-full dark:bg-gray-700 dark:text-gray-300">Pro</span>
                            {% endif %}
                            {% if item.notifications %}
                                <span class="inline-flex items-center justify-center w-3 h-3 p-3 ms-3 text-sm font-medium text-sky-800 bg-sky-100 rounded-full dark:bg-sky-900 dark:text-sky-300">
                                    {{ item.notifications }}
                                </span>
                            {% endif %}
                        </a>
                    {% endif %}
                </li>
            {% endfor %}
         </ul>

          {# Desktop sidebar toggle button (hidden on mobile) #}
         <div class="hidden lg:block mt-auto pt-4 border-t border-gray-200 dark:border-gray-700">
           <button id="sidebar-toggle-desktop"
                   class="w-full flex items-center justify-center p-3 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors duration-150"
                   aria-label="Colapsar menú"
                   aria-expanded="true">
             {{ icon_caret_left|safe }}
           </button>
         </div>
        {% else %}
            <p class="text-center text-gray-500">No menu items</p>
        {% endif %}
    </div>
</aside>

<!-- Mobile Toggle Button (hidden in desktop) -->
<button id="sidebar-toggle" class="md:hidden fixed bottom-4 right-4 z-50 p-3 bg-emerald-600 text-white rounded-full shadow-lg hover:bg-emerald-700 transition-colors" aria-label="Toggle Sidebar">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
    </svg>
</button>

<!-- Overlay for mobile (hidden by default) -->
<div id="sidebar-overlay" class="md:hidden fixed inset-0 bg-black bg-opacity-50 z-40 hidden"></div>

