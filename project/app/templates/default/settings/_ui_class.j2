{# _ui_class.j2 #}

{# frontpage styles #}
{% set body_classes = "flex flex-col min-h-full h-screen bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-300" %}
{% set main_clases = "flex-grow overflow-y-auto mx-auto px-6 py-8" %}
{% set text_color = "text-gray-900 dark:text-gray-100" %}
{% set hover_bg = "hover:bg-gray-100 dark:hover:bg-gray-700" %}
{% set bg_color = "bg-white dark:bg-gray-800" %}
{% set menu_bg_color = "bg-gray-50 dark:bg-gray-800" %}
{% set shadow = "shadow-sm" %}
{% set rounded = "rounded-lg" %}
{% set padding = "p-6" %}
{% set container = "container mx-auto px-6 py-8" %}
{% set close_menu_button = "p-2 rounded-md text-gray-500 hover:text-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500" %}
{% set menu_link_style = "block py-2 px-4 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white rounded-md text-sm font-medium" %}

{# dashboard styles #}
{% set class_sidebar_menu = "flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 group" %}
{% set input_bg_color = "bg-white dark:bg-gray-700" %}
{% set border_color = "border-gray-300 dark:border-gray-600" %}
{% set hover_bg_color = "hover:bg-gray-50 dark:hover:bg-gray-800/50" %}
{% set focus_ring_color = "focus:ring-emerald-500 dark:focus:ring-emerald-500" %}
{% set button_bg_color = "bg-emerald-600 hover:bg-emerald-700" %}
{% set delete_button_bg_color = "bg-red-600 hover:bg-red-700" %}
{% set input_focus_bg_color = "focus:bg-white dark:focus:bg-gray-600" %}
{% set base_button_classes = "inline-flex justify-center rounded-lg px-4 py-2 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition" %}
{% set base_input_classes = "mt-1 block w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:ring-emerald-500" %}
{% set table_header_class = "px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider bg-gray-50 dark:bg-gray-800 text-gray-700 dark:text-gray-300" %}
{% set table_cell_class = "px-6 py-4 whitespace-nowrap text-sm" %}

{# card styles (interfaz_usuario.md section 4.3) #}
{% set card_base = "bg-white rounded-2xl shadow-sm border border-gray-100 p-5 dark:bg-gray-800 dark:border-gray-700" %}
{% set card_interactive = "bg-white rounded-2xl shadow-sm border border-gray-100 p-5 hover:shadow-md hover:border-emerald-500 transition-all dark:bg-gray-800 dark:border-gray-700 dark:hover:border-emerald-500" %}
{% set card_header = "border-b border-gray-200 pb-3 mb-4 dark:border-gray-700" %}

{# badge styles (interfaz_usuario.md section 4.5) #}
{% set badge_success = "px-2 py-1 text-xs bg-emerald-100 dark:bg-emerald-900/30 text-emerald-800 dark:text-emerald-300 rounded" %}
{% set badge_info = "px-2 py-1 text-xs bg-sky-100 dark:bg-sky-900/30 text-sky-800 dark:text-sky-300 rounded" %}
{% set badge_warning = "px-2 py-1 text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300 rounded" %}
{% set badge_error = "px-2 py-1 text-xs bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300 rounded" %}
{% set badge_neutral = "px-2 py-1 text-xs bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-300 rounded" %}

{# button secondary variant (interfaz_usuario.md section 4.1) #}
{% set button_secondary = "bg-white border border-gray-300 hover:border-gray-400 text-gray-700 font-medium py-2 px-4 rounded-lg focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition dark:bg-gray-800 dark:border-gray-600 dark:text-gray-300 dark:hover:border-gray-500" %}
