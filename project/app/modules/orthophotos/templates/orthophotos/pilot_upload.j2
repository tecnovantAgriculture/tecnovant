{% extends "base.j2" %}

{% block content %}
<div class="mx-auto max-w-2xl">
  <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-900">
    <p class="text-xs font-semibold uppercase tracking-wide text-emerald-600">TecnoAgro Ortofotos</p>
    <h1 class="mt-2 text-3xl font-semibold text-gray-900 dark:text-white">Subir fotos del vuelo</h1>
    <p class="mt-3 text-sm text-gray-600 dark:text-gray-300">
      Selecciona las fotos del vuelo. La carga se hace por paquetes para que el celular no se bloquee.
    </p>

    <div class="mt-6 rounded-2xl border border-dashed border-emerald-300 bg-emerald-50 p-5 dark:border-emerald-800 dark:bg-emerald-950/30">
      <label for="mission" class="block text-sm font-semibold text-gray-800 dark:text-gray-100">Mision</label>
      <select id="mission" class="mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm dark:border-gray-700 dark:bg-gray-800 dark:text-white">
        <option value="">Crear nueva carga</option>
        {% for item in missions %}
          <option value="{{ item.id }}" {% if mission and item.id == mission.id %}selected{% endif %}>{{ item.name }}</option>
        {% endfor %}
      </select>
      <input id="mission-name" type="text" placeholder="Nombre si es una nueva carga"
             class="mt-3 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm dark:border-gray-700 dark:bg-gray-800 dark:text-white">

      <label for="photos" class="block text-sm font-semibold text-gray-800 dark:text-gray-100">Fotos del dron</label>
      <input id="photos" type="file" accept=".jpg,.jpeg,.png,.tif,.tiff,image/*" multiple
             class="mt-3 block w-full text-sm text-gray-900 file:mr-4 file:rounded-lg file:border-0 file:bg-emerald-600 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white dark:text-gray-100">
      <button id="upload-btn" class="mt-4 w-full rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white hover:bg-emerald-700 disabled:opacity-60">
        Subir fotos
      </button>
    </div>

    <div class="mt-6">
      <div class="h-3 overflow-hidden rounded-full bg-gray-100 dark:bg-gray-800">
        <div id="bar" class="h-full w-0 bg-emerald-500 transition-all"></div>
      </div>
      <p id="status" class="mt-3 text-sm text-gray-600 dark:text-gray-300">Esperando seleccion.</p>
      <ul id="errors" class="mt-3 space-y-1 text-sm text-red-600"></ul>
    </div>
  </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
document.addEventListener('DOMContentLoaded', () => {
  const input = document.getElementById('photos');
  const mission = document.getElementById('mission');
  const missionName = document.getElementById('mission-name');
  const button = document.getElementById('upload-btn');
  const status = document.getElementById('status');
  const bar = document.getElementById('bar');
  const errors = document.getElementById('errors');
  const endpoint = {{ url_for('orthophotos_api.upload_photos')|tojson }};
  const uploadSessionId = {{ upload_session_id|tojson }};
  const batchSize = 20;
  let activeMissionId = mission.value || '';

  function setProgress(done, total) {
    const pct = total ? Math.round((done / total) * 100) : 0;
    bar.style.width = `${pct}%`;
    status.textContent = total ? `Subidas ${done} de ${total} fotos (${pct}%).` : 'Esperando seleccion.';
  }

  button.addEventListener('click', async () => {
    const files = Array.from(input.files || []);
    errors.innerHTML = '';
    if (!files.length) {
      status.textContent = 'Selecciona fotos antes de subir.';
      return;
    }

    button.disabled = true;
    let done = 0;
    activeMissionId = mission.value || activeMissionId;
    setProgress(done, files.length);

    for (let i = 0; i < files.length; i += batchSize) {
      const batch = files.slice(i, i + batchSize);
      const form = new FormData();
      if (activeMissionId) form.append('mission_id', activeMissionId);
      if (missionName.value) form.append('mission_name', missionName.value);
      form.append('upload_session_id', uploadSessionId);
      batch.forEach(file => form.append('files', file, file.name));

      try {
        const res = await fetch(endpoint, { method: 'POST', body: form });
        const data = await res.json().catch(() => ({}));
        if (data.mission && data.mission.id) {
          activeMissionId = String(data.mission.id);
        }
        if (!mission.value && activeMissionId) {
          const option = document.createElement('option');
          option.value = activeMissionId;
          option.textContent = data.mission.name;
          mission.appendChild(option);
          mission.value = activeMissionId;
        }
        done += (data.uploaded || []).length;
        (data.errors || []).forEach(err => {
          const item = document.createElement('li');
          item.textContent = `${err.name || 'Archivo'}: ${err.message || 'Error'}`;
          errors.appendChild(item);
        });
      } catch (err) {
        batch.forEach(file => {
          const item = document.createElement('li');
          item.textContent = `${file.name}: error de conexion`;
          errors.appendChild(item);
        });
      }
      setProgress(done, files.length);
    }

    button.disabled = false;
    if (done === files.length) {
      status.textContent = `Listo. Se subieron ${done} fotos correctamente.`;
      input.value = '';
    } else {
      status.textContent = `Se subieron ${done} de ${files.length}. Revisa los errores y vuelve a intentar las faltantes.`;
    }
  });
});
</script>
{% endblock %}
