{% extends "base.j2" %}
{% set flush_content_shell = true %}

{% block extra_css %}
{{ super() }}
<style>
  .orth-dashboard {
    display: grid;
    gap: 18px;
    color: #17221e;
  }

  .orth-dashboard h1,
  .orth-dashboard h2,
  .orth-dashboard p {
    margin: 0;
  }

  .orth-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 18px;
  }

  .orth-title h1 {
    color: #17221e;
    font-size: 26px;
    font-weight: 600;
    line-height: 1.12;
  }

  .orth-title p {
    margin-top: 8px;
    max-width: 640px;
    color: #64736a;
    font-size: 13px;
    line-height: 1.5;
  }

  .orth-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 36px;
    padding: 0 14px;
    border: 1px solid #dbe6dd;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    color: #33423a;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
  }

  .orth-card {
    overflow: hidden;
    border: 1px solid #dfe8df;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
  }

  .orth-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    border-bottom: 1px solid #edf2ed;
  }

  .orth-card-head h2 {
    color: #17221e;
    font-size: 16px;
    font-weight: 600;
  }

  .orth-card-head p {
    margin-top: 4px;
    color: #7a867f;
    font-size: 12px;
  }

  .orth-table-wrap {
    overflow-x: auto;
  }

  .orth-table {
    width: 100%;
    min-width: 920px;
    border-collapse: collapse;
    text-align: left;
  }

  .orth-table th {
    padding: 13px 20px;
    border-bottom: 1px solid #edf2ed;
    color: #6f7b73;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .orth-table td {
    padding: 16px 20px;
    border-bottom: 1px solid #f0f4f0;
    color: #34443b;
    font-size: 13px;
    vertical-align: top;
  }

  .orth-table tr:last-child td {
    border-bottom: 0;
  }

  .orth-mission-name {
    color: #17221e;
    font-weight: 700;
  }

  .orth-muted {
    margin-top: 4px;
    color: #7a867f;
    font-size: 12px;
  }

  .orth-status {
    display: grid;
    gap: 7px;
    min-width: 180px;
  }

  .orth-status-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    color: #235446;
    font-weight: 700;
  }

  .orth-status-label::before {
    content: "";
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: #80d9e7;
  }

  .orth-status-ready {
    color: #0f8a5f;
  }

  .orth-status-ready::before {
    background: #10b981;
  }

  .orth-status-error {
    color: #c9342e;
  }

  .orth-status-error::before {
    background: #ef4444;
  }

  .orth-progress {
    width: 150px;
    height: 7px;
    overflow: hidden;
    border-radius: 999px;
    background: #eef4ed;
  }

  .orth-progress span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #173f36, #80d9e7);
  }

  .orth-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    min-width: 210px;
  }

  .orth-upload-form {
    display: inline-flex;
  }

  .orth-file-input {
    display: none;
  }

  .orth-card-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
  }

  .orth-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 34px;
    padding: 0 12px;
    border: 1px solid #dbe6dd;
    border-radius: 10px;
    background: #ffffff;
    color: #235446;
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    transition: background 140ms ease, border-color 140ms ease, transform 140ms ease;
  }

  .orth-btn:hover {
    border-color: #b8dfae;
    background: #f5fbf2;
    transform: translateY(-1px);
  }

  .orth-btn-primary {
    border-color: #173f36;
    background: #173f36;
    color: #f7fff7;
  }

  .orth-btn-primary:hover {
    border-color: #173f36;
    background: #235446;
  }

  .orth-btn-danger {
    border-color: #fecaca;
    background: #fff7f7;
    color: #c9342e;
  }

  .orth-btn-danger:hover {
    border-color: #fca5a5;
    background: #fee2e2;
  }

  .orth-empty {
    display: grid;
    min-height: 150px;
    place-items: center;
    color: #7a867f;
    font-size: 13px;
    text-align: center;
  }

  .dark .orth-dashboard {
    color: #eef8f1;
  }

  .dark .orth-title h1,
  .dark .orth-card-head h2,
  .dark .orth-mission-name {
    color: #f4fbf5;
  }

  .dark .orth-title p,
  .dark .orth-card-head p,
  .dark .orth-muted,
  .dark .orth-table th,
  .dark .orth-empty {
    color: #a9b8ae;
  }

  .dark .orth-chip,
  .dark .orth-card {
    border-color: rgba(148, 163, 184, 0.16);
    background: rgba(22, 32, 27, 0.94);
  }

  .dark .orth-card-head,
  .dark .orth-table th,
  .dark .orth-table td {
    border-color: rgba(148, 163, 184, 0.12);
  }

  .dark .orth-table td {
    color: #d9e8dd;
  }

  .dark .orth-progress {
    background: rgba(148, 163, 184, 0.14);
  }

  .dark .orth-btn {
    border-color: rgba(148, 163, 184, 0.22);
    background: rgba(31, 41, 55, 0.72);
    color: #d9e8dd;
  }

  .dark .orth-btn-primary {
    border-color: #c8fb8d;
    background: #c8fb8d;
    color: #173f36;
  }

  .dark .orth-btn-danger {
    border-color: rgba(248, 113, 113, 0.35);
    background: rgba(127, 29, 29, 0.22);
    color: #fecaca;
  }

  @media (max-width: 820px) {
    .orth-head,
    .orth-card-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .orth-chip {
      white-space: normal;
    }
  }
</style>
{% endblock %}

{% block content %}
<div class="orth-dashboard">
  <section class="orth-head">
    <div class="orth-title">
      <h1>Ortofotos</h1>
      <p>Consulta el avance de las misiones, procesa imĂˇgenes capturadas en campo y descarga los resultados listos para anĂˇlisis.</p>
    </div>
    <div class="orth-chip">
      <i class="fas fa-map"></i>
      GestiĂłn de misiones
    </div>
  </section>

  <section class="orth-card">
    <div class="orth-card-head">
      <div>
        <h2>Misiones</h2>
        <p>Seguimiento operativo de vuelos y ortofotos generadas.</p>
      </div>
      <div class="orth-card-actions">
        <form class="orth-upload-form" data-create-mission="true">
          <input class="orth-file-input" type="file" name="files" accept=".jpg,.jpeg,.png,.tif,.tiff,image/jpeg,image/png,image/tiff" multiple>
          <button class="orth-btn orth-btn-primary" type="button">
            <i class="fas fa-upload"></i>
            Subir imagenes
          </button>
        </form>
        <span class="orth-chip">
          <i class="fas fa-layer-group"></i>
          {{ missions|length }} registradas
        </span>
      </div>
    </div>

    <div class="orth-table-wrap">
      <table class="orth-table">
        <thead>
          <tr>
            <th>MisiĂłn</th>
            <th>Fotos</th>
            <th>Estado</th>
            <th>Resultado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {% for mission in missions %}
          <tr>
            <td>
              <div class="orth-mission-name">{{ mission.name }}</div>
              {% if mission.description %}<div class="orth-muted">{{ mission.description }}</div>{% endif %}
            </td>
            <td>{{ mission.photos|length }}</td>
            <td>
              <div class="orth-status">
                {% if mission.status == 'completed' %}
                  <div class="orth-status-label orth-status-ready">Lista</div>
                {% elif mission.status in ['starting_webodm', 'submitting', 'uploading_to_webodm', 'queued'] %}
                  <div class="orth-status-label">Preparando procesamiento</div>
                {% elif mission.status == 'running' %}
                  <div class="orth-status-label">Procesando ortofoto</div>
                {% elif mission.status == 'downloading_asset' %}
                  <div class="orth-status-label">Preparando descarga</div>
                {% elif mission.status == 'failed' %}
                  <div class="orth-status-label orth-status-error">Requiere revisiĂłn</div>
                {% elif mission.status == 'canceled' %}
                  <div class="orth-status-label orth-status-error">Cancelada</div>
                {% else %}
                  <div class="orth-status-label">Pendiente</div>
                {% endif %}

                {% if mission.progress is not none %}
                  {% set progress_percent = (mission.progress * 100)|round|int %}
                  <div class="orth-progress" aria-label="Avance {{ progress_percent }}%">
                    <span style="width: {{ progress_percent }}%"></span>
                  </div>
                  <div class="orth-muted">{{ progress_percent }}%</div>
                {% endif %}

                {% if mission.processing_error %}
                  <div class="orth-muted orth-status-error">No fue posible completar el procesamiento. Revisa la misiĂłn e intenta nuevamente.</div>
                {% endif %}
              </div>
            </td>
            <td>
              {% if mission.status == 'completed' %}
                {% if not mission.available_assets or 'orthophoto.tif' in mission.available_assets %}
                  <a href="{{ url_for('orthophotos.download_mission_asset', mission_id=mission.id, asset_key='orthophoto') }}"
                     class="orth-btn orth-btn-primary">
                    <i class="fas fa-download"></i>
                    Descargar ortofoto
                  </a>
                {% else %}
                  <span class="orth-muted">Resultado no disponible</span>
                {% endif %}
              {% elif mission.status in ['starting_webodm', 'submitting', 'uploading_to_webodm', 'queued', 'running', 'downloading_asset'] %}
                <span class="orth-muted">En preparaciĂłn</span>
              {% else %}
                <span class="orth-muted">Pendiente de procesamiento</span>
              {% endif %}
            </td>
            <td>
              <div class="orth-actions">

                {% if mission.status not in ['completed', 'starting_webodm', 'submitting', 'uploading_to_webodm', 'queued', 'running', 'downloading_asset'] %}
                  <form class="process-orthophoto-form" method="post" action="{{ url_for('orthophotos.process_mission', mission_id=mission.id) }}">
                    <input type="hidden" name="profile" value="max_2d">
                    <button class="orth-btn orth-btn-primary">
                      <i class="fas fa-play"></i>
                      Procesar
                    </button>
                  </form>
                {% endif %}
                <form class="delete-orthophoto-form" method="post" action="{{ url_for('orthophotos.delete_mission', mission_id=mission.id) }}">
                  <button class="orth-btn orth-btn-danger">
                    <i class="fas fa-trash"></i>
                    Eliminar
                  </button>
                </form>
              </div>
            </td>
          </tr>
          {% else %}
          <tr>
            <td colspan="5">
              <div class="orth-empty">AĂşn no hay misiones registradas.</div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
</div>
{% endblock %}

{% block extra_js %}
<script>
document.addEventListener('DOMContentLoaded', () => {
  const uploadEndpoint = {{ url_for('orthophotos_api.upload_photos')|tojson }};
  const activeProcessing = {{ missions | selectattr('status', 'in', ['starting_webodm', 'submitting', 'uploading_to_webodm', 'queued', 'running']) | list | length }};
  if (activeProcessing > 0) {
    window.setTimeout(() => window.location.reload(), 30000);
  }

  document.querySelectorAll('.orth-upload-form').forEach((uploadForm) => {
    const input = uploadForm.querySelector('.orth-file-input');
    const button = uploadForm.querySelector('button');
    const missionId = uploadForm.dataset.missionId;
    const createsMission = uploadForm.dataset.createMission === 'true';
    if (!input || !button) {
      return;
    }

    button.addEventListener('click', () => input.click());
    input.addEventListener('change', async () => {
      const files = Array.from(input.files || []);
      if (!files.length) {
        return;
      }

      const originalContent = button.innerHTML;
      const defaultName = `Mision ${new Date().toLocaleString('es-CO')}`;
      const missionName = createsMission
        ? window.prompt('Nombre para la nueva mision:', defaultName)
        : '';
      if (createsMission && missionName === null) {
        input.value = '';
        return;
      }
      if (!createsMission && !missionId) {
        alert('No se encontro la mision para subir imagenes.');
        input.value = '';
        return;
      }

      const uploadSessionId = `${Date.now()}-${Math.random().toString(36).slice(2)}`;
      let uploadedCount = 0;
      const errors = [];

      button.disabled = true;
      button.classList.add('opacity-60', 'cursor-not-allowed');

      try {
        for (let index = 0; index < files.length; index += 1) {
          const file = files[index];
          const formData = new FormData();
          formData.append('files', file);
          if (createsMission) {
            formData.append('mission_name', (missionName || defaultName).trim());
            formData.append('upload_session_id', uploadSessionId);
          } else {
            formData.append('mission_id', missionId);
          }

          button.textContent = `Subiendo ${index + 1}/${files.length}...`;
          let response;
          try {
            response = await fetch(uploadEndpoint, {
              method: 'POST',
              credentials: 'same-origin',
              headers: {
                'X-CSRF-TOKEN': typeof getCsrfToken === 'function' ? getCsrfToken() : '',
                'X-Requested-With': 'XMLHttpRequest'
              },
              body: formData
            });
          } catch (error) {
            errors.push(`${file.name}: la conexión se cerró antes de terminar la subida. Revisa el tamańo del archivo y los logs de Railway.`);
            break;
          }
          const data = await response.json().catch(() => ({}));
          if (response.ok && data.uploaded && data.uploaded.length) {
            uploadedCount += data.uploaded.length;
            continue;
          }
          const firstError = data.errors && data.errors.length ? data.errors[0].message : null;
          errors.push(`${file.name}: ${firstError || data.message || 'No se pudo subir.'}`);
        }

        if (uploadedCount > 0) {
          window.location.reload();
          return;
        }
        alert(errors.join('\\n') || 'No se pudieron subir las imagenes.');
      } finally {
        input.value = '';
        button.disabled = false;
        button.innerHTML = originalContent;
        button.classList.remove('opacity-60', 'cursor-not-allowed');
      }
    });
  });

  document.querySelectorAll('.process-orthophoto-form').forEach((processForm) => {
    processForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = processForm.querySelector('button');
      if (!confirm('Se iniciarĂˇ el procesamiento de la misiĂłn. ÂżDeseas continuar?')) {
        return;
      }
      const originalContent = button ? button.innerHTML : '';
      if (button) {
        button.disabled = true;
        button.textContent = 'Procesando...';
        button.classList.add('opacity-60', 'cursor-not-allowed');
      }
      try {
        const response = await fetch(processForm.action, {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'X-CSRF-TOKEN': typeof getCsrfToken === 'function' ? getCsrfToken() : '',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: new FormData(processForm)
        });
        const data = await response.json().catch(() => ({}));
        if (response.ok && data.redirect_url) {
          window.location.href = data.redirect_url;
          return;
        }
        alert(data.message || 'No se pudo iniciar el procesamiento.');
      } finally {
        if (button) {
          button.disabled = false;
          button.innerHTML = originalContent;
          button.classList.remove('opacity-60', 'cursor-not-allowed');
        }
      }
    });
  });

  document.querySelectorAll('.delete-orthophoto-form').forEach((deleteForm) => {
    deleteForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = deleteForm.querySelector('button');
      if (!confirm('Vas a eliminar esta misiĂłn y sus archivos asociados. ÂżDeseas continuar?')) {
        return;
      }
      if (button) {
        button.disabled = true;
        button.dataset.originalContent = button.innerHTML;
        button.textContent = 'Eliminando...';
        button.classList.add('opacity-60', 'cursor-not-allowed');
      }
      try {
        const response = await fetch(deleteForm.action, {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'X-CSRF-TOKEN': typeof getCsrfToken === 'function' ? getCsrfToken() : '',
            'X-Requested-With': 'XMLHttpRequest'
          }
        });
        const data = await response.json().catch(() => ({}));
        if (response.ok && data.redirect_url) {
          window.location.href = data.redirect_url;
          return;
        }
        alert(data.message || 'No se pudo eliminar la misiĂłn.');
      } finally {
        if (button) {
          button.disabled = false;
          button.innerHTML = button.dataset.originalContent || 'Eliminar';
          button.classList.remove('opacity-60', 'cursor-not-allowed');
        }
      }
    });
  });
});
</script>
{% endblock %}

