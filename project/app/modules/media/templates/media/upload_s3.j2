{% extends "base.j2" %}

{% set dashboard = dashboard if dashboard is defined else true %}

{% block header %}
  {% if not picker_mode %}
    {{ super() }}
  {% endif %}
{% endblock %}

{% block footer %}
  {% if not picker_mode %}
    {{ super() }}
  {% endif %}
{% endblock %}

{% block extra_css %}
  {{ super() }}
  {% if picker_mode %}
  <style>
    body { background-color: transparent; }
  </style>
  {% endif %}
{% endblock %}

{% block content %}
<div class="max-w-3xl">
  <h1 class="text-2xl font-semibold text-gray-900 dark:text-white mb-2">Importar desde Amazon S3</h1>
  <p class="text-sm text-gray-500 dark:text-gray-300 mb-6">Configura el origen en S3 para importar archivos (solo UI, no implementado).</p>

  <div class="space-y-4 rounded-lg border border-gray-200 dark:border-gray-700 p-6 bg-white dark:bg-gray-900">
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1">Bucket</label>
       <input type="text" placeholder="mi-bucket" class="w-full px-3 py-2 rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-emerald-500" disabled>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1">Prefijo / Carpeta</label>
       <input type="text" placeholder="carpeta/medios/" class="w-full px-3 py-2 rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-emerald-500" disabled>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1">Región (opcional)</label>
       <input type="text" placeholder="us-east-1" class="w-full px-3 py-2 rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-emerald-500" disabled>
    </div>

    <div class="flex items-center gap-2 pt-2">
       <button class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-md bg-sky-600 text-white opacity-50 cursor-not-allowed" disabled>Conectar e importar</button>
      {% if picker_mode %}
      <a href="{{ url_for('media.library', picker=1, event=picker_event_name, multi=1 if picker_multi else 0, allowed=picker_allowed_types | join(',') if picker_allowed_types else '') }}" class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-md border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-900">Volver a la biblioteca</a>
      {% else %}
      <a href="{{ url_for('media.library') }}" class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-md border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-900">Volver a la biblioteca</a>
      {% endif %}
    </div>
  </div>

  <div class="mt-6 text-sm text-gray-500 dark:text-gray-300">
    Próximamente: selección de archivos en S3, vista previa y reglas de ingestión.
  </div>
</div>
{% endblock %}

{% block extra_js %}
{% if picker_mode %}
<script>
(function(){
  const eventName = {{ picker_event_name|tojson }};

  function postToParent(payload) {
    try {
      window.parent.postMessage(payload, '*');
    } catch (err) {
      console.error('No se pudo enviar el mensaje al padre', err);
    }
  }

  function sendLifecycle(kind) {
    postToParent({ type: `${eventName}:${kind}` });
  }

  // Notificar que el picker está listo
  sendLifecycle('ready');
})();
</script>
{% endif %}
{% endblock %}
