{% extends "base.j2" %}

{% set dashboard = true %}

{% block content %}
<div class="max-w-5xl mx-auto">
  <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">Detalle del elemento</h1>
      <p class="text-sm text-gray-500 dark:text-gray-300">Información del archivo <span class="font-medium text-gray-900 dark:text-gray-100">{{ asset.original_name }}</span>.</p>
    </div>
    <div class="flex gap-2">
      <a href="{{ url_for('media.library') }}" class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-md border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-900">Volver a la biblioteca</a>
       <a href="{{ download_url }}" class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-md bg-emerald-600 text-white hover:bg-emerald-700">Descargar</a>
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <div id="media-card-preview" class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900">
      <div class="aspect-video flex items-center justify-center bg-gray-100 dark:bg-gray-800">
        <img src="{{ thumb_url }}" alt="Miniatura de {{ asset.original_name }}" class="max-h-full max-w-full object-contain" loading="lazy" decoding="async">
      </div>
      <div class="flex items-center justify-between gap-3 border-t border-gray-200 dark:border-gray-800 px-4 py-3 text-sm">
         <a href="{{ asset_url }}" target="_blank" class="inline-flex items-center text-sky-600 hover:text-sky-700 dark:text-sky-300 dark:hover:text-sky-200">Ver original</a>
        <span class="text-gray-500 dark:text-gray-400">ID interno: {{ asset.id }}</span>
      </div>
    </div>

    <div id="media-card-properties" class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 p-4">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Propiedades</h2>
      {% set size_bytes = asset.size_bytes or 0 %}
      {% set size_kb = size_bytes / 1024 %}
      {% if size_kb < 1024 %}
        {% set display_size = size_kb %}
        {% set display_unit = 'KB' %}
      {% elif size_kb < 1024 * 1024 %}
        {% set display_size = size_kb / 1024 %}
        {% set display_unit = 'MB' %}
      {% else %}
        {% set display_size = size_kb / (1024 * 1024) %}
        {% set display_unit = 'GB' %}
      {% endif %}
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">Nombre</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100 break-words">{{ asset.original_name }}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">Tipo</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100">{{ asset.asset_type }}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">MIME</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100">{{ asset.mime }}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">Extensión</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100">{{ asset.ext }}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">Dimensiones</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100">{{ asset.width or '?' }} × {{ asset.height or '?' }} px</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">Tamaño</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100">{{ display_size|round(2) }} {{ display_unit }}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">Almacenamiento</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100">{{ asset.storage }}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">Clave</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100 break-all">{{ asset.storage_key }}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">SHA-256</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100 break-all">{{ asset.sha256 }}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">Creado</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100">{{ asset.created_at.strftime('%d/%m/%Y %H:%M') }}</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">Geoespacial</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100">{{ 'Sí' if asset.is_geo else 'No' }}</dd>
        </div>
        {% if asset.crs %}
        <div class="flex justify-between gap-4">
          <dt class="w-32 text-gray-500 dark:text-gray-400">CRS</dt>
          <dd class="flex-1 text-gray-900 dark:text-gray-100">{{ asset.crs }}</dd>
        </div>
        {% endif %}
      </dl>
    </div>
  </div>

  <div id="media-card-preprocess" class="mt-6 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 p-4">
    <div class="flex items-start justify-between gap-3">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Preprocesamiento RGB</h2>
      
      <!-- Botón de acción -->
      {% if not preproc_status.is_processing and not preproc_previews %}
      <button type="button" 
              onclick="startPreprocessing('{{ asset.uuid }}')"
              class="inline-flex items-center gap-2 rounded-md bg-sky-600 px-3 py-1.5 text-sm font-semibold text-white shadow-xs hover:bg-sky-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-600">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
        </svg>
        Iniciar procesamiento
      </button>
      {% endif %}
    </div>

    <!-- Error de procesamiento (estado terminal, no procesando) -->
    {% if preproc_status.error and not preproc_status.is_processing %}
    <div id="preprocess-error-banner" class="mt-4 rounded-lg border border-red-200 dark:border-red-800 bg-gradient-to-br from-red-50 to-orange-50 dark:from-red-900/20 dark:to-orange-900/20 p-4">
      <div class="flex items-start gap-3">
        <div class="flex-shrink-0">
          <div class="h-8 w-8 rounded-full bg-red-100 dark:bg-red-900/40 flex items-center justify-center">
            <svg class="h-4 w-4 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
            </svg>
          </div>
        </div>
        <div class="flex-1">
          <h3 class="font-semibold text-red-800 dark:text-red-300">El procesamiento falló</h3>
          <p class="mt-1 text-sm text-red-700 dark:text-red-400">{{ preproc_status.error }}</p>
        </div>
      </div>
    </div>
    {% endif %}

    <!-- Panel de estado de procesamiento -->
    {% if preproc_status.is_processing %}
    {% set _state = preproc_status.status.state if preproc_status.status and preproc_status.status.state else "starting" %}
    {% set _progress_pct = ((preproc_status.status.progress or 0) * 100)|round|int if preproc_status.status else 0 %}
    <div id="processing-panel" class="mt-4 space-y-4">
      <!-- Stepper visual -->
      <div class="flex items-start gap-0 mt-2">
        {% set steps = [
          ("starting",            "Iniciando",   "M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"),
          ("loading",             "Cargando",    "M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"),
          ("generating_previews", "Previews",    "m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"),
          ("completed",           "Completado",  "M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z")
        ] %}
        {% set step_order = ["starting", "loading", "generating_previews", "completed"] %}
        {% set current_idx = step_order.index(_state) if _state in step_order else 0 %}
        {% for step_key, step_label, step_icon in steps %}
          {% set loop_idx = loop.index0 %}
          {% set is_done = loop_idx < current_idx %}
          {% set is_active = loop_idx == current_idx and _state != "failed" %}
          {% set is_error = _state == "failed" and loop_idx == current_idx %}
          <div class="flex flex-col items-center flex-1 min-w-0">
            <div class="flex items-center w-full">
              {% if not loop.first %}
              <div class="flex-1 h-0.5 {% if is_done or is_active %}bg-sky-400 dark:bg-sky-600{% else %}bg-gray-200 dark:bg-gray-700{% endif %} transition-colors duration-500"></div>
              {% endif %}
              <div class="flex-shrink-0 h-8 w-8 rounded-full flex items-center justify-center
                {% if is_done %}bg-emerald-100 dark:bg-emerald-900/40 ring-2 ring-emerald-500
                {% elif is_active %}bg-sky-100 dark:bg-sky-900/40 ring-2 ring-sky-500 animate-pulse
                {% elif is_error %}bg-red-100 dark:bg-red-900/40 ring-2 ring-red-500
                {% else %}bg-gray-100 dark:bg-gray-800 ring-1 ring-gray-300 dark:ring-gray-600{% endif %}
                transition-all duration-500">
                {% if is_done %}
                  <svg class="h-4 w-4 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                {% elif is_error %}
                  <svg class="h-4 w-4 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                  </svg>
                {% else %}
                  <svg class="h-4 w-4 {% if is_active %}text-sky-600 dark:text-sky-400{% else %}text-gray-400 dark:text-gray-500{% endif %}" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="{{ step_icon }}" />
                  </svg>
                {% endif %}
              </div>
              {% if not loop.last %}
              <div class="flex-1 h-0.5 {% if is_done %}bg-sky-400 dark:bg-sky-600{% else %}bg-gray-200 dark:bg-gray-700{% endif %} transition-colors duration-500"></div>
              {% endif %}
            </div>
            <span class="mt-1.5 text-xs text-center truncate w-full px-1
              {% if is_done %}text-emerald-600 dark:text-emerald-400 font-medium
              {% elif is_active %}text-sky-600 dark:text-sky-400 font-semibold
              {% elif is_error %}text-red-600 dark:text-red-400 font-medium
              {% else %}text-gray-400 dark:text-gray-500{% endif %}">
              {{ step_label }}
            </span>
          </div>
        {% endfor %}
      </div>

      <!-- Mensaje de estado actual -->
      <div class="flex items-center gap-3 mt-3">
        {% if _state != "failed" %}
        <div class="relative flex-shrink-0">
          <div class="h-7 w-7">
            <div class="absolute inset-0 rounded-full border-2 border-sky-200 dark:border-sky-800"></div>
            <div class="absolute inset-0 rounded-full border-2 border-sky-600 dark:border-sky-400 border-t-transparent animate-spin"></div>
          </div>
        </div>
        {% endif %}
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-gray-900 dark:text-white truncate">
            {% if preproc_status.status and preproc_status.status.current_artifact %}
              {{ preproc_status.status.current_artifact }}
            {% else %}
              Preparando análisis de imagen
            {% endif %}
          </p>
        </div>
        {% if _progress_pct > 0 %}
        <span class="text-sm font-semibold text-sky-600 dark:text-sky-400 flex-shrink-0">{{ _progress_pct }}%</span>
        {% endif %}
      </div>

      <!-- Barra de progreso animada con gradiente -->
      <div class="space-y-1">
        <div class="h-2 w-full overflow-hidden rounded-full bg-gray-200 dark:bg-gray-700">
          <div id="preproc-progress-bar"
               class="h-full rounded-full bg-gradient-to-r from-sky-500 via-blue-500 to-emerald-500 transition-all duration-700 ease-out"
               style="width: {{ _progress_pct }}%">
          </div>
        </div>
      </div>
    </div>
    {% endif %}

  </div>{# /media-card-preprocess inner #}

  <!-- Galería de artefactos preprocesados -->
  <div id="preproc-gallery" class="mt-6">
    {% if preproc_previews %}
    <div class="preview-grid grid grid-cols-2 md:grid-cols-3 gap-4">
      {% for item in preproc_previews %}
      <div class="rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 group" data-artifact-key="{{ item.id }}">
        <img src="{{ item.url }}" alt="{{ item.label }}"
             class="w-full object-cover aspect-video bg-gray-100 dark:bg-gray-800"
             loading="lazy">
        <p class="text-xs text-center py-2 text-gray-600 dark:text-gray-400">{{ item.label }}</p>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>

<!-- JavaScript para manejar procesamiento -->
<script>
// Polling para actualizar estado
let pollingInterval = null;

function getCookie(name) {
  const parts = document.cookie.split('; ' + name + '=');
  if (parts.length === 2) return parts.pop().split(';').shift();
  return '';
}

function startPreprocessing(uuid) {
  const preprocessCard = document.getElementById('media-card-preprocess');
  const processingHTML = `
    <div id="processing-panel" class="mt-4 space-y-4">
      <div class="flex items-center gap-3">
        <div class="relative flex-shrink-0">
          <div class="h-7 w-7">
            <div class="absolute inset-0 rounded-full border-2 border-sky-200 dark:border-sky-800"></div>
            <div class="absolute inset-0 rounded-full border-2 border-sky-600 dark:border-sky-400 border-t-transparent animate-spin"></div>
          </div>
        </div>
        <div class="flex-1">
          <p class="text-sm font-medium text-gray-900 dark:text-white">Solicitando procesamiento</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Iniciando worker en segundo plano...</p>
        </div>
      </div>
      <div class="h-2 w-full overflow-hidden rounded-full bg-gray-200 dark:bg-gray-700">
        <div id="preproc-progress-bar" class="h-full rounded-full bg-gradient-to-r from-sky-500 via-blue-500 to-emerald-500 transition-all duration-700 ease-out" style="width: 0%"></div>
      </div>
    </div>
  `;

  const header = preprocessCard.querySelector('.flex.items-start.justify-between');
  const existingPanel = preprocessCard.querySelector('#processing-panel');
  if (existingPanel) existingPanel.remove();
  else if (header.nextElementSibling) header.nextElementSibling.remove();
  header.insertAdjacentHTML('afterend', processingHTML);

  const button = preprocessCard.querySelector('button');
  if (button) {
    button.disabled = true;
    button.innerHTML = '<svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path></svg> Solicitando...';
  }

  fetch(`/api/media/assets/${uuid}/reprocess`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-TOKEN': getCookie('csrf_access_token'),
    }
  })
  .then(async response => {
    if (!response.ok) {
      let msg = `Error del servidor (${response.status})`;
      try { const d = await response.json(); if (d.message) msg = d.message; } catch (_) {}
      throw new Error(msg);
    }
    return response.json();
  })
  .then(data => {
    console.log('Procesamiento iniciado:', data);
    startPolling(uuid);
  })
  .catch(error => {
    console.error('Error:', error);
    showError(uuid, error.message);
  });
}

function retryPreprocessing(uuid) {
  startPreprocessing(uuid);
}

// Stepper state → step index mapping
const STEP_ORDER = ['starting', 'loading', 'generating_previews', 'completed'];

function updateStepper(state, hasError) {
  const panel = document.getElementById('processing-panel');
  if (!panel) return;
  const stepDivs = panel.querySelectorAll('[data-step-key]');
  if (!stepDivs.length) return;

  const currentIdx = STEP_ORDER.indexOf(state);
  stepDivs.forEach((el, idx) => {
    const isDone   = idx < currentIdx;
    const isActive = idx === currentIdx && !hasError;
    const isError  = hasError && idx === currentIdx;
    const circle   = el.querySelector('[data-step-circle]');
    const label    = el.querySelector('[data-step-label]');
    const lineAfter  = el.querySelector('[data-step-line-after]');
    const lineBefore = el.querySelector('[data-step-line-before]');

    if (circle) {
      circle.className = circle.className.replace(/ring-\S+|bg-\S+/g, '');
      if (isDone)        { circle.classList.add('bg-emerald-100', 'dark:bg-emerald-900/40', 'ring-2', 'ring-emerald-500'); }
      else if (isActive) { circle.classList.add('bg-sky-100', 'dark:bg-sky-900/40', 'ring-2', 'ring-sky-500', 'animate-pulse'); }
      else if (isError)  { circle.classList.add('bg-red-100', 'dark:bg-red-900/40', 'ring-2', 'ring-red-500'); }
      else               { circle.classList.add('bg-gray-100', 'dark:bg-gray-800', 'ring-1', 'ring-gray-300'); }
    }
    if (label) {
      label.className = label.className.replace(/text-\S+|font-\S+/g, '');
      if (isDone)        label.classList.add('text-emerald-600', 'dark:text-emerald-400', 'font-medium');
      else if (isActive) label.classList.add('text-sky-600', 'dark:text-sky-400', 'font-semibold');
      else if (isError)  label.classList.add('text-red-600', 'dark:text-red-400', 'font-medium');
      else               label.classList.add('text-gray-400', 'dark:text-gray-500');
    }
    if (lineAfter)  lineAfter.classList.toggle('bg-sky-400', isDone || isActive);
    if (lineBefore) lineBefore.classList.toggle('bg-sky-400', isDone || isActive);
  });
}

function updateProgressBar(progress) {
  const bar = document.getElementById('preproc-progress-bar');
  if (bar) bar.style.width = Math.round(progress * 100) + '%';
}

function injectPreviews(previews) {
  const gallery = document.getElementById('preproc-gallery');
  if (!gallery) return;

  const labelMap = {
    rgb_preview:   'RGB normalizado',
    vi_gray:       'VI (G/R)',
    vi_heat:       'Mapa térmico VI',
    heatmap:       'Heatmap vegetación',
    nd_index_rgba: 'Índice espectral (RGBA)',
  };

  let grid = gallery.querySelector('.preview-grid');
  if (!grid) {
    grid = document.createElement('div');
    grid.className = 'preview-grid grid grid-cols-2 md:grid-cols-3 gap-4';
    gallery.appendChild(grid);
  }

  for (const [key, url] of Object.entries(previews)) {
    if (gallery.querySelector(`[data-artifact-key="${key}"]`)) continue;
    const card = document.createElement('div');
    card.className = 'rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 group';
    card.setAttribute('data-artifact-key', key);
    card.innerHTML = `
      <img src="${url}" alt="${labelMap[key] || key}"
           class="w-full object-cover aspect-video bg-gray-100 dark:bg-gray-800"
           loading="lazy">
      <p class="text-xs text-center py-2 text-gray-600 dark:text-gray-400">${labelMap[key] || key}</p>
    `;
    grid.appendChild(card);
  }
}

function showCompletedState() {
  const preprocessCard = document.getElementById('media-card-preprocess');
  if (!preprocessCard) return;
  const gallery = document.getElementById('preproc-gallery');
  if (gallery && gallery.querySelector('.preview-grid')) {
    const processingPanel = preprocessCard.querySelector('#processing-panel');
    if (processingPanel) {
      processingPanel.innerHTML = `
        <div class="flex items-center gap-2 text-emerald-600 dark:text-emerald-400 mt-2">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <span class="text-sm font-medium">Procesamiento completado</span>
        </div>
      `;
    }
  }
}

function updateUIWithStatus(data) {
  const state    = data.status ? data.status.state    : null;
  const progress = data.status ? (data.status.progress || 0) : 0;

  updateStepper(state, data.has_error);
  updateProgressBar(progress);

  if (data.previews && Object.keys(data.previews).length > 0) {
    injectPreviews(data.previews);
  }

  if (!data.is_processing && !data.has_error) {
    showCompletedState();
  }
}

function startPolling(uuid) {
  if (pollingInterval) clearInterval(pollingInterval);

  pollingInterval = setInterval(() => {
    fetch(`/api/media/assets/${uuid}/preprocess-status`)
      .then(response => {
        if (response.status === 401) {
          clearInterval(pollingInterval);
          window.location.href = '/login';
          return null;
        }
        if (!response.ok) throw new Error(`Error del servidor: ${response.status}`);
        return response.json();
      })
      .then(data => {
        if (!data) return;
        updateUIWithStatus(data);

        if (!data.is_processing && !data.has_error) {
          clearInterval(pollingInterval);
          showCompletedState();
        }

        if (data.has_error) {
          clearInterval(pollingInterval);
          showPreprocessError(data.error || 'El procesamiento falló sin mensaje de detalle.');
        }
      })
      .catch(error => {
        console.error('Error en polling:', error);
      });
  }, 2000);
}

function showPreprocessError(message) {
  // Banner idempotente con el error terminal del worker (data.error del
  // endpoint de estado, ya traducido por friendly_preprocess_error).
  let banner = document.getElementById('preprocess-error-banner');
  if (!banner) {
    banner = document.createElement('div');
    banner.id = 'preprocess-error-banner';
    banner.className = 'mt-4 rounded-lg border border-red-200 dark:border-red-800 bg-gradient-to-br from-red-50 to-orange-50 dark:from-red-900/20 dark:to-orange-900/20 p-4';
    const card = document.getElementById('media-card-preprocess');
    if (card) card.appendChild(banner);
  }
  banner.innerHTML = `
    <div class="flex items-start gap-3">
      <div class="flex-shrink-0">
        <div class="h-8 w-8 rounded-full bg-red-100 dark:bg-red-900/40 flex items-center justify-center">
          <svg class="h-4 w-4 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
        </div>
      </div>
      <div class="flex-1">
        <h3 class="font-semibold text-red-800 dark:text-red-300">El procesamiento falló</h3>
        <p class="mt-1 text-sm text-red-700 dark:text-red-400"></p>
      </div>
    </div>`;
  banner.querySelector('p').textContent = message;
}

function showError(uuid, message) {
  const preprocessCard = document.getElementById('media-card-preprocess');
  const errorHTML = `
    <div class="mt-4 rounded-lg border border-red-200 dark:border-red-800 bg-gradient-to-br from-red-50 to-orange-50 dark:from-red-900/20 dark:to-orange-900/20 p-4">
      <div class="flex items-start gap-3">
        <div class="flex-shrink-0">
          <div class="h-8 w-8 rounded-full bg-red-100 dark:bg-red-900/40 flex items-center justify-center">
            <svg class="h-4 w-4 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
            </svg>
          </div>
        </div>
        <div class="flex-1">
          <h3 class="font-semibold text-red-800 dark:text-red-300">Error al iniciar procesamiento</h3>
          <p class="mt-1 text-sm text-red-700 dark:text-red-400">${message}</p>
          <div class="mt-3">
            <button type="button"
                    onclick="retryPreprocessing('${uuid}')"
                    class="inline-flex items-center gap-1.5 rounded-md bg-red-600 px-3 py-1.5 text-xs font-semibold text-white shadow-xs hover:bg-red-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
              Reintentar
            </button>
          </div>
        </div>
      </div>
    </div>
  `;

  const header = preprocessCard.querySelector('.flex.items-start.justify-between');
  let currentContent = header.nextElementSibling;
  while (currentContent) {
    const next = currentContent.nextElementSibling;
    currentContent.remove();
    currentContent = next;
  }
  header.insertAdjacentHTML('afterend', errorHTML);
}

// Iniciar polling si ya está procesando al cargar la página
{% if preproc_status.is_processing %}
document.addEventListener('DOMContentLoaded', function() {
  startPolling('{{ asset.uuid }}');
});
{% endif %}
</script>

{% endblock %}
