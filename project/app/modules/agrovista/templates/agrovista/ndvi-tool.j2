    // ===== Lot Reference (Geometry) Loader =====
    (function() {
      const lotSelector = document.getElementById('referenceLotsSelect');
      const lotStatus = document.getElementById('lotPolygonStatus');
      const savePolygonBtn = document.getElementById('savePolygonToLotBtn');
      const contextFarmEl = document.getElementById('contextFarm');

      let lotGeometryMap = {};
      let currentLotPolygon = null;
      let selectedLotId = null;

      if (!lotSelector) return;

      // Cargar lotes cuando se cambia de finca
      function loadLotsForCurrentFarm() {
        // Usar window.currentFarmId como fuente de verdad (establecido por farm picker o analysisFarmSelect)
        const farmId = window.currentFarmId;
        if (!farmId) {
          lotSelector.innerHTML = '<option value="">-- Sin finca seleccionada --</option>';
          lotStatus.textContent = 'Selecciona una finca para ver los lotes disponibles';
          updateSaveButtonState();
          return;
        }

        fetch('/api/foliage/lots/?filter_value=' + farmId, {
          credentials: 'include'
        })
        .then(r => r.json())
        .then(lots => {
          lotSelector.innerHTML = '<option value="">-- Seleccionar lote --</option>';
          lotGeometryMap = {};
          (lots || []).forEach(function(lot) {
            var opt = document.createElement('option');
            opt.value = lot.id;
            const hasGeometry = lot.geometry && lot.geometry.trim() !== '';
            const icon = hasGeometry ? '📍' : '○';
            opt.textContent = icon + ' ' + lot.name + ' (' + lot.area + ' ha)';
            opt.dataset.hasGeometry = hasGeometry ? '1' : '0';
            lotSelector.appendChild(opt);
            if (hasGeometry) {
              lotGeometryMap[lot.id] = lot.geometry;
            }
          });
          updateSaveButtonState();
        })
        .catch(err => {
          lotStatus.textContent = '❌ Error al cargar lotes: ' + (err.message || '');
          console.error('Error loading lots:', err);
        });
      }

      lotSelector.addEventListener('change', function() {
        removeLotPolygon();
        selectedLotId = this.value;

        if (!selectedLotId) {
          lotStatus.textContent = 'Selecciona un lote para visualizar su polígono';
          updateSaveButtonState();
          return;
        }

        if (lotGeometryMap[selectedLotId]) {
          drawLotPolygon(lotGeometryMap[selectedLotId]);
          lotStatus.innerHTML = '✓ <strong>Polígono del lote cargado</strong><br><span class="text-xs">Mostrado en naranja punteado. Dibuja un nuevo polígono para reemplazarlo.</span>';
        } else {
          lotStatus.innerHTML = '○ <strong>Este lote no tiene límites definidos aún</strong><br><span class="text-xs">Dibuja un polígono en el mapa para asociarlo a este lote.</span>';
        }
        updateSaveButtonState();
      });

      function drawLotPolygon(geojsonStr) {
        try {
          var geoJsonObj = JSON.parse(geojsonStr);
          // Extraer coordenadas del GeoJSON (formato: [lng, lat])
          var coords = [];
          if (geoJsonObj.type === 'Feature' && geoJsonObj.geometry) {
            geoJsonObj = geoJsonObj.geometry;
          }
          if (geoJsonObj.type === 'Polygon' && geoJsonObj.coordinates && geoJsonObj.coordinates[0]) {
            // Convertir [lng, lat] a [lat, lng] para Leaflet
            coords = geoJsonObj.coordinates[0].map(function(c) { return [c[1], c[0]]; });
          } else if (geoJsonObj.type === 'MultiPolygon' && geoJsonObj.coordinates && geoJsonObj.coordinates[0]) {
            coords = geoJsonObj.coordinates[0][0].map(function(c) { return [c[1], c[0]]; });
          }

          if (coords.length < 3) {
            throw new Error('GeoJSON no contiene un polígono válido');
          }

          // Crear polígono funcional y agregarlo a drawnItems (no solo al mapa)
          currentLotPolygon = L.polygon(coords, {
            color: '#ff6600',
            weight: 3,
            opacity: 0.8,
            fillOpacity: 0.15,
            dashArray: '5, 5'
          });
          drawnItems.addLayer(currentLotPolygon);

          // Hacerlo funcional: registrar en lotState y activarlo
          ensureLotEntry(currentLotPolygon);
          setActiveLayer(currentLotPolygon);
          wireArea(currentLotPolygon);
          updateStatsForLayer(currentLotPolygon);

          // Centrar mapa en el polígono
          if (currentLotPolygon.getBounds && currentLotPolygon.getBounds().isValid()) {
            map.fitBounds(currentLotPolygon.getBounds(), { padding: [50, 50] });
          }
        } catch(e) {
          lotStatus.textContent = '❌ Error al cargar polígono: ' + (e.message || '');
          console.error('GeoJSON parse error:', e);
        }
      }

      function removeLotPolygon() {
        if (currentLotPolygon) {
          // Remover de drawnItems y del mapa
          drawnItems.removeLayer(currentLotPolygon);
          map.removeLayer(currentLotPolygon);
          // Si era el polígono activo, resetear activeLayerId
          const layerKey = getLayerKey(currentLotPolygon);
          if (layerKey !== null && activeLayerId === layerKey) {
            activeLayerId = null;
            setText(el.activeLotName, "Sin lote seleccionado");
          }
          currentLotPolygon = null;
        }
      }

      function updateSaveButtonState() {
        if (!savePolygonBtn) return;

        const hasLotSelected = !!selectedLotId;
        const lotHasGeometry = hasLotSelected && lotGeometryMap[selectedLotId];
        const hasPolygonDrawn = window.drawnItems && window.drawnItems.getLayers && window.drawnItems.getLayers().length > 0;

        // Resetear clases de color (remover clases de color anteriores)
        savePolygonBtn.classList.remove('bg-blue-600', 'hover:bg-blue-700', 'bg-amber-600', 'bg-emerald-600');

        // Caso 1: No hay lote seleccionado
        if (!hasLotSelected) {
          savePolygonBtn.disabled = true;
          savePolygonBtn.innerHTML = '<i class="fas fa-save mr-2"></i>Guardar polígono en lote';
          savePolygonBtn.classList.add('bg-blue-600', 'hover:bg-blue-700');
          savePolygonBtn.title = 'Selecciona un lote primero';
          return;
        }

        // Caso 2: Lote con geometría existente
        if (lotHasGeometry) {
          savePolygonBtn.innerHTML = '<i class="fas fa-exchange-alt mr-2"></i>Actualizar polígono del lote';
          savePolygonBtn.classList.add('bg-amber-600');
          savePolygonBtn.classList.remove('hover:bg-blue-700');
          savePolygonBtn.classList.add('hover:bg-amber-700');
          savePolygonBtn.disabled = !hasPolygonDrawn;
          savePolygonBtn.title = hasPolygonDrawn
            ? '⚠️ Esto sobrescribirá la geometría actual. Confirma al hacer click.'
            : '⚠️ Dibuja un polígono primero para actualizar los límites';
          return;
        }

        // Caso 3: Lote sin geometría
        if (hasPolygonDrawn) {
          savePolygonBtn.innerHTML = '<i class="fas fa-plus-circle mr-2"></i>Asociar polígono al lote';
          savePolygonBtn.classList.add('bg-emerald-600');
          savePolygonBtn.classList.remove('hover:bg-blue-700');
          savePolygonBtn.classList.add('hover:bg-emerald-700');
          savePolygonBtn.disabled = false;
          savePolygonBtn.title = '✓ Listo para guardar. Click aquí para asociar el polígono.';
        } else {
          savePolygonBtn.innerHTML = '<i class="fas fa-plus-circle mr-2"></i>Asociar polígono al lote';
          savePolygonBtn.classList.add('bg-blue-600', 'hover:bg-blue-700');
          savePolygonBtn.disabled = true;
          savePolygonBtn.title = 'Dibuja un polígono en el mapa primero';
        }
      }

      savePolygonBtn.addEventListener('click', function() {
        if (!selectedLotId) {
          alert('Selecciona un lote primero');
          return;
        }

        // Buscar polígono dibujado en el mapa
        var drawnLayers = [];
        if (window.drawnItems) {
          window.drawnItems.eachLayer(function(layer) {
            if (layer instanceof L.Polygon || layer instanceof L.Rectangle) {
              drawnLayers.push(layer);
            }
          });
        }

        if (drawnLayers.length === 0) {
          alert('Dibuja un polígono primero');
          return;
        }

        var geojsonStr = JSON.stringify(drawnLayers[0].toGeoJSON());

        // PUT request to update lot with geometry
        fetch('/api/foliage/lots/', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            id: parseInt(selectedLotId),
            geometry: geojsonStr
          })
        })
        .then(r => r.json())
        .then(function() {
          alert('✓ Polígono guardado exitosamente');
          lotGeometryMap[selectedLotId] = geojsonStr;
          removeLotPolygon();
          drawLotPolygon(geojsonStr);
          lotStatus.textContent = '✓ Polígono guardado en lote';
        })
        .catch(function(err) {
          alert('❌ Error al guardar: ' + (err.message || ''));
        });
      });

      // Exponer globalmente para que sea accesible desde selectFarmFromPicker y analysisFarmSelect
      window.loadLotsForCurrentFarm = loadLotsForCurrentFarm;

      // Intentar cargar lotes inicialmente (si hay farm_id disponible)
      // El ndvi_tool.js debe establecer window.currentFarmId
      loadLotsForCurrentFarm();
    })();

  // Codex: vista previa nutricional aislada. No modifica cálculos ni endpoints existentes.
  (function(){
    const section = document.getElementById("polygonComparisonPreview");
    const select = document.getElementById("polygonComparisonObjective");
    const hint = document.getElementById("polygonComparisonHint");
    const cards = document.getElementById("polygonComparisonCards");
    let lastSignature = "";
    const balanceCache = new Map();
    const MACRO_SYMBOLS = new Set(["N", "P", "K", "Ca", "Mg", "S"]);

    function syncObjectiveOptions(){
      const source = document.getElementById("compareObjectiveSelect");
      if(!select || !source || source.options.length <= 1){ return; }
      if(select.dataset.synced === String(source.options.length)){ return; }
      const current = select.value;
      select.innerHTML = source.innerHTML;
      if(current){ select.value = current; }
      select.dataset.synced = String(source.options.length);
    }
    function normalizeName(value){
      return String(value || "")
        .trim()
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9]+/g, "");
    }
    const NUTRIENT_ALIASES = new Map([
      ["cloro", "cl"], ["cl", "cl"], ["cloruro", "cl"], ["clorine", "cl"],
      ["nitrogeno", "n"], ["n", "n"], ["fosforo", "p"], ["p", "p"],
      ["potasio", "k"], ["k", "k"], ["calcio", "ca"], ["ca", "ca"],
      ["magnesio", "mg"], ["mg", "mg"], ["azufre", "s"], ["s", "s"],
      ["silicio", "si"], ["si", "si"], ["boro", "b"], ["b", "b"],
      ["cobre", "cu"], ["cu", "cu"], ["hierro", "fe"], ["fe", "fe"],
      ["manganeso", "mn"], ["mn", "mn"], ["molibdeno", "mo"], ["mo", "mo"],
      ["zinc", "zn"], ["zn", "zn"],
    ]);
    function canonicalNutrientKey(item){
      const symbol = normalizeName(item && (item.nutrient_symbol || item.symbol || item.simbolo));
      const name = normalizeName(item && (item.nutrient_name || item.name || item.nombre));
      if(symbol && NUTRIENT_ALIASES.has(symbol)){ return NUTRIENT_ALIASES.get(symbol); }
      if(name && NUTRIENT_ALIASES.has(name)){ return NUTRIENT_ALIASES.get(name); }
      const id = item && (item.nutrient_id || item.id_nutrient || item.nutrientId);
      if(id != null && id !== ""){ return "id:" + String(id); }
      return symbol || name || "";
    }
    function getPreviewEntries(){
      const entries = [];
      if(typeof lotState !== "undefined" && lotState && typeof lotState.values === "function"){
        Array.from(lotState.values()).forEach(entry => {
          if(entry && entry.areaStats && Array.isArray(entry.areaStats.nutrients) && entry.areaStats.nutrients.length){
            entries.push(entry);
          }
        });
      }
      if(entries.length){ return entries; }
      if(lastAreaStats && Array.isArray(lastAreaStats.nutrients) && lastAreaStats.nutrients.length){
        const activeEntry = activeLayerId !== null && typeof lotState !== "undefined" && lotState ? lotState.get(activeLayerId) : null;
        return [{
          id: activeEntry && activeEntry.id ? activeEntry.id : "activo",
          name: activeEntry && activeEntry.name ? activeEntry.name : "Polígono activo",
          areaStats: lastAreaStats
        }];
      }
      return [];
    }
    function getSelectedObjective(){
      if(!select || !select.value){ return null; }
      const parsed = parseObjectiveValue(select.value);
      const source = parsed.type === "secondary" ? secondaryObjectives : cropObjectives;
      return (source || []).find(item => Number(item && item.id) === Number(parsed.id)) || null;
    }
    function mapTargets(objective){
      const map = new Map();
      const rows = Array.isArray(objective && objective.nutrient_targets) ? objective.nutrient_targets : [];
      rows.forEach(item => {
        const key = canonicalNutrientKey(item);
        const ideal = Number(item.target_value);
        if(!key){ return; }
        map.set(key, {name:item.nutrient_name || item.nutrient_symbol || "Nutriente", symbol:item.nutrient_symbol || "", unit:item.nutrient_unit || "", ideal:Number.isFinite(ideal) ? ideal : null});
      });
      return map;
    }
    function mapActuals(stats){
      const map = new Map();
      const rows = Array.isArray(stats && stats.nutrients) ? stats.nutrients : [];
      rows.forEach(item => {
        const key = canonicalNutrientKey(item);
        const actual = Number(item.target_value);
        if(!key){ return; }
        map.set(key, {name:item.nutrient_name || item.nutrient_symbol || "Nutriente", symbol:item.nutrient_symbol || "", unit:item.nutrient_unit || "", actual:Number.isFinite(actual) ? actual : null});
      });
      return map;
    }
    function isMacro(row){
      const key = canonicalNutrientKey(row || {});
      const symbol = normalizeName(row && row.symbol);
      const name = normalizeName(row && row.name);
      const macroKeys = new Set(["n", "p", "k", "ca", "mg", "s", "si"]);
      return macroKeys.has(key) || macroKeys.has(symbol) || macroKeys.has(name);
    }
    function buildRows(stats, objective){
      const actuals = mapActuals(stats);
      const targets = mapTargets(objective);
      const keys = Array.from(new Set([...actuals.keys(), ...targets.keys()]));
      return keys.map(key => {
        const a = actuals.get(key) || {};
        const b = targets.get(key) || {};
        const row = {key, name:a.name || b.name || "Nutriente", symbol:a.symbol || b.symbol || "", unit:a.unit || b.unit || "", actual:a.actual != null ? a.actual : null, ideal:b.ideal != null ? b.ideal : null};
        row.type = isMacro(row) ? "Macronutriente" : "Micronutriente";
        row.pct = row.actual != null && row.ideal != null && row.ideal > 0 ? (row.actual / row.ideal) * 100 : null;
        return row;
      }).sort((a,b) => a.type !== b.type ? (a.type === "Macronutriente" ? -1 : 1) : (a.symbol || a.name).localeCompare(b.symbol || b.name));
    }
    function pctColor(pct){
      if(pct == null){ return "bg-gray-300"; }
      if(pct < 60){ return "bg-red-500"; }
      if(pct < 88){ return "bg-amber-500"; }
      if(pct <= 125){ return "bg-emerald-500"; }
      return "bg-emerald-800";
    }
    function chart(title, rows){
      const visible = rows.filter(row => row.pct != null);
      if(!visible.length){ return '<div class="rounded-xl border border-gray-200 bg-white p-3 text-[11px] text-gray-500 shadow-sm">Sin datos para ' + escapeHtml(title) + '.</div>'; }
      return '<div class="rounded-xl border border-gray-200 bg-white p-3 shadow-sm">'
        + '<h4 class="mb-2 text-center text-sm font-semibold text-emerald-800">' + escapeHtml(title) + '</h4>'
        + '<div class="overflow-x-auto"><table class="min-w-full text-[11px]"><thead><tr class="text-gray-400">'
        + '<th class="w-12 px-1 py-1 text-left font-semibold">Nutr.</th><th class="px-1 py-1 text-left font-semibold">Barra</th><th class="w-20 px-1 py-1 text-right font-semibold">Actual</th><th class="w-20 px-1 py-1 text-right font-semibold">Ideal</th><th class="w-14 px-1 py-1 text-right font-semibold">%</th></tr></thead><tbody>'
        + visible.map(row => {
          const width = Math.max(2, Math.min(100, row.pct));
          const unit = row.unit ? ' ' + escapeHtml(row.unit) : '';
          return '<tr class="border-t border-gray-100">'
            + '<td class="px-1 py-1.5 text-gray-500" title="' + escapeHtml(row.name) + '">' + escapeHtml(row.symbol || row.name) + '</td>'
            + '<td class="px-1 py-1.5"><div class="h-2 min-w-[120px] rounded bg-gray-100"><div class="h-2 rounded ' + pctColor(row.pct) + '" style="width:' + width.toFixed(1) + '%"></div></div></td>'
            + '<td class="px-1 py-1.5 text-right font-semibold text-emerald-800 whitespace-nowrap">' + formatNutrientValue(row.actual) + unit + '</td>'
            + '<td class="px-1 py-1.5 text-right text-sky-700 whitespace-nowrap">' + formatNutrientValue(row.ideal) + unit + '</td>'
            + '<td class="px-1 py-1.5 text-right font-semibold whitespace-nowrap">' + row.pct.toFixed(1) + '%</td></tr>';
        }).join('')
        + '</tbody></table></div></div>';
    }
    function detailedTable(rows){
      return '<div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white shadow-sm"><table class="min-w-full divide-y divide-gray-200 text-[11px]"><thead class="bg-emerald-600 text-white"><tr><th class="px-3 py-2 text-left">Nutriente</th><th class="px-3 py-2 text-left">Símbolo</th><th class="px-3 py-2 text-left">Valor Actual</th><th class="px-3 py-2 text-left">Unidad</th><th class="px-3 py-2 text-left">Valor Ideal</th><th class="px-3 py-2 text-left">Tipo</th><th class="px-3 py-2 text-left">% del Ideal</th></tr></thead><tbody class="divide-y divide-gray-100 bg-white">' + rows.map(row => {
        const pct = row.pct != null ? row.pct.toFixed(1) + '%' : '--';
        const badge = row.type === "Macronutriente" ? "bg-emerald-100 text-emerald-700" : "bg-sky-100 text-sky-700";
        const barWidth = row.pct != null ? Math.max(4, Math.min(100, row.pct)) : 0;
        return '<tr><td class="px-3 py-2">' + escapeHtml(row.name) + '</td><td class="px-3 py-2 font-semibold">' + escapeHtml(row.symbol || '--') + '</td><td class="px-3 py-2 font-semibold text-emerald-800">' + formatNutrientValue(row.actual) + '</td><td class="px-3 py-2">' + escapeHtml(row.unit || '--') + '</td><td class="px-3 py-2 text-sky-700">' + formatNutrientValue(row.ideal) + '</td><td class="px-3 py-2"><span class="rounded-full px-2.5 py-1 text-xs font-semibold ' + badge + '">' + row.type + '</span></td><td class="px-3 py-2"><div class="flex items-center gap-2"><strong class="w-14">' + pct + '</strong><span class="h-2 w-24 rounded-full bg-gray-200"><span class="block h-2 rounded-full ' + pctColor(row.pct) + '" style="width:' + barWidth.toFixed(1) + '%"></span></span></div></td></tr>';
      }).join('') + '</tbody></table></div>';
    }
    function balancePayload(rows, stats, objective){
      const order = [], targets = {}, actuals = {};
      rows.forEach(row => { order.push(row.name); if(row.ideal != null){ targets[row.name] = row.ideal; } if(row.actual != null){ actuals[row.name] = row.actual; } });
      const broma = stats && stats.bromatologia ? stats.bromatologia : {};
      const firstNumber = (...values) => {
        for(const value of values){
          const num = Number(value);
          if(Number.isFinite(num) && num > 0){ return num; }
        }
        return null;
      };
      const aforoActual = firstNumber(broma.aforo_ua_ha, broma.aforo, stats.yield_estimate, stats.aforo_ua_ha, stats.aforo, stats.aforo_actual);
      const aforoObjective = firstNumber(objective && objective.target_value, objective && objective.aforo, objective && objective.aforo_objective);
      const protein = firstNumber(objective && objective.protein, objective && objective.protein_average);
      return {order, targets, actuals, aforo_objective:aforoObjective, aforo_actual:aforoActual, protein:protein};
    }
    async function getBalance(entry, rows, objective){
      if(!ENDPOINTS.mineralBalance || !rows.length){ return null; }
      const payload = balancePayload(rows, entry.areaStats || {}, objective);
      const key = JSON.stringify({id:entry.id, objective:select ? select.value : '', payload});
      if(balanceCache.has(key)){ return balanceCache.get(key); }
      const res = await fetch(ENDPOINTS.mineralBalance, {method:'POST', credentials:'include', headers:{'Content-Type':'application/json', 'X-CSRF-TOKEN':getCsrfToken() || ''}, body:JSON.stringify(payload)});
      if(!res.ok){ return null; }
      const data = await res.json().catch(() => null);
      balanceCache.set(key, data);
      return data;
    }
    function balanceTable(balance, entry, objective){
      const entries = balance && Array.isArray(balance.entries) ? balance.entries : [];
      if(!entries.length){ return '<div class="rounded-2xl border border-gray-200 bg-white p-4 text-xs text-gray-500 shadow-sm">Balance mineral pendiente de datos suficientes.</div>'; }
      const stats = entry && entry.areaStats ? entry.areaStats : {};
      const broma = stats.bromatologia || {};
      const firstNumber = (...values) => {
        for(const value of values){
          const num = Number(value);
          if(Number.isFinite(num) && num > 0){ return num; }
        }
        return null;
      };
      const proteinObjective = firstNumber(objective && objective.protein, objective && objective.protein_average);
      const aforoObjective = firstNumber(balance && balance.aforo_objective, objective && objective.target_value, objective && objective.aforo, objective && objective.aforo_objective);
      const proteinActual = firstNumber(stats.protein, stats.protein_average, broma.proteina_pct, broma.proteina);
      const aforoActual = firstNumber(broma.aforo_ua_ha, broma.aforo, stats.yield_estimate, stats.aforo_ua_ha, stats.aforo, stats.aforo_actual, balance && balance.aforo_actual);
      const formatSummary = (value, suffix) => Number.isFinite(value) && value > 0 ? value.toFixed(2) + (suffix || '') : '--';
      const sumFor = key => entries.reduce((total, item) => {
        const value = Number(item[key]);
        return Number.isFinite(value) ? total + value : total;
      }, 0);
      const totalCell = (value, suffix) => '<td class="px-2 py-1.5 text-center font-bold">' + (value == null ? '--' : formatNutrientValue(value) + (suffix || '')) + '</td>';
      const row = (label, key, cls, totalValue, suffix) => '<tr class="' + (cls || '') + '"><td class="sticky left-0 w-28 bg-inherit px-2 py-1.5 font-semibold">' + label + '</td>' + entries.map(item => '<td class="px-2 py-1.5 text-center">' + formatNutrientValue(item[key]) + '</td>').join('') + totalCell(totalValue, suffix) + '</tr>';
      const objectiveKgTotal = sumFor('objective_kg');
      const actualKgTotal = sumFor('actual_kg');
      const diffTotal = sumFor('difference_kg');
      const gradeTotal = sumFor('grade_pct');
      return '<div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm"><div class="mb-3 flex flex-wrap items-center justify-between gap-2"><h4 class="text-sm font-semibold text-gray-800">Balance de Minerales</h4><span class="rounded-full bg-gray-100 px-2.5 py-1 text-[11px] text-gray-600">Déficits convertidos a kg/ha según el aforo</span></div>'
        + '<div class="mb-3 grid grid-cols-4 divide-x divide-gray-200 overflow-hidden rounded-lg border border-gray-200 text-center text-[11px]"><div class="bg-gray-100 px-3 py-2"><div class="uppercase tracking-wide text-gray-500">Proteína objetivo</div><strong class="mt-1 block text-sm text-gray-900">' + formatSummary(proteinObjective, '') + '</strong></div><div class="bg-gray-100 px-3 py-2"><div class="uppercase tracking-wide text-gray-500">Aforo objetivo</div><strong class="mt-1 block text-sm text-gray-900">' + formatSummary(aforoObjective, '') + '</strong></div><div class="bg-gray-200 px-3 py-2"><div class="uppercase tracking-wide text-gray-500">Proteína actual</div><strong class="mt-1 block text-sm text-gray-900">' + formatSummary(proteinActual, '') + '</strong></div><div class="bg-gray-200 px-3 py-2"><div class="uppercase tracking-wide text-gray-500">Aforo actual</div><strong class="mt-1 block text-sm text-gray-900">' + formatSummary(aforoActual, '') + '</strong></div></div>'
        + '<div class="overflow-x-auto"><table class="w-full min-w-[1120px] table-fixed text-[11px]"><thead class="bg-gray-50"><tr><th class="sticky left-0 w-28 bg-gray-50 px-2 py-1.5 text-left">Concepto</th>' + entries.map(item => '<th class="px-2 py-1.5 text-center">' + escapeHtml(item.name) + '</th>').join('') + '<th class="px-2 py-1.5 text-center">Total</th></tr></thead><tbody>'
        + row('Objetivo (% · ppm)', 'objective_raw', 'bg-indigo-50', null)
        + row('Objetivo (kg/ha)', 'objective_kg', 'bg-indigo-50', objectiveKgTotal, ' kg/ha')
        + row('Actual (% · ppm)', 'actual_raw', 'bg-sky-50', null)
        + row('Actual (kg/ha)', 'actual_kg', 'bg-sky-50', actualKgTotal, ' kg/ha')
        + row('Diferencia (kg/ha)', 'difference_kg', 'bg-red-50 text-red-600', diffTotal, ' kg/ha')
        + row('Grado fórmula (%)', 'grade_pct', 'bg-yellow-50', gradeTotal, '%')
        + '<tr class="bg-emerald-50"><td class="sticky left-0 bg-emerald-50 px-2 py-1.5 font-semibold">Nano (kg/ha)</td>' + entries.map(item => '<td class="px-2 py-1.5 text-center font-semibold text-emerald-800">' + formatNutrientValue(item.nano_kg) + '</td>').join('') + '<td class="px-2 py-1.5 text-center font-bold">' + (balance.total_kg_ha != null ? formatNutrientValue(balance.total_kg_ha) + ' kg/ha' : '--') + '</td></tr></tbody></table></div>'
        + '<p class="mt-3 text-[11px] text-gray-600">Objetivo se expresa en kg/ha con el aforo objetivo y Actual con el aforo actual. La Diferencia solo refleja déficits y Nano es la cantidad estimada del producto a aplicar según su concentración.</p></div>';
    }
    function renderEntry(entry, rows, label){
      const macro = rows.filter(row => row.type === 'Macronutriente');
      const micro = rows.filter(row => row.type === 'Micronutriente');
      const id = String(entry.id).replace(/[^a-zA-Z0-9_-]/g, '');
      return '<details open class="group rounded-2xl border border-gray-200 bg-white shadow-sm">'
        + '<summary class="flex cursor-pointer list-none flex-wrap items-center justify-between gap-3 px-4 py-3">'
        + '<div><h3 class="text-base font-semibold text-gray-900">' + escapeHtml(entry.name || 'Polígono') + '</h3>'
        + '<p class="text-xs text-gray-500">Resultados comparados contra: ' + escapeHtml(label || 'Objetivo seleccionado') + '</p></div>'
        + '<div class="flex items-center gap-2"><span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">Vista previa</span>'
        + '<span class="rounded-full border border-gray-200 px-2.5 py-1 text-[11px] font-semibold text-gray-500 group-open:hidden">Abrir</span>'
        + '<span class="hidden rounded-full border border-gray-200 px-2.5 py-1 text-[11px] font-semibold text-gray-500 group-open:inline-flex">Cerrar</span></div>'
        + '</summary>'
        + '<div class="space-y-4 border-t border-gray-100 p-4">'
        + '<div class="grid gap-4 lg:grid-cols-2">' + chart('Macronutrientes', macro) + chart('Micronutrientes', micro) + '</div>'
        + '<div><h4 class="mb-2 text-sm font-semibold text-emerald-800">Valores Detallados</h4>' + detailedTable(rows) + '</div>'
        + '<div id="previewBalance-' + id + '" class="rounded-2xl border border-gray-200 bg-white p-4 text-xs text-gray-500 shadow-sm">Calculando balance mineral...</div>'
        + '</div></details>';
    }
    async function renderBalances(entries, objective){
      for(const entry of entries){
        const id = String(entry.id).replace(/[^a-zA-Z0-9_-]/g, '');
        const node = document.getElementById('previewBalance-' + id);
        if(!node){ continue; }
        try{ node.outerHTML = balanceTable(await getBalance(entry, buildRows(entry.areaStats || {}, objective), objective), entry, objective); }
        catch(err){ node.textContent = 'No se pudo calcular el balance mineral para este polígono.'; }
      }
    }
    function renderPreview(){
      if(!section || !hint || !cards){ return; }
      syncObjectiveOptions();
      const entries = getPreviewEntries();
      const objective = getSelectedObjective();
      const label = select && select.selectedIndex >= 0 ? (select.options[select.selectedIndex].textContent || '').trim() : '';
      const signature = entries.map(entry => [entry.id, entry.name, !!entry.areaStats].join(':')).join('|') + '::' + (select ? select.value : '');
      if(signature === lastSignature){ return; }
      lastSignature = signature;
      if(!entries.length){ hint.textContent = 'Dibuja un polígono para ver aquí la comparación previa.'; cards.innerHTML = ''; return; }
      if(!objective){ hint.textContent = 'Selecciona un objetivo para completar la tabla de comparación.'; cards.innerHTML = ''; return; }
      hint.textContent = 'Comparación previa calculada con los datos del polígono y el objetivo seleccionado.';
      try{
        cards.innerHTML = entries.map(entry => renderEntry(entry, buildRows(entry.areaStats || {}, objective), label)).join('');
        renderBalances(entries, objective);
      }catch(err){
        console.error('Error renderizando vista previa nutricional', err);
        cards.innerHTML = '<div class="rounded-xl border border-red-100 bg-red-50 px-4 py-3 text-sm text-red-700">No se pudo pintar la vista previa nutricional. Revisa los datos del polígono activo.</div>';
      }
    }
    if(select){ select.addEventListener('change', () => { balanceCache.clear(); lastSignature = ''; renderPreview(); }); }
    renderPreview();
    window.setInterval(renderPreview, 800);
  })();

  })();
  </script>
{% endblock %}