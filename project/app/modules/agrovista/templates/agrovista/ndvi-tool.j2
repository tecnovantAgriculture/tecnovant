    function updateAnalysisCropOptions(items){
      analysisCropsList = Array.isArray(items) ? items.slice() : [];
      analysisCropsList.sort((a, b) => {
        const nameA = (a?.name || "").toLowerCase();
        const nameB = (b?.name || "").toLowerCase();
        return nameA.localeCompare(nameB);
      });
      analysisCropMap.clear();
      if(el.analysisCropOptions){
        el.analysisCropOptions.innerHTML = "";
      }
      for(const crop of analysisCropsList){
        if(!crop || !crop.name){
          continue;
        }
        const key = crop.name.toLowerCase();
        analysisCropMap.set(key, crop.id);
        if(el.analysisCropOptions){
          const option = document.createElement("option");
          option.value = crop.name;
          el.analysisCropOptions.appendChild(option);
        }
      }
    }

    async function fetchAnalysisCrops(){
      try{
        const res = await fetch(ENDPOINTS.analysisCrops, { credentials: "include" });
        if(!res.ok){
          return;
        }
        const data = await res.json();
        updateAnalysisCropOptions(Array.isArray(data) ? data : []);
      }catch(err){
        console.error("analysis-crops", err);
      }
    }

    function resolveAnalysisCropSelection(){
      const input = el.analysisCropInput;
      if(!input){
        return { id: null, name: "" };
      }
      const name = (input.value || "").trim();
      if(!name){
        return { id: null, name: "" };
      }
      const key = name.toLowerCase();
      const id = analysisCropMap.has(key) ? analysisCropMap.get(key) : null;
      return { id, name };
    }

    const foliarState = {
      farms: [],
      lots: [],
    };
    let isSavingFoliar = false;

