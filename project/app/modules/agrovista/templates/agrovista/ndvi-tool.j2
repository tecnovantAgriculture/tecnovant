    let cropObjectives = [];
    let lotCrops = [];
    let lotCropsLoaded = false;

    /* ---------- Utils ---------- */
    // Nice step length selector for scales
    function niceStep(length){
      const seeds = [1,2,5];
      const p = Math.pow(10, Math.floor(Math.log10(length || 1)));
      let best = p;
      for(const s of seeds){
        const cand = s * p;
        if(cand <= length) best = cand;
        if(cand >= length * 0.6) return cand;
      }
      return best;
    }

    function formatMetric(value, decimals = 3){
      if(typeof value === "number" && isFinite(value)){
        return value.toFixed(decimals);
      }
      return "--";
    }

    function formatNutrientValue(value){
      if(typeof value !== "number" || !isFinite(value)){
        return "--";
      }
      if(Math.abs(value) >= 100){
        return value.toFixed(1);
      }
      if(Math.abs(value) >= 10){
        return value.toFixed(2);
      }
      return value.toFixed(3);
    }

    function isFiniteNumber(value){
      return typeof value === "number" && isFinite(value);
    }

    function setText(node, value, fallback = "--"){
      if(!node){
        return;
      }
      const text = value === null || value === undefined || value === "" ? fallback : value;
      node.textContent = text;
    }

    function updateAssetLabels(name){
      const label = name || "Sin ortofoto";
      setText(el.headerAssetName, label, "Sin ortofoto");
      setText(el.contextAsset, label, "Sin ortofoto");
    }

    /* Escape helpers for HTML/attributes */
    function escapeHtml(str){
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escapeAttr(str){
      return String(str).replace(/"/g,'&quot;').replace(/'/g,'&#x27;');
    }

    /* Farm Picker */
    function renderFarmPickerList() {
      if (!el.farmPickerList) return;
      if (!foliarState.farms.length) {
        el.farmPickerList.innerHTML = '<li class="px-5 py-3 text-sm text-gray-400 dark:text-gray-500">Sin fincas disponibles</li>';
        return;
      }
      el.farmPickerList.innerHTML = foliarState.farms.map(farm => {
        const isActive = window.currentFarmId && Number(window.currentFarmId) === Number(farm.id);
        const activeClass = isActive
          ? 'bg-emerald-50 dark:bg-emerald-900/20 font-semibold text-emerald-700 dark:text-emerald-400'
          : 'text-gray-800 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700';
        return `<li><button type="button"
          class="w-full text-left px-5 py-2.5 text-sm transition-colors ${activeClass}"
          data-farm-id="${farm.id}" data-farm-name="${escapeAttr(farm.name)}">${escapeHtml(farm.name)}</button></li>`;
      }).join('');
    }
