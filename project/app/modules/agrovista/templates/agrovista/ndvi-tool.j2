    function renderNutrients(items){
      if(!el.nutrientsList){
        return;
      }
      el.nutrientsList.innerHTML = "";
      const data = Array.isArray(items) ? items : [];
      if(data.length === 0){
        const li = document.createElement("li");
        li.className = "text-xs text-gray-500 dark:text-gray-400";
        li.textContent = "Selecciona un polígono para estimar objetivos secundarios.";
        el.nutrientsList.appendChild(li);
        return;
      }
      // Filtrar Cl/cloro cuando no hay datos calibrados (target_value === 0)
      const nutrientesAMostrar = data.filter(function(n) {
        const sym = (n.nutrient_symbol || n.symbol || "").toLowerCase();
        return !(sym === "cl" || sym === "cloro") || n.target_value !== 0;
      });
      // Símbolos con valor bibliográfico (constante, no calibrado localmente)
      const BIBLIOGRAPHIC_SYMBOLS = new Set(["mo", "molibdeno", "si", "silicio"]);
      for(const item of nutrientesAMostrar){
        const name = item?.nutrient_name || item?.nutrient_symbol || "Nutriente";
        const symbol = item?.nutrient_symbol ? ` (${item.nutrient_symbol})` : "";
        const unit = item?.nutrient_unit ? ` ${item.nutrient_unit}` : "";
        const value = formatNutrientValue(item?.target_value);
        const sym = (item?.nutrient_symbol || "").toLowerCase();
        const isBibliographic = BIBLIOGRAPHIC_SYMBOLS.has(sym);
        const li = document.createElement("li");
        li.className = "flex justify-between gap-2 text-sm";
        const label = document.createElement("span");
        label.className = isBibliographic
          ? "font-medium text-emerald-600 dark:text-emerald-400"
          : "font-medium";
        label.textContent = `${name}${symbol}`;
        const val = document.createElement("span");
        val.className = isBibliographic
          ? "tabular-nums text-emerald-600 dark:text-emerald-400"
          : "tabular-nums";
        val.textContent = `${value}${unit}`;
        li.appendChild(label);
        li.appendChild(val);
        el.nutrientsList.appendChild(li);
      }
    }

    function ensureLotEntry(layer){
      const key = getLayerKey(layer);
      if(key === null){
        return null;
      }
      if(!lotState.has(key)){
        lotCounter += 1;
        lotState.set(key, {
          id: key,
          name: `Lote ${lotCounter}`,
          stats: null,
          areaStats: null,
          linkedLotId: null,
          linkedCommonAnalysisId: null,
          linkedLotName: null,
        });
      }
      return lotState.get(key);
    }

    function getPrimaryStatsFromData(data){
      const vars = getVariablesSource(data);
      const ndvi = vars?.vi;
      const vari = vars?.vari;
      const nbi = typeof vars?.nbi === "number" ? vars.nbi : vars?.exg;
      return { ndvi, vari, nbi };
    }

    function setPrimaryMetrics(data){
      const stats = getPrimaryStatsFromData(data || {});
      if(el.ndviValue){
        el.ndviValue.textContent = formatMetric(stats.ndvi, 2);
      }
      if(el.variValue){
        el.variValue.textContent = formatMetric(stats.vari, 2);
      }
      if(el.nbiValue){
        el.nbiValue.textContent = formatMetric(stats.nbi, 2);
        if(typeof stats.nbi === "number" && !("nbi" in (data || {}))){
          el.nbiValue.setAttribute("title", "ExG (aprox.)");
        }else{
          el.nbiValue.removeAttribute("title");
        }
      }
      // Update NDVI indicator position on rgb-bar
      if(el.ndviIndicator){
        if(typeof stats.ndvi === "number" && isFinite(stats.ndvi)){
          const pct = Math.max(0, Math.min(100, stats.ndvi * 100));
          el.ndviIndicator.style.left = pct + "%";
          el.ndviIndicator.style.opacity = "1";
          if(el.ndviIndicatorLabel){
            el.ndviIndicatorLabel.textContent = stats.ndvi.toFixed(2);
          }
        } else {
          el.ndviIndicator.style.opacity = "0";
          if(el.ndviIndicatorLabel){
            el.ndviIndicatorLabel.textContent = "--";
          }
        }
      }
    }

    const polygonStyleNormal = { color: '#0066cc', weight: 2, opacity: 0.7, fillOpacity: 0.2 };
    const polygonStyleActive = { color: '#22c55e', weight: 3, opacity: 1, fillOpacity: 0.35 };

    function setActiveLayer(layer){
      const entry = ensureLotEntry(layer);
      // Restaurar estilo normal al layer anterior
      if(activeLayerId !== null){
        const prevLayer = drawnItems.getLayer(activeLayerId);
        if(prevLayer && typeof prevLayer.setStyle === "function"){
          prevLayer.setStyle(polygonStyleNormal);
        }
      }
      // Aplicar estilo activo al nuevo layer
      if(layer && typeof layer.setStyle === "function"){
        layer.setStyle(polygonStyleActive);
      }
      // Actualizar activeLayerId
      if(entry){
        activeLayerId = entry.id;
        setText(el.activeLotName, entry.name, "Sin lote seleccionado");
      }else{
        activeLayerId = null;
        setText(el.activeLotName, "Sin lote seleccionado");
      }
      renderLotsList();
    }

