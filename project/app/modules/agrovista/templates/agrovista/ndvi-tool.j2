    async function fetchLotCrops(){
      if(lotCropsLoaded){
        return lotCrops;
      }
      try{
        const res = await fetch(ENDPOINTS.foliageLotCrops, { credentials: "include" });
        if(!res.ok){
          lotCropsLoaded = true;
          lotCrops = [];
          return lotCrops;
        }
        const data = await res.json().catch(() => []);
        lotCrops = Array.isArray(data) ? data : [];
      }catch(err){
        console.error("lot-crops", err);
        lotCrops = [];
      }finally{
        lotCropsLoaded = true;
      }
      return lotCrops;
    }

    function resolveCropIdForLot(lotId){
      if(!lotId){
        return null;
      }
      const items = lotCrops.filter(item => Number(item?.lot_id) === Number(lotId));
      if(items.length === 0){
        return null;
      }
      const active = items.find(item => !item?.end_date);
      if(active && active.crop_id){
        return active.crop_id;
      }
      items.sort((a, b) => {
        const dateA = Date.parse(a?.start_date || "") || 0;
        const dateB = Date.parse(b?.start_date || "") || 0;
        return dateB - dateA;
      });
      return items[0]?.crop_id || null;
    }

