      if(!el.lotsList){
        return;
      }
      const entries = Array.from(lotState.values());
      if(el.lotsCount){
        el.lotsCount.textContent = String(entries.length);
      }
      if(entries.length === 0){
        el.lotsList.innerHTML = '<li class="text-xs italic text-gray-400">Dibuja un polígono en el mapa para registrar el primer lote.</li>';
        return;
      }
      el.lotsList.innerHTML = "";
      entries.forEach(entry => {
        const li = document.createElement("li");
        const isActive = activeLayerId === entry.id;
        li.className = `flex items-start justify-between gap-3 rounded-lg border px-3 py-2 ${isActive ? "border-emerald-200 bg-emerald-50/60" : "border-gray-100 bg-white"}`;
        const left = document.createElement("div");
        const title = document.createElement("p");
        title.className = "text-sm font-medium text-gray-900";
        title.textContent = entry.name;
        left.appendChild(title);
        const meta = document.createElement("p");
        meta.className = "text-[11px] text-gray-500";
        if(entry.stats){
          meta.textContent = `NDVI: ${formatMetric(entry.stats.ndvi, 2)} · VARI: ${formatMetric(entry.stats.vari, 2)} · NBI: ${formatMetric(entry.stats.nbi, 2)}`;
        } else if(entry.computing){
          meta.className = "text-[11px] text-emerald-600 dark:text-emerald-400 font-medium";
          meta.innerHTML = '<span class="inline-flex items-center gap-1.5"><svg class="animate-spin h-3 w-3" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg>Calculando…</span>';
        } else {
          meta.textContent = "Sin análisis calculado";
        }
        left.appendChild(meta);
        const action = document.createElement("button");
        action.type = "button";
        action.className = "text-[11px] font-medium text-emerald-700 hover:underline";
        action.textContent = "Ver";
        action.addEventListener("click", () => {
          const layer = drawnItems.getLayer(entry.id);
          if(layer){
            setActiveLayer(layer);
            updateStatsForLayer(layer);
          }
        });
        li.appendChild(left);
        li.appendChild(action);
        el.lotsList.appendChild(li);
      });
      renderCompareDrawnLots();
