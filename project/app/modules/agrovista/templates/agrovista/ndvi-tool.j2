            const lotBId = el.compareLotBSelect ? el.compareLotBSelect.value : "";
            if(!lotAId || !lotBId || lotAId === lotBId){
              throw new Error("Selecciona dos lotes diferentes para comparar.");
            }
            const entryA = getLotEntryById(lotAId);
            const entryB = getLotEntryById(lotBId);
            if(!entryA || !entryB){
              throw new Error("Selecciona los lotes dibujados para comparar.");
            }
            if(!entryB.linkedLotId){
              throw new Error("Guarda el análisis foliar del Lote B antes de generar el informe.");
            }
            const commonId = entryB.linkedCommonAnalysisId || getLatestCommonAnalysisId(entryB.linkedLotId);
            if(!commonId){
              throw new Error("El Lote B no tiene un análisis común registrado.");
            }
            const areaStats = await ensureAreaStatsForEntry(entryA);
            if(!areaStats || !Array.isArray(areaStats.nutrients) || areaStats.nutrients.length === 0){
              throw new Error("Calcula los datos del Lote A antes de generar el informe.");
            }
            const layerA = drawnItems.getLayer(entryA.id);
            const layerB = drawnItems.getLayer(entryB.id);
            payload.lot_a = {
              id: entryA.id,
              name: entryA.name,
              stats: entryA.stats,
              area_stats: cloneAreaStats(areaStats),
              area_ha: layerA ? computeAreaHaForLayer(layerA) : null,
              linked_lot_id: entryA.linkedLotId ? Number(entryA.linkedLotId) : null,
              linked_common_analysis_id: entryA.linkedCommonAnalysisId
                ? Number(entryA.linkedCommonAnalysisId)
                : null,
            };
            payload.lot_b = {
              id: entryB.id,
              name: entryB.name,
              stats: entryB.stats,
