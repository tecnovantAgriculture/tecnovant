{# index.j2 #}
{% extends "base.j2" %}
{% set dashboard = true %}
{% set bg_color = "bg-transparent" %}
{% set rounded = "" %}
{% set shadow = "" %}
{% set padding = "" %}
{% set flush_content_shell = true %}
{% set main_clases = "flex-grow overflow-y-auto p-0" %}
{% from "settings/_ui_class.j2" import base_button_classes, input_bg_color, border_color, hover_bg_color, focus_ring_color, button_bg_color, delete_button_bg_color, input_focus_bg_color, text_color %}
{% from "macros/_forms.j2" import render_alert %}

{% block extra_css %}
  {{ css_code|safe }}
  {{ super() }}
  <link rel="stylesheet" href="/css/leaflet.css" />
  <link rel="stylesheet" href="/css/leaflet.draw.css" />
  <style>
    #map{
      height: clamp(380px, 72vh, 780px);
      position: relative;
      z-index: 0;
    }

    /* Keep space for right ruler (+ shift default right controls) */
    :root { --ruler-right-w: 64px; }
    #map .leaflet-top.leaflet-right{ right:var(--ruler-right-w,64px); }

    /* Drop left controls by 40px to avoid top ruler overlap */
    .leaflet-top.leaflet-left{ top:40px; }

    .leaflet-top,.leaflet-bottom{ pointer-events:none; }
    .leaflet-control{ pointer-events:auto; }

    .leaflet-draw,
    .leaflet-draw-toolbar {
      display:none !important;
    }

    /* (Optional) Hide Leaflet attribution – keep it visible in production to respect license */
    .leaflet-control-attribution.leaflet-control {
      display:none !important; visibility:hidden !important; opacity:0 !important; pointer-events:none !important;
    }
    #foliar-analysis-modal {z-index:999999 !important}
    #farm-picker-modal {z-index:999999 !important}

    /* Fullscreen: right sidebar must not overflow viewport and must scroll independently */
    #workzone:fullscreen aside,
    #workzone:-webkit-full-screen aside,
    #workzone:-moz-full-screen aside {
      max-height: 100vh;
      overflow-y: auto;
      overscroll-behavior: contain;
    }
  </style>
{% endblock %}

{% block extra_head %}
  {{ js_code|safe }}
  {{ super() }}
{% endblock %}

{% block content %}
<div id="workzone" class="w-full bg-transparent min-h-screen">
  <div class="w-full px-0 py-0 space-y-4">
    <nav class="text-sm text-gray-500 dark:text-gray-400">
      <ol class="flex items-center gap-2">
        <li><a href="{{ url_for('core.dashboard') }}" class="hover:text-gray-700 dark:hover:text-gray-300">Inicio</a></li>
        <li class="text-gray-400 dark:text-gray-600">/</li>
        <li><a href="{{ url_for('agrovista.hello') }}" class="hover:text-gray-700 dark:hover:text-gray-300">Análisis</a></li>
        <li class="text-gray-400 dark:text-gray-600">/</li>
        <li class="text-gray-700 dark:text-gray-300 font-medium">Imagen</li>
      </ol>
    </nav>

    <header class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100">
          Análisis de imagen –
          <span id="headerAssetName" class="text-gray-500 dark:text-gray-400">{{ context_asset or "Sin ortofoto" }}</span>
        </h1>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          Dibuja polígonos sobre la ortofoto para calcular índices y preparar la comparación de lotes.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <button id="upload-trigger"
                class="inline-flex items-center rounded-lg bg-white dark:bg-gray-800 px-3 py-2 text-xs font-medium text-gray-700 dark:text-gray-300 shadow-sm ring-1 ring-gray-200 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700">
          Subir ortofoto
        </button>
        <button id="open-media-picker"
                class="inline-flex items-center rounded-lg bg-gray-900 dark:bg-gray-100 px-3 py-2 text-xs font-semibold text-white dark:text-gray-900 shadow-sm hover:bg-gray-800 dark:hover:bg-gray-200">
          Seleccionar desde Media
        </button>
        <div class="flex items-center gap-2 text-xs">
          <span class="text-gray-500 dark:text-gray-400">Vista:</span>
          <select id="preview-selector"
                  class="block rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 dark:text-gray-100 py-1.5 pl-3 pr-8 text-xs shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500">
            <option value="nd_index_rgba" selected>Índice espectral</option>
            <option value="rgb">RGB</option>
            <option value="vi_heat">VI Heat</option>
            <option value="vi_ratio">VI Ratio</option>
            <option value="vi_heatmap">Heatmap</option>
          </select>
        </div>
        <button id="toggleLegendBtn"
                class="inline-flex items-center rounded-full bg-gray-100 dark:bg-gray-700 px-3 py-1 text-xs font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600">
          <span class="mr-2 h-2 w-2 rounded-full bg-gradient-to-r from-red-500 via-yellow-400 to-green-500"></span>
          Mapa de colores
        </button>
      </div>
    </header>

    <input type="file" id="uploader" accept=".tif,.tiff,.jp2,.png,.jpg,.jpeg" class="hidden" />

    <section class="grid gap-4 lg:grid-cols-12 lg:items-start">
      <div class="lg:col-span-8 xl:col-span-9 space-y-3">
        <div id="map-container" class="relative isolate overflow-hidden rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm">
          <!-- Herramientas de dibujo: izquierda, separadas del borde -->
          <div id="drawing-tools-layer" class="absolute left-14 top-14 z-30 flex flex-col gap-2">
            <button id="drawPolygonBtn"
                    class="inline-flex items-center rounded-md bg-white dark:bg-gray-700 px-3 py-1.5 text-xs font-medium text-gray-800 dark:text-gray-100 shadow-md ring-1 ring-gray-200 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
              <span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-md bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 text-xs">
                △
              </span>
              Polígono
            </button>
            <button id="drawRectangleBtn"
                    class="inline-flex items-center rounded-md bg-white dark:bg-gray-700 px-3 py-1.5 text-xs font-medium text-gray-800 dark:text-gray-100 shadow-md ring-1 ring-gray-200 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
              <span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-md bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-400 text-xs">
                ▭
              </span>
              Rectángulo
            </button>
            <button id="selectPolygonBtn"
                    class="inline-flex items-center rounded-md bg-white dark:bg-gray-700 px-3 py-1.5 text-xs font-medium text-gray-800 dark:text-gray-100 shadow-md ring-1 ring-gray-200 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
              <span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-md bg-sky-100 dark:bg-sky-900/40 text-sky-700 dark:text-sky-400 text-xs">
                ⌖
              </span>
              Seleccionar
            </button>
            <button id="resetMapBtn"
                    class="inline-flex items-center rounded-md bg-white dark:bg-gray-700 px-3 py-1.5 text-xs font-medium text-gray-800 dark:text-gray-100 shadow-md ring-1 ring-gray-200 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
              <span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-md bg-rose-100 dark:bg-rose-900/40 text-rose-700 dark:text-rose-400 text-xs">
                ↺
              </span>
              Reiniciar
            </button>
          </div>

          <!-- Herramientas de utilidad: derecha, separadas del borde -->
          <div class="absolute right-14 top-14 z-30 flex flex-col gap-2">
            <button id="fit-bounds"
                    class="inline-flex items-center rounded-md bg-white dark:bg-gray-700 px-3 py-1.5 text-xs font-medium text-gray-800 dark:text-gray-100 shadow-md ring-1 ring-gray-200 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
              Ajustar imagen
            </button>
            <button id="enter-fullscreen"
                    class="inline-flex items-center rounded-md bg-white dark:bg-gray-700 px-3 py-1.5 text-xs font-medium text-gray-800 dark:text-gray-100 shadow-md ring-1 ring-gray-200 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
              Pantalla completa
            </button>
            <button id="exit-fullscreen"
                    class="inline-flex items-center rounded-md bg-white dark:bg-gray-700 px-3 py-1.5 text-xs font-medium text-gray-800 dark:text-gray-100 shadow-md ring-1 ring-gray-200 dark:ring-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors hidden">
              Salir pantalla completa
            </button>
            <button id="download-kmz"
                    class="inline-flex items-center rounded-md bg-white dark:bg-gray-700 px-3 py-1.5 text-xs font-medium text-gray-400 dark:text-gray-400 shadow-md ring-1 ring-gray-200 dark:ring-gray-600 opacity-60 cursor-not-allowed"
                    disabled>
              Descargar KMZ
            </button>
          </div>

          <div id="map" class="w-full bg-gray-100 dark:bg-gray-800"></div>
        </div>

        <div id="legendPanel"
             class="flex items-center justify-between rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-4 py-3 text-xs text-gray-700 dark:text-gray-300 shadow-sm">
          <div class="flex items-center gap-3 w-[100%]">
            <span class="font-medium text-gray-800 dark:text-gray-200">Leyenda de colores</span>
            <div id="rgb-bar-container" class="relative w-[90%] sm:w-[60%] lg:max-w-[40rem]">
              <div id="rgb-bar" class="h-3 rounded-full bg-gradient-to-r from-red-500 via-yellow-400 to-green-500"></div>
              <div id="ndviIndicator" class="absolute top-0 flex h-3 items-start transition-all duration-500 ease-out" style="left: 0%; opacity: 0;">
                <div class="relative mx-auto flex h-4 w-4 items-center justify-center">
                  <div class="absolute h-2.5 w-2.5 rotate-45 border-2 border-gray-900 dark:border-white bg-white dark:bg-gray-900 shadow-md"></div>
                  <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 whitespace-nowrap text-[9px] font-bold text-gray-900 dark:text-white drop-shadow-sm">
                    <span id="ndviIndicatorLabel">--</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-4 text-[11px] text-gray-500 dark:text-gray-400">
              <span>Bajo</span>
              <span>Medio</span>
              <span>Alto</span>
            </div>
          </div>
          <div class="hidden sm:flex items-center gap-2 text-[11px] text-gray-500 dark:text-gray-400">
            <span>Escala 0.0 – 1.0</span>
          </div>
        </div>

        <div class="flex flex-wrap items-center justify-between gap-2 text-xs text-gray-500 dark:text-gray-400">
          <div id="method-box" class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2 text-xs text-gray-600 dark:text-gray-400 shadow-sm">
            Método: <span id="method-value">--</span>
          </div>
          <div id="status" class="text-xs text-gray-500 dark:text-gray-400" aria-live="polite">Sube una imagen para analizar</div>
        </div>

        {# Codex: vista previa nutricional, aislada de la lógica principal #}
        <section id="polygonComparisonPreview" class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4 shadow-sm">
          <div class="mb-3 flex flex-wrap items-start justify-between gap-3">
            <div>
              <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><i class="fas fa-balance-scale mr-2 text-emerald-700"></i>Vista previa nutricional</h2>
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Selecciona un objetivo y dibuja uno o más polígonos para ver sus datos calculados.</p>
            </div>
            <div class="min-w-[240px]">
              <label for="polygonComparisonObjective" class="mb-1 block text-xs font-semibold text-gray-600 dark:text-gray-400">Objetivo</label>
              <select id="polygonComparisonObjective" class="block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 dark:text-gray-100 py-1.5 px-3 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500">
                <option value="">Selecciona un objetivo</option>
              </select>
            </div>
          </div>
          <div id="polygonComparisonHint" class="rounded-xl bg-gray-50 dark:bg-gray-700 px-3 py-2 text-xs text-gray-500 dark:text-gray-400">Dibuja un polígono para ver aquí la comparación previa.</div>
          <div id="polygonComparisonCards" class="mt-3 space-y-3 overflow-y-auto pr-2" style="max-height: 760px;"></div>
        </section>
      </div>

      <aside class="space-y-4 lg:col-span-4 xl:col-span-3">
        <section class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4 shadow-sm">
          <h2 class="mb-3 text-sm font-semibold text-gray-800 dark:text-gray-200">Contexto</h2>
          <dl class="space-y-1 text-sm text-gray-600 dark:text-gray-400">
            <div class="flex justify-between">
              <dt class="text-gray-500 dark:text-gray-400"><i class="fas fa-users mr-2"></i>Cliente</dt>
              <dd id="contextClient" class="font-medium text-gray-800 dark:text-gray-200">{{ context_client or "Sin cliente" }}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-500 dark:text-gray-400"><i class="fas fa-tractor mr-2"></i>Finca</dt>
              <button id="contextFarm" type="button"
                      class="font-medium text-emerald-600 dark:text-emerald-400 hover:underline text-sm text-right leading-snug">
                {{ context_farm or "Seleccionar finca…" }}
              </button>
            </div>
            <div class="flex justify-between">
              <dt class="text-gray-500 dark:text-gray-400"><i class="fas fa-satellite-dish mr-2"></i>Ortofoto</dt>
              <dd id="contextAsset" class="font-medium text-gray-800 dark:text-gray-200">{{ context_asset or "Sin ortofoto" }}</dd>
            </div>
          </dl>
        </section>

        <section class="rounded-xl border border-blue-200 dark:border-blue-800 bg-blue-50/70 dark:bg-blue-900/20 p-4 shadow-sm">
          <h2 class="mb-3 text-sm font-semibold text-blue-900 dark:text-blue-300">
            <i class="fas fa-map-marker mr-2"></i>Lote de referencia (trazabilidad)
          </h2>
          <div class="space-y-3 text-xs text-gray-700 dark:text-gray-300">
            <div>
              <label class="mb-1 block font-medium text-gray-700 dark:text-gray-400">Selecciona un lote guardado</label>
              <select id="referenceLotsSelect"
                      class="block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 dark:text-gray-100 py-1.5 px-3 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                <option value="">-- Sin lote seleccionado --</option>
              </select>
            </div>
            <div id="lotPolygonStatus" class="text-xs text-gray-500 dark:text-gray-400 italic">
              Selecciona un lote para visualizar su polígono (si existe)
            </div>
            <button id="savePolygonToLotBtn"
                    class="w-full inline-flex items-center justify-center rounded-lg bg-blue-600 hover:bg-blue-700 px-3 py-2 text-xs font-semibold text-white shadow-sm disabled:cursor-not-allowed disabled:bg-gray-400"
                    disabled
                    title="Guarda el polígono dibujado en el lote seleccionado">
              <i class="fas fa-save mr-2"></i>Guardar polígono en lote
            </button>
          </div>
        </section>

        <section class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4 shadow-sm">
          <div class="mb-3 flex items-center justify-between">
             <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200"><i class="fas fa-seedling mr-2"></i>Lotes dibujados</h2>
            <span class="rounded-full bg-emerald-50 dark:bg-emerald-900/30 px-2 py-0.5 text-[11px] font-medium text-emerald-700 dark:text-emerald-400">
              <span id="lotsCount">0</span> lotes
            </span>
          </div>
          <ul id="lotsList" class="space-y-2 text-sm">
            <li class="text-xs italic text-gray-400 dark:text-gray-500">
              Dibuja un polígono en el mapa para registrar el primer lote.
            </li>
          </ul>
        </section>

        <section class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 p-4 shadow-sm">
          <div class="mb-3 flex items-center justify-between">
             <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200"><i class="fas fa-chart-line mr-2"></i>Análisis del lote seleccionado</h2>
            <span id="activeLotName" class="text-xs text-gray-500 dark:text-gray-400">Sin lote seleccionado</span>
          </div>

          <div class="space-y-3">
            <div>
              <label class="mb-1 block text-xs font-medium text-gray-600 dark:text-gray-400">
                Fecha de análisis suelo/foliar
              </label>
              <select id="analysisDateSelect"
                      class="block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 dark:text-gray-100 py-1.5 px-3 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500"
                      disabled>
                <option>Selecciona un análisis disponible</option>
              </select>
            </div>

            <div class="grid grid-cols-3 gap-3 text-center text-sm">
              <div class="rounded-lg bg-gray-50 dark:bg-gray-700 px-2 py-2">
                 <dt class="text-[11px] uppercase tracking-wide text-gray-500 dark:text-gray-400"><i class="fas fa-leaf mr-1"></i>NDVI</dt>
                <dd id="ndviValue" class="mt-1 text-base font-semibold text-gray-900 dark:text-gray-100">--</dd>
              </div>
              <div class="rounded-lg bg-gray-50 dark:bg-gray-700 px-2 py-2">
                 <dt class="text-[11px] uppercase tracking-wide text-gray-500 dark:text-gray-400"><i class="fas fa-sun mr-1"></i>VARI</dt>
                <dd id="variValue" class="mt-1 text-base font-semibold text-gray-900 dark:text-gray-100">--</dd>
              </div>
              <div class="rounded-lg bg-gray-50 dark:bg-gray-700 px-2 py-2">
                 <dt class="text-[11px] uppercase tracking-wide text-gray-500 dark:text-gray-400"><i class="fas fa-water mr-1"></i>NBI</dt>
                <dd id="nbiValue" class="mt-1 text-base font-semibold text-gray-900 dark:text-gray-100">--</dd>
              </div>
            </div>

            <div id="area" class="rounded-lg bg-gray-50 dark:bg-gray-700 px-3 py-2 text-xs text-gray-600 dark:text-gray-400">
               <div id="area-box" aria-live="polite"><i class="fas fa-ruler mr-2"></i>Selecciona un polígono</div>
            </div>

            <div id="protein-box" class="rounded-lg bg-gray-50 dark:bg-gray-700 px-3 py-2 text-xs text-gray-600 dark:text-gray-400">
              <div><i class="fas fa-flask mr-2"></i>Proteína: <span id="protein-value">--</span>%</div>
              <div>Nitrógeno estimado: <span id="nitrogen-value">--</span>%</div>
              <p id="protein-message" class="mt-1 text-[11px] text-gray-500 dark:text-gray-400"></p>
            </div>

            <div id="bromatologia-box" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2 text-xs">
              <p class="mb-2 font-semibold text-gray-700 dark:text-gray-300"><i class="fas fa-seedling mr-1"></i>Perfil bromatológico</p>
              <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-gray-600 dark:text-gray-400">
                <div>FDA: <span id="broma-fda" class="font-medium text-gray-800 dark:text-gray-200">--</span>%</div>
                <div>FDN: <span id="broma-fdn" class="font-medium text-gray-800 dark:text-gray-200">--</span>%</div>
                <div>Energía: <span id="broma-mcal" class="font-medium text-gray-800 dark:text-gray-200">--</span> Mcal/kg</div>
                <div>Energía: <span id="broma-mj" class="font-medium text-gray-800 dark:text-gray-200">--</span> MJ/kg</div>
                <div>Energía2: <span id="broma-enl" class="font-medium text-gray-800 dark:text-gray-200">--</span> Mcal/kg</div>
                <div>AFORO: <span id="broma-aforo" class="font-medium text-gray-800 dark:text-gray-200">--</span> UA/ha</div>
              </div>
              <p id="broma-warning" class="hidden mt-1 text-[11px] text-amber-600 dark:text-amber-400"></p>
            </div>

            <details class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2">
              <summary class="cursor-pointer text-xs font-medium text-gray-600 dark:text-gray-400">
                Variables avanzadas
              </summary>
              <ul id="variables" class="mt-2 space-y-1 text-xs text-gray-600 dark:text-gray-400">
                <li>VI (NDVI): <span data-var="vi">--</span></li>
                <li>VARI: <span data-var="vari">--</span></li>
                <li>GLI: <span data-var="gli">--</span></li>
                <li>NGRDI: <span data-var="ngrdi">--</span></li>
                <li>ExG: <span data-var="exg">--</span></li>
              </ul>
            </details>

            <details class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2">
              <summary class="cursor-pointer text-xs font-medium text-gray-600 dark:text-gray-400">
                Nutrientes estimados
              </summary>
              <div id="nutrients-box" class="mt-2 text-xs text-gray-700 dark:text-gray-300">
                <ul id="nutrients-list" class="space-y-2">
                  <li class="text-xs text-gray-500 dark:text-gray-400">
                    Dibuja un polígono para estimar objetivos secundarios.
                  </li>
                </ul>
              </div>
            </details>

            <div class="flex items-center justify-between gap-3">
              <button id="saveLotAnalysisBtn"
                      class="inline-flex flex-1 items-center justify-center rounded-lg bg-gray-900 dark:bg-gray-100 dark:text-gray-900 px-3 py-2 text-xs font-semibold text-white shadow-sm disabled:cursor-not-allowed disabled:bg-gray-300 dark:disabled:bg-gray-700 dark:disabled:text-gray-500"
                      disabled>
                Guardar análisis del lote
              </button>
              <label class="flex items-center gap-2 text-xs text-gray-600 dark:text-gray-400">
                <input id="markAsObjectiveChk"
                       type="checkbox"
                       class="h-3.5 w-3.5 rounded border-gray-300 dark:border-gray-600 text-emerald-600 focus:ring-emerald-500"
                       disabled>
                <span>Usar como objetivo de referencia</span>
              </label>
            </div>

            <div id="objectiveControls" class="space-y-2 hidden">
              <div>
                <label for="analysis-crop-name" class="block text-xs font-semibold text-gray-700 dark:text-gray-300">
                  Cultivo de referencia
                </label>
                <input
                  type="text"
                  id="analysis-crop-name"
                  list="analysis-crop-options"
                  placeholder="Ej: Kikuyo"
                  class="w-full mt-1 px-2 py-1.5 border rounded-md text-sm border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-emerald-500"
                  autocomplete="off"
                >
                <datalist id="analysis-crop-options"></datalist>
                <p id="analysis-crop-hint" class="mt-1 text-[11px] text-gray-500 dark:text-gray-400">
                  Elige un cultivo registrado o escribe uno nuevo.
                </p>
              </div>

              <button
                id="btn-create-objective"
                type="button"
                class="w-full inline-flex items-center justify-center gap-2 rounded-lg bg-emerald-600 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-emerald-700"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" />
                </svg>
                <span>Crear objetivo secundario</span>
              </button>
            </div>

            <p id="indicesRange" class="text-[11px] text-gray-500 dark:text-gray-400">
              Selecciona un polígono para ver sus índices y vincular un análisis de laboratorio.
            </p>
          </div>
        </section>

        <section class="hidden rounded-xl border border-emerald-200 dark:border-emerald-800 bg-emerald-50/70 dark:bg-emerald-900/20 p-4 shadow-sm space-y-3">
          <h2 class="text-sm font-semibold text-emerald-900 dark:text-emerald-300">
            <i class="fas fa-balance-scale mr-2"></i>Preparar comparación nutricional
          </h2>

          <div class="space-y-2 text-xs text-gray-700 dark:text-gray-300">
            <p class="font-medium">¿Qué quieres comparar?</p>

            <div class="space-y-1">
              <label class="flex items-center gap-2">
                <input type="radio" name="compareMode" value="lot_vs_objective"
                       class="h-3.5 w-3.5 text-emerald-600 focus:ring-emerald-500" checked>
                <span>Lote vs objetivo ideal (tabla de objetivos guardados)</span>
              </label>
              <label class="flex items-center gap-2">
                <input type="radio" name="compareMode" value="lot_vs_lot"
                       class="h-3.5 w-3.5 text-emerald-600 focus:ring-emerald-500">
                <span>Lote vs otro lote (ambos dibujados en la ortofoto)</span>
              </label>
            </div>
          </div>

          <div id="compareLotObjective" class="grid gap-3 text-xs md:grid-cols-2">
            <div>
              <label class="mb-1 block font-medium text-gray-700 dark:text-gray-300">Lote</label>
              <select id="compareLotSelect"
                      class="block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 dark:text-gray-100 py-1.5 px-3 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500">
                <option value="">Selecciona un lote guardado</option>
              </select>
            </div>
            <div>
              <label class="mb-1 block font-medium text-gray-700 dark:text-gray-300">Objetivo ideal</label>
              <select id="compareObjectiveSelect"
                      class="block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 dark:text-gray-100 py-1.5 px-3 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500">
                <option value="">Selecciona un objetivo</option>
              </select>
            </div>
            <div class="md:col-span-2">
              <label class="mb-1 block font-medium text-gray-700 dark:text-gray-300">Análisis del lote</label>
              <select id="compareAnalysisSelect"
                      class="block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 dark:text-gray-100 py-1.5 px-3 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 disabled:cursor-not-allowed disabled:opacity-60"
                      disabled>
                <option value="">Selecciona primero un lote</option>
              </select>
              <p class="mt-1 text-[11px] text-gray-500 dark:text-gray-400">
                La comparación usa el análisis foliar del lote en esa fecha.
              </p>
            </div>
          </div>

          <div id="compareLotLot" class="grid gap-3 text-xs md:grid-cols-2 hidden">
            <div>
              <label class="mb-1 block font-medium text-gray-700 dark:text-gray-300">Lote A</label>
              <select id="compareLotASelect"
                      class="block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 dark:text-gray-100 py-1.5 px-3 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500">
                <option value="">Selecciona Lote A</option>
              </select>
            </div>
            <div>
              <label class="mb-1 block font-medium text-gray-700 dark:text-gray-300">Lote B</label>
              <select id="compareLotBSelect"
                      class="block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 dark:text-gray-100 py-1.5 px-3 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500">
                <option value="">Selecciona Lote B</option>
              </select>
            </div>
          </div>

          <p id="compareHint" class="text-[11px] text-emerald-900 dark:text-emerald-300">
            Cuando tengas al menos un lote con análisis guardado podrás lanzar la comparación y ver la tabla de Ley de Mínimos.
          </p>

          <button id="goToComparisonBtn"
                  class="mt-1 inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm disabled:cursor-not-allowed disabled:bg-emerald-300 dark:disabled:bg-emerald-900 dark:disabled:text-emerald-500"
                  data-compare-url="{{ url_for('agrovista.comparison_config') }}"
                  disabled>
            Ver comparación nutricional
          </button>
        </section>
      </aside>
    </section>
  </div>
</div>
<div id="foliar-analysis-modal" class="hidden fixed inset-0 z-40 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center px-4 py-6">
  <div class="w-full max-w-3xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl">
    <div class="flex items-start justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
      <div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Nuevo analisis foliar</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Completa los datos para registrar el analisis y guardar los nutrientes del poligono.</p>
      </div>
      <button type="button" id="foliar-modal-close" class="{{ base_button_classes }} text-sm">Cerrar</button>
    </div>
    <form id="foliar-analysis-form" class="px-5 py-4 space-y-4">
      <p id="foliar-analysis-message" class="text-sm text-red-500 hidden"></p>
      <div class="grid gap-4 md:grid-cols-2">
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Finca</span>
          <select id="analysis-farm" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" required>
            <option value="">Selecciona una finca</option>
          </select>
        </label>
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Lote</span>
          <select id="analysis-lot" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" required>
            <option value="">Selecciona un lote</option>
          </select>
        </label>
      </div>
      <div class="flex items-center gap-2 text-sm">
        <input type="checkbox" id="analysis-create-lot" class="h-4 w-4" />
        <label for="analysis-create-lot" class="text-gray-700 dark:text-gray-200">Crear nuevo lote</label>
      </div>
      <div id="polygon-coordinates-box"
           class="hidden rounded-md border border-emerald-200 dark:border-emerald-800 bg-emerald-50 dark:bg-emerald-950/30 px-3 py-2 space-y-1">
        <div class="flex items-center justify-between text-xs">
          <span class="font-semibold text-emerald-700 dark:text-emerald-400">
            Coordenadas del polígono activo
          </span>
          <span id="polygon-area-preview"
                class="font-mono text-emerald-700 dark:text-emerald-400"></span>
        </div>
        <details>
          <summary class="cursor-pointer text-xs text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200">
            Ver GeoJSON
          </summary>
          <pre id="polygon-geojson-preview"
               class="mt-1 max-h-28 overflow-y-auto whitespace-pre-wrap break-all text-[10px] text-gray-600 dark:text-gray-300"></pre>
        </details>
      </div>
      <div id="analysis-new-lot-fields" class="grid gap-4 md:grid-cols-2 hidden">
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Nombre del lote</span>
          <input id="analysis-lot-name" type="text" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" placeholder="Ej: Lote 1" />
        </label>
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Area (ha)</span>
          <input id="analysis-lot-area" type="number" step="0.01" min="0" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" placeholder="Ej: 2.5" />
        </label>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Fecha de analisis</span>
          <input id="analysis-date" type="date" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" />
        </label>
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Proteina (%)</span>
          <input id="analysis-protein" type="number" step="0.01" min="0" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" required />
        </label>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Energia</span>
          <input id="analysis-energy" type="number" step="0.01" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" required />
        </label>
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Descanso</span>
          <input id="analysis-rest" type="number" step="0.01" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" required />
        </label>
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Dias de descanso</span>
          <input id="analysis-rest-days" type="number" step="1" min="0" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" required />
        </label>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Aforo</span>
          <input id="analysis-yield" type="number" step="0.01" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" required />
        </label>
        <label class="flex flex-col text-sm gap-1">
          <span class="font-semibold text-gray-800 dark:text-gray-100">Ciclo de pastoreo (mes)</span>
          <input id="analysis-month" type="number" min="1" max="12" step="1" class="px-2 py-2 border rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800" required />
        </label>
      </div>
      <div class="flex justify-end gap-3 pt-2 border-t border-gray-200 dark:border-gray-700">
        <button type="button" id="foliar-modal-cancel" class="{{ base_button_classes }}">Cancelar</button>
        <button type="submit" id="foliar-modal-submit" class="{{ base_button_classes }} {{ button_bg_color }} text-white {{ focus_ring_color }}">Guardar analisis</button>
      </div>
    </form>
  </div>
</div>

<!-- Farm Picker Modal -->
