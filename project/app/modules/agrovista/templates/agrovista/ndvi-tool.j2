    function renderFarmOptions(selectedId){
      if(!el.analysisFarmSelect){
        return;
      }
      const options = ["<option value=\"\">Selecciona una finca</option>"];
      for(const farm of foliarState.farms){
        if(!farm){ continue; }
        const value = farm.id;
        const name = farm.name || `Finca ${farm.id}`;
        const selected = selectedId && Number(selectedId) === Number(value) ? " selected" : "";
        options.push(`<option value="${value}"${selected}>${name}</option>`);
      }
      el.analysisFarmSelect.innerHTML = options.join("");
    }

    function renderLotOptions(farmId, selectedId){
      if(!el.analysisLotSelect){
        return;
      }
      const rows = foliarState.lots.filter(lot => {
        if(!farmId){
          return true;
        }
        return Number(lot.farm_id) === Number(farmId);
      });
      const options = ["<option value=\"\">Selecciona un lote</option>"];
      for(const lot of rows){
        if(!lot){ continue; }
        const value = lot.id;
        const label = lot.name || `Lote ${lot.id}`;
        const selected = selectedId && Number(selectedId) === Number(value) ? " selected" : "";
        options.push(`<option value="${value}"${selected}>${label}</option>`);
      }
      el.analysisLotSelect.innerHTML = options.join("");
    }

    function buildFarmMap(){
      const map = new Map();
      for(const farm of foliarState.farms){
        if(farm && farm.id != null){
          map.set(Number(farm.id), farm.name || `Finca ${farm.id}`);
        }
      }
      return map;
    }

    function getFarmNameById(farmId){
      if(!farmId){
        return null;
      }
      const farm = foliarState.farms.find(item => Number(item?.id) === Number(farmId));
      return farm ? (farm.name || `Finca ${farm.id}`) : null;
    }

    function renderCompareLotOptions(){
      if(!el.compareLotSelect){
        return;
      }
      const farmMap = buildFarmMap();
      const options = ["<option value=\"\">Selecciona un lote guardado</option>"];
      for(const lot of foliarState.lots){
        if(!lot){ continue; }
        const farmName = farmMap.get(Number(lot.farm_id)) || "Finca";
        const label = `${farmName} · ${lot.name || `Lote ${lot.id}`}`;
        options.push(`<option value=\"${lot.id}\">${label}</option>`);
      }
      el.compareLotSelect.innerHTML = options.join("");
      renderCompareAnalysisOptions();
    }

    function getCommonAnalysesForLot(lotId){
      if(!lotId || !Array.isArray(commonAnalyses)){
        return [];
      }
      return commonAnalyses
        .filter(item => item && Number(item.lot_id) === Number(lotId))
        .slice()
        .sort((a, b) => {
          const stampA = Date.parse(a?.date || a?.created_at || "");
          const stampB = Date.parse(b?.date || b?.created_at || "");
          return (Number.isFinite(stampB) ? stampB : 0) - (Number.isFinite(stampA) ? stampA : 0);
        });
    }

    function renderCompareAnalysisOptions(){
      if(!el.compareAnalysisSelect){
        updateComparisonButtonState();
        return;
      }
      const lotIdRaw = el.compareLotSelect ? el.compareLotSelect.value : "";
      if(!lotIdRaw){
        el.compareAnalysisSelect.innerHTML = '<option value="">Selecciona primero un lote</option>';
        el.compareAnalysisSelect.disabled = true;
        updateComparisonButtonState();
        return;
      }
      const items = getCommonAnalysesForLot(lotIdRaw);
      if(!items.length){
        el.compareAnalysisSelect.innerHTML = '<option value="">Sin análisis foliares registrados</option>';
        el.compareAnalysisSelect.disabled = true;
        updateComparisonButtonState();
        return;
      }
      const options = items.map((item, idx) => {
        const date = item?.date || item?.created_at || "";
        const suffix = idx === 0 ? " (más reciente)" : "";
        return `<option value="${item.id}"${idx === 0 ? " selected" : ""}>Análisis del ${date}${suffix}</option>`;
      });
      el.compareAnalysisSelect.innerHTML = options.join("");
      el.compareAnalysisSelect.disabled = false;
      updateComparisonButtonState();
    }

    function renderCompareDrawnLots(){
      const entries = Array.from(lotState.values());
      if(el.compareLotASelect){
        const opts = ["<option value=\"\">Selecciona Lote A</option>"];
        entries.forEach(entry => {
          const linkedName = entry.linkedLotName ? ` · ${entry.linkedLotName}` : "";
          const suffix = entry.linkedLotId ? "" : " (sin guardar)";
          const label = `${entry.name}${linkedName}${suffix}`;
          opts.push(`<option value=\"${entry.id}\">${label}</option>`);
        });
        el.compareLotASelect.innerHTML = opts.join("");
      }
      if(el.compareLotBSelect){
        const opts = ["<option value=\"\">Selecciona Lote B</option>"];
        entries.forEach(entry => {
          const linkedName = entry.linkedLotName ? ` · ${entry.linkedLotName}` : "";
          const suffix = entry.linkedLotId ? "" : " (sin guardar)";
          const label = `${entry.name}${linkedName}${suffix}`;
          opts.push(`<option value=\"${entry.id}\">${label}</option>`);
        });
        el.compareLotBSelect.innerHTML = opts.join("");
      }
      updateComparisonButtonState();
    }

    function renderObjectiveOptions(){
      if(!el.compareObjectiveSelect){
        return;
      }
      const options = ["<option value=\"\">Selecciona un objetivo</option>"];
      if(secondaryObjectives.length){
        options.push('<optgroup label="Objetivos secundarios">');
        secondaryObjectives.forEach(obj => {
          const cropName = obj?.analysis_crop?.name || `Objetivo ${obj?.id}`;
          const label = `${cropName} · Secundario #${obj?.id ?? ""}`.trim();
          options.push(`<option value="secondary:${obj?.id}">${label}</option>`);
        });
        options.push("</optgroup>");
      }
      if(cropObjectives.length){
        options.push('<optgroup label="Objetivos de cultivo">');
        cropObjectives.forEach(obj => {
          const cropName = obj?.crop_name || `Cultivo ${obj?.crop_id ?? ""}`;
          const target = typeof obj?.target_value === "number" ? ` · Target ${obj.target_value}` : "";
          const label = `Objetivo ${cropName}${target}`.trim();
          options.push(`<option value="crop:${obj?.id}">${label}</option>`);
        });
        options.push("</optgroup>");
      }
      el.compareObjectiveSelect.innerHTML = options.join("");
