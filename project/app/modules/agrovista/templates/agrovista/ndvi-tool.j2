              area_ha: layerB ? computeAreaHaForLayer(layerB) : null,
              linked_lot_id: Number(entryB.linkedLotId),
              linked_common_analysis_id: Number(commonId),
              linked_lot_name: entryB.linkedLotName || "",
            };
          }
          // Build URL query params for reliable navigation (primary method)
          const params = new URLSearchParams();
          params.set("mode", mode);

          if (mode === "lot_vs_objective") {
            params.set("lot_id", String(payload.lot_id));
            params.set("common_analysis_id", String(payload.common_analysis_id));
            params.set("objective_id", String(payload.objective.id));
            params.set("objective_type", payload.objective.type || "crop");
            params.set("objective_label", payload.objective.label || "");
            if (payload.lot_label) params.set("lot_label", payload.lot_label);
          } else {
            params.set("lot_a_id", String(payload.lot_a.id));
            params.set("lot_a_name", payload.lot_a.name || "");
            params.set("lot_a_area_ha", payload.lot_a.area_ha ? String(payload.lot_a.area_ha) : "");
            if (payload.lot_a.linked_lot_id) params.set("lot_a_linked_lot_id", String(payload.lot_a.linked_lot_id));
            if (payload.lot_a.linked_common_analysis_id) params.set("lot_a_linked_common_analysis_id", String(payload.lot_a.linked_common_analysis_id));
            params.set("lot_b_id", String(payload.lot_b.id));
            params.set("lot_b_name", payload.lot_b.name || "");
            params.set("lot_b_area_ha", payload.lot_b.area_ha ? String(payload.lot_b.area_ha) : "");
            params.set("linked_lot_id", String(payload.lot_b.linked_lot_id));
            params.set("linked_common_analysis_id", String(payload.lot_b.linked_common_analysis_id));
            if (payload.lot_b.linked_lot_name) params.set("linked_lot_name", payload.lot_b.linked_lot_name);
            // Stats complejos van solo por sessionStorage como respaldo
            const token = `cmp_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
            sessionStorage.setItem(`agrovista_comparison_${token}`, JSON.stringify(payload));
            params.set("token", token);
          }

          // Keep sessionStorage as backup for complex data (lot_vs_lot area_stats)
          if (mode === "lot_vs_objective") {
            const token = `cmp_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
            sessionStorage.setItem(`agrovista_comparison_${token}`, JSON.stringify(payload));
            params.set("token", token);
          }

          window.location.href = `${compareUrl}?${params.toString()}`;
        }catch(err){
          const message = err?.message || "Error al preparar la comparación.";
          isGeneratingComparison = false;
          el.goToComparisonBtn.textContent = compareButtonLabel || "Ver comparación nutricional";
          el.goToComparisonBtn.removeAttribute("aria-busy");
