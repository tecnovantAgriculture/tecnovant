    /* ---------- Upload ---------- */
    function getCsrfToken(){
      const value = `; ${document.cookie}`;
      const parts = value.split('; csrf_access_token=');
      if(parts.length === 2) return parts.pop().split(';').shift();
      return '';
    }
    async function uploadFile(file){
      const fd = new FormData(); fd.append("file", file);
      const csrf = getCsrfToken();
      const res = await fetch(ENDPOINTS.upload, {
        method: "POST",
        credentials: "include",
        headers: { "X-CSRF-TOKEN": csrf || "" },
        body: fd,
      });
      if(!res.ok){
        let msg = "Upload error";
        try{ msg = await res.text(); } catch {}
        throw new Error(msg);
      }
      return res.json();
    }
    function applyMeta(meta){
      imageMeta = (meta && typeof meta === "object") ? { ...meta } : null;
      imageId = imageMeta ? (imageMeta.id || null) : null;
      const widthPreview  = imageMeta && typeof imageMeta.width_preview === "number" ? imageMeta.width_preview : null;
      const heightPreview = imageMeta && typeof imageMeta.height_preview === "number" ? imageMeta.height_preview : null;
      const widthFull  = imageMeta && typeof imageMeta.width_full === "number" ? imageMeta.width_full : null;
      const heightFull = imageMeta && typeof imageMeta.height_full === "number" ? imageMeta.height_full : null;
      imageMeta.width_preview = widthPreview;
      imageMeta.height_preview = heightPreview;
      imageMeta.width_full = widthFull;
      imageMeta.height_full = heightFull;
      imageWidth  = (widthPreview && isFinite(widthPreview)) ? widthPreview : (imageMeta && typeof imageMeta.width === "number" ? imageMeta.width : 0);
      imageHeight = (heightPreview && isFinite(heightPreview)) ? heightPreview : (imageMeta && typeof imageMeta.height === "number" ? imageMeta.height : 0);
      mppX = imageMeta && typeof imageMeta.mppX === "number" && isFinite(imageMeta.mppX) ? imageMeta.mppX : null;
      mppY = imageMeta && typeof imageMeta.mppY === "number" && isFinite(imageMeta.mppY) ? imageMeta.mppY : null;
      imageMeta.preview_url = imageMeta && typeof imageMeta.preview_url === "string" ? imageMeta.preview_url : null;
      imageMeta.cache_npz_key = imageMeta && typeof imageMeta.cache_npz_key === "string" ? imageMeta.cache_npz_key : null;
      imageMeta.media_asset_id = imageMeta && typeof imageMeta.asset_id === "number" ? imageMeta.asset_id : null;
      imageMeta.source = imageMeta && imageMeta.source ? String(imageMeta.source) : "agrovista";
      imageMeta.previews = imageMeta && typeof imageMeta.previews === "object" && imageMeta.previews !== null ? { ...imageMeta.previews } : {};
      if(!imageMeta.previews.rgb && imageMeta.preview_url){ imageMeta.previews.rgb = imageMeta.preview_url; }
      if(!imageMeta.previews[currentPreviewKey]){
        const _firstAvail = Object.keys(imageMeta.previews).find(k => !!imageMeta.previews[k]);
        currentPreviewKey = _firstAvail || "rgb";
        if(el.previewSelector){ el.previewSelector.value = currentPreviewKey; }
      }
      imgBounds = [[0,0], [imageHeight, imageWidth]];
      if(imageMeta){
        areaStatsCache.clear();
        const vars = getVariablesSource(imageMeta);
        imageMeta.variables = vars;
        imageMeta.processed = !!imageMeta.processed;
        imageMeta.ndvi_stamp = imageMeta.ndvi_stamp || meta?.ndvi_stamp || Date.now();
        if(!imageMeta.method){ imageMeta.method = "ndvi_approx"; }
        if(!imageMeta.visible_method){ imageMeta.visible_method = "combined"; }
        imageMeta.has_nir = false;
        imageMeta.nutrients = Array.isArray(meta?.nutrients)
          ? meta.nutrients.map(item => ({ ...item }))
          : [];
      }

      refreshMethodLabel();

      resetVariableValues();
      if(imageMeta){
        const vars = getVariablesSource(imageMeta);
        VARIABLE_KEYS.forEach(key => {
          setVariableValue(key, vars[key]);
        });
        renderNutrients(imageMeta.nutrients);
        setPrimaryMetrics(imageMeta);
      }

      setProteinBox(null, null, imageMeta && imageMeta.processed ? "Selecciona un polígono" : "Calcula NDVI dibujando un polígono");
      setStatus(imageMeta && imageMeta.processed ? "NDVI listo." : "Vista previa cargada. Dibuja un polígono para procesar NDVI.");
    }
    async function handleFileChange(ev){
      const file = ev.target.files?.[0];
      if(!file) return;
      try{
        setStatus("Procesando...");
        if(file && file.name){
          updateAssetLabels(file.name);
        }
        const meta = await uploadFile(file);
        applyMeta(meta);
        if(overlay) map.removeLayer(overlay);
        overlay = L.imageOverlay(getOverlayUrl(), imgBounds).addTo(map);
        fitImage();
        if(el.previewSelector){
          const availableKeys = imageMeta && imageMeta.previews ? Object.keys(imageMeta.previews).filter(k => !!imageMeta.previews[k]) : [];
          const options = el.previewSelector.querySelectorAll('option');
          options.forEach(opt => {
            opt.disabled = availableKeys.length > 0 ? !availableKeys.includes(opt.value) : false;
          });
          if(availableKeys.length > 0 && !availableKeys.includes(currentPreviewKey)){
            currentPreviewKey = availableKeys.includes("rgb") ? "rgb" : availableKeys[0];
            el.previewSelector.value = currentPreviewKey;
          }
        }
        setStatus(mppX != null ? `Escala automática: ~${mppX} m/px` : "Escala en píxeles (mpp no disponible)");
        await restoreDraftPolygons();
        drawnItems.eachLayer(layer => { if(layer instanceof L.Polygon || layer instanceof L.Rectangle){ updateAreaForLayer(layer); } });
      }catch(e){
        setStatus("Error al procesar el archivo");
      }
    }

    // Picker callback usa metadata directa desde Media (sin re-subir)
    MP.setOnPick(async (payload)=>{
      try{
        setStatus("Procesando...");
        let meta = null;
        if(payload && payload.meta){
          meta = payload.meta;
        }else if(payload && payload.file){
          meta = await uploadFile(payload.file);
        }else{
          throw new Error("Selección inválida");
        }
        const assetName = payload?.asset?.original_name || payload?.asset?.name || payload?.meta?.filename || payload?.file?.name;
        if(assetName){
          updateAssetLabels(assetName);
        }
        applyMeta(meta);
        if(overlay) map.removeLayer(overlay);
        overlay = L.imageOverlay(getOverlayUrl(), imgBounds).addTo(map);
        fitImage();
        if(el.previewSelector){
          const availableKeys = imageMeta && imageMeta.previews ? Object.keys(imageMeta.previews).filter(k => !!imageMeta.previews[k]) : [];
          const options = el.previewSelector.querySelectorAll('option');
          options.forEach(opt => {
            opt.disabled = availableKeys.length > 0 ? !availableKeys.includes(opt.value) : false;
          });
          if(availableKeys.length > 0 && !availableKeys.includes(currentPreviewKey)){
            currentPreviewKey = availableKeys.includes("rgb") ? "rgb" : availableKeys[0];
            el.previewSelector.value = currentPreviewKey;
          }
        }
        setStatus(mppX != null ? `Escala automática: ~${mppX} m/px` : "Escala en píxeles (mpp no disponible)");
        await restoreDraftPolygons();
        drawnItems.eachLayer(layer => { if(layer instanceof L.Polygon || layer instanceof L.Rectangle){ updateAreaForLayer(layer); } });
      }catch(e){ setStatus("Error al procesar el archivo"); }
    });

    /* ---------- Draw events ---------- */
    async function fetchAreaStats(verts, coordsFullRes){
      const csrf = getCsrfToken();
      const res = await fetch(ENDPOINTS.protein, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-TOKEN": csrf || "",
        },
        body: JSON.stringify({
          id: imageId,
          media_asset_id: imageMeta && imageMeta.media_asset_id ? imageMeta.media_asset_id : null,
          source: imageMeta && imageMeta.source ? imageMeta.source : "agrovista",
          visible_method: imageMeta && imageMeta.visible_method ? imageMeta.visible_method : null,
          width_preview: imageMeta && imageMeta.width_preview ? imageMeta.width_preview : imageWidth,
          height_preview: imageMeta && imageMeta.height_preview ? imageMeta.height_preview : imageHeight,
          width_full: imageMeta && imageMeta.width_full ? imageMeta.width_full : null,
          height_full: imageMeta && imageMeta.height_full ? imageMeta.height_full : null,
          scale_x: imageMeta && imageMeta.scale_x ? imageMeta.scale_x : null,
          scale_y: imageMeta && imageMeta.scale_y ? imageMeta.scale_y : null,
          coords_full_res: !!coordsFullRes,
          vertices: verts,
        }),
      });
      let data = {};
      try{ data = await res.json(); }catch{}
      if(!res.ok){ throw new Error(data?.description || "Área inválida"); }
      return data;
    }
    function wireArea(layer){
      layer.on("click", () => {
        setActiveLayer(layer);
        updateStatsForLayer(layer);
      });
    }

    let restoringDraftPolygons = false;
    function polygonDraftKey(){
      const id = imageId || imageMeta?.asset_id || imageMeta?.media_asset_id || imageMeta?.filename || "sin-imagen";
      return `agrovista:poligonos:${id}`;
    }
    function serializeDraftPolygons(){
      const items = [];
      drawnItems.eachLayer(layer => {
        if(!(layer instanceof L.Polygon || layer instanceof L.Rectangle)){ return; }
        try{
          const entry = ensureLotEntry(layer);
          items.push({
            name: entry?.name || null,
            geojson: layer.toGeoJSON(),
          });
        }catch(err){
          console.warn("No se pudo serializar polígono", err);
        }
      });
      return items;
    }
    function saveDraftPolygons(){
      if(restoringDraftPolygons || !imageMeta){ return; }
      try{
        const items = serializeDraftPolygons();
        const key = polygonDraftKey();
        if(items.length){
          localStorage.setItem(key, JSON.stringify({version:1, savedAt:new Date().toISOString(), items}));
        }else{
          localStorage.removeItem(key);
        }
      }catch(err){
        console.warn("No se pudieron guardar los polígonos locales", err);
      }
    }
    function clearDraftPolygons(){
      if(!imageMeta){ return; }
      try{ localStorage.removeItem(polygonDraftKey()); }catch(err){}
    }
    async function restoreDraftPolygons(){
      if(!imageMeta){ return; }
      let payload = null;
      try{
        const raw = localStorage.getItem(polygonDraftKey());
        payload = raw ? JSON.parse(raw) : null;
      }catch(err){
        payload = null;
      }
      drawnItems.clearLayers();
      areaStatsCache.clear();
      lotState.clear();
      lotCounter = 0;
      activeLayerId = null;
      renderLotsList();
      if(!payload || !Array.isArray(payload.items) || !payload.items.length){
        return;
      }
      restoringDraftPolygons = true;
      try{
        for(const item of payload.items){
          const layer = L.geoJSON(item.geojson).getLayers()[0];
          if(!layer){ continue; }
          if(typeof layer.setStyle === "function"){
            layer.setStyle(polygonStyleNormal);
          }
          drawnItems.addLayer(layer);
          const entry = ensureLotEntry(layer);
          if(entry && item.name){ entry.name = item.name; }
          wireArea(layer);
          await updateStatsForLayer(layer);
        }
        const firstLayer = drawnItems.getLayers()[0];
        if(firstLayer){ setActiveLayer(firstLayer); }
        renderLotsList();
        toggleKmzButton();
        updateSaveButtonState();
        setStatus("Polígonos restaurados del borrador local.");
      }finally{
        restoringDraftPolygons = false;
      }
    }

    async function updateStatsForLayer(layer){
      updateAreaForLayer(layer);
      if(!imageId){ return; }
      const layerKey = getLayerKey(layer);
      if(layerKey !== null && areaStatsCache.has(layerKey)){
        const cached = areaStatsCache.get(layerKey);
        applyAreaStats(cached);
        const entry = ensureLotEntry(layer);
        if(entry){
          entry.stats = getPrimaryStatsFromData(cached);
          entry.areaStats = cloneAreaStats(cached);
        }
        renderLotsList();
        if(el.analysisCreateLotToggle && el.analysisCreateLotToggle.checked){
          updateLotAreaInput(false);
        }
        setStatus("Resultados recuperados del caché local.");
        return;
      }
      const verts = getRasterVertices(layer);
      if(!verts){
        setProteinBox(null, null, "Selecciona un polígono");
        resetVariableValues();
        return;
      }
      const token = ++statsRequestToken;
      setProteinBox(null, null, "Calculando…");
      setStatus("Procesando área seleccionada…");
      // Mark entry as computing
      const entry = ensureLotEntry(layer);
      if(entry){
        entry.computing = true;
        renderLotsList();
      }
      try{
        const data = await fetchAreaStats(verts, true);
        if(token !== statsRequestToken) return;
        applyAreaStats(data);
        if(layerKey !== null){
          areaStatsCache.set(layerKey, data);
        }
        const entry = ensureLotEntry(layer);
        if(entry){
          entry.stats = getPrimaryStatsFromData(data);
          entry.areaStats = cloneAreaStats(data);
          entry.computing = false;
        }
        renderLotsList();
        if(el.analysisCreateLotToggle && el.analysisCreateLotToggle.checked){
          updateLotAreaInput(false);
        }
        if(data && data.ndvi_ready){
          imageMeta.processed = true;
          if(typeof data.ndvi_stamp !== "undefined" && data.ndvi_stamp !== null){
            updateOverlayStamp(data.ndvi_stamp);
          }
        }
        setStatus("Área procesada.");
      }catch(err){
        if(token !== statsRequestToken) return;
        if(layerKey !== null){
          const errEntry = lotState.get(layerKey);
          if(errEntry){ errEntry.computing = false; }
        }
        renderLotsList();
        if(imageMeta){
          const vars = getVariablesSource(imageMeta);
          VARIABLE_KEYS.forEach(key => {
            setVariableValue(key, vars[key]);
          });
        } else {
          resetVariableValues();
        }
        setProteinBox(null, null, (err && err.message) || "Error al calcular la proteína");
        setStatus("Error al procesar el área.");
      }
    }

    map.on(L.Draw.Event.CREATED, async (e)=>{
      const { layer, layerType } = e;
      drawnItems.addLayer(layer);

      if(layerType === "polygon" || layerType === "rectangle"){
        ensureLotEntry(layer);
        wireArea(layer);
        setActiveLayer(layer);
        await updateStatsForLayer(layer);
        toggleKmzButton();
        updateSaveButtonState(); // Actualizar estado del botón de guardar
        saveDraftPolygons();
      }
    });

    map.on(L.Draw.Event.EDITED, (e)=>{
      e.layers.eachLayer(layer => {
        const k = getLayerKey(layer);
        if(k !== null){ areaStatsCache.delete(k); }
        if(layer instanceof L.Polygon || layer instanceof L.Rectangle){
          updateStatsForLayer(layer);
        }
      });
      updateSaveButtonState(); // Actualizar estado del botón tras editar
      saveDraftPolygons();
    });
    map.on(L.Draw.Event.DELETED, ()=>{
      resetMapState(false);
      updateSaveButtonState(); // Actualizar estado del botón tras borrar polígono
      saveDraftPolygons();
    });

    /* ---------- Fullscreen ---------- */
    function enterFullscreen(){
      el.workzone.requestFullscreen().catch(()=>{});
      setTimeout(() => { map.invalidateSize(); scheduleRulersRedraw(); }, 80);
    }
    function exitFullscreen(){ document.exitFullscreen(); }
    function onFsChange(){
      const isFs = document.fullscreenElement === el.workzone;
      el.btnFsIn.classList.toggle("hidden", isFs);
      el.btnFsOut.classList.toggle("hidden", !isFs);
      setTimeout(() => { map.invalidateSize(); scheduleRulersRedraw(); }, 80);
