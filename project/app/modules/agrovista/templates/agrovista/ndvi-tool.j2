    function updateCompareMode(){
      if(!el.compareLotObjective || !el.compareLotLot){
        return;
      }
      const mode = getSelectedCompareMode();
      const isObjective = mode === "lot_vs_objective";
      el.compareLotObjective.classList.toggle("hidden", !isObjective);
      el.compareLotLot.classList.toggle("hidden", isObjective);
      updateComparisonButtonState();
    }

    function parseObjectiveValue(value){
      if(!value){
        return { type: null, id: null };
      }
      const parts = String(value).split(":");
      if(parts.length === 2){
        return { type: parts[0], id: Number(parts[1]) };
      }
      return { type: "crop", id: Number(value) };
    }

    function getLatestCommonAnalysisId(lotId){
      if(!lotId || !Array.isArray(commonAnalyses)){
        return null;
      }
      let latestId = null;
      let latestStamp = -1;
      commonAnalyses.forEach(item => {
        if(!item || Number(item?.lot_id) !== Number(lotId)){
          return;
        }
        const rawDate = item?.date || item?.created_at || "";
        const stamp = Date.parse(rawDate);
        const resolved = Number.isFinite(stamp) ? stamp : 0;
        if(latestId === null || resolved > latestStamp){
          latestId = item?.id ?? null;
          latestStamp = resolved;
        }
      });
      return latestId;
    }

    function getSelectedLotLabel(lotId){
      if(el.compareLotSelect){
        const option = el.compareLotSelect.options[el.compareLotSelect.selectedIndex];
        if(option && option.textContent){
          return option.textContent.trim();
        }
      }
      return lotId ? `Lote ${lotId}` : "Lote";
    }

    function getLotEntryById(entryId){
      if(!entryId){
        return null;
      }
      return lotState.get(Number(entryId)) || null;
    }

    function getEntryLabel(entry){
      if(!entry){
        return "Lote";
      }
      const linked = entry.linkedLotName ? ` · ${entry.linkedLotName}` : "";
      return `${entry.name}${linked}`.trim();
    }

    function computeAreaHaForLayer(layer){
      if(!layer){
        return null;
      }
      const verts = getRasterVertices(layer) || extractVertices(layer);
      if(!Array.isArray(verts) || verts.length < 3){
        return null;
      }
      if(mppX == null){
        return null;
      }
      const _mppY = (mppY != null) ? mppY : mppX;
      const px2 = polygonAreaVerticesPx2(verts);
      const m2 = px2 * mppX * _mppY;
      const ha = m2 / 10000;
      return Number.isFinite(ha) ? ha : null;
    }

    function updateLotAreaInput(force = false){
      if(!el.analysisLotAreaInput){
        return;
      }
      if(!force && el.analysisLotAreaInput.dataset.manual === "1" && el.analysisLotAreaInput.value){
        return;
      }
      const layer = activeLayerId !== null ? drawnItems.getLayer(activeLayerId) : null;
      if(!layer){
        return;
      }
      const ha = computeAreaHaForLayer(layer);
      if(!Number.isFinite(ha) || ha <= 0){
        return;
      }
      el.analysisLotAreaInput.value = ha.toFixed(2);
    }

    function getSelectedCompareMode(){
      if(!el.compareModeInputs){
        return "lot_vs_objective";
      }
      const input = Array.from(el.compareModeInputs).find(node => node.checked);
      return input ? input.value : "lot_vs_objective";
    }

    function updateComparisonButtonState(){
      if(!el.goToComparisonBtn){
        return;
      }
      if(isGeneratingComparison){
        el.goToComparisonBtn.disabled = true;
        return;
      }
      const mode = getSelectedCompareMode();
      let ready = false;
      if(mode === "lot_vs_objective"){
        const lot = el.compareLotSelect ? el.compareLotSelect.value : "";
        const objective = el.compareObjectiveSelect ? el.compareObjectiveSelect.value : "";
        const analysisOk = !el.compareAnalysisSelect || !!el.compareAnalysisSelect.value;
        ready = !!(lot && objective && analysisOk);
      }else{
        const lotA = el.compareLotASelect ? el.compareLotASelect.value : "";
        const lotB = el.compareLotBSelect ? el.compareLotBSelect.value : "";
        const entryB = getLotEntryById(lotB);
        const hasLinkedLot = entryB && Number.isFinite(Number(entryB.linkedLotId));
        const hasCommon = entryB && (entryB.linkedCommonAnalysisId || getLatestCommonAnalysisId(entryB.linkedLotId));
        ready = !!(lotA && lotB && lotA !== lotB && hasLinkedLot && hasCommon);
      }
      el.goToComparisonBtn.disabled = !ready;
      if(ready){
        setCompareHint("Comparación lista para revisar los resultados nutricionales.");
        return;
      }
      if(mode === "lot_vs_lot"){
        const lotA = el.compareLotASelect ? el.compareLotASelect.value : "";
        const lotB = el.compareLotBSelect ? el.compareLotBSelect.value : "";
        if(!lotA || !lotB){
          setCompareHint("Selecciona los dos lotes dibujados para generar la comparación.");
          return;
        }
        if(lotA === lotB){
          setCompareHint("Selecciona dos lotes diferentes.", true);
          return;
        }
        const entryB = getLotEntryById(lotB);
        if(!entryB || !entryB.linkedLotId){
          setCompareHint("Guarda el análisis foliar del Lote B antes de generar el informe.", true);
          return;
        }
        if(!entryB.linkedCommonAnalysisId && !getLatestCommonAnalysisId(entryB.linkedLotId)){
          setCompareHint("El Lote B no tiene un análisis común registrado.", true);
          return;
        }
        const entryA = getLotEntryById(lotA);
        if(entryA && (!entryA.areaStats || !Array.isArray(entryA.areaStats.nutrients) || entryA.areaStats.nutrients.length === 0)){
          setCompareHint("Haz clic en el Lote A para calcular sus datos antes de comparar.");
          return;
        }
        setCompareHint("Selecciona ambos lotes para comparar y generar el informe.");
        return;
      }
      const lotValue = el.compareLotSelect ? el.compareLotSelect.value : "";
      if(lotValue && el.compareAnalysisSelect && el.compareAnalysisSelect.disabled){
        setCompareHint("El lote seleccionado no tiene análisis foliares registrados.", true);
        return;
      }
      if(lotValue && el.compareAnalysisSelect && !el.compareAnalysisSelect.value){
        setCompareHint("Selecciona el análisis del lote que quieres comparar.");
        return;
      }
      const objectiveValue = el.compareObjectiveSelect ? el.compareObjectiveSelect.value : "";
      if(objectiveValue || lotValue){
        setCompareHint("Selecciona el lote, su análisis y el objetivo ideal para generar la comparación.");
        return;
      }
      setCompareHint("Cuando tengas al menos un lote con análisis guardado podrás lanzar la comparación y ver la tabla de Ley de Mínimos.");
    }

    async function ensureAreaStatsForEntry(entry){
      if(!entry){
        return null;
      }
      if(entry.areaStats && Array.isArray(entry.areaStats.nutrients) && entry.areaStats.nutrients.length){
        return entry.areaStats;
      }
      const layer = drawnItems.getLayer(entry.id);
      if(!layer){
        return null;
      }
      await updateStatsForLayer(layer);
      return entry.areaStats || null;
    }

