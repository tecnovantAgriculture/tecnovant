{% extends "base.j2" %}
{% set dashboard = true %}
{% set bg_color = "bg-transparent" %}
{% set rounded = "" %}
{% set shadow = "" %}
{% set padding = "" %}
{% set main_clases = "flex-grow overflow-y-auto p-0" %}
{% block extra_css %}
  {{ css_code|safe }}
  {{ super() }}
{% endblock %}

{% block extra_head %}
  {{ js_code|safe }}
  {{ super() }}
{% endblock %}

{% block content %}
<!-- Hidden metadata for PDF export -->
<span id="meta-username" class="hidden">{{ claims.get('full_name', 'Sistema') if claims else 'Sistema' }}</span>
<span id="meta-orgname" class="hidden">{{ context_client if context_client else '' }}</span>
<div class="min-h-screen bg-slate-50">
  <div id="comparison-content" class="mx-auto max-w-7xl px-4 py-6 lg:px-8 lg:py-8">
    <div id="comparison-error" class="hidden mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

    <nav class="mb-4 flex items-center text-xs text-gray-500" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1">
        <li>
          <a href="{{ url_for('core.dashboard') }}" class="hover:text-emerald-700">Inicio</a>
        </li>
        <li class="flex items-center">
          <span class="mx-1">/</span>
          <a href="{{ url_for('agrovista.hello') }}" class="hover:text-emerald-700">Análisis</a>
        </li>
        <li class="flex items-center">
          <span class="mx-1">/</span>
          <span class="font-medium text-gray-700">Comparación nutricional</span>
        </li>
      </ol>
    </nav>

    <header class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-xl font-semibold text-gray-900">Comparación nutricional</h1>
        <p class="mt-1 text-sm text-gray-600">
          Revisa las brechas nutricionales entre el lote analizado y su referencia
          (objetivo ideal o lote comparativo) y visualiza la tabla de Ley de Mínimos.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <span id="modeBadge" class="inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-800">
          Modo: --
        </span>
        <a href="{{ url_for('agrovista.hello') }}"
           class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-3 py-2 text-xs font-medium text-gray-700 shadow-sm hover:bg-gray-50">
          Volver al mapa
        </a>
      </div>
    </header>

    <section class="mb-6 grid gap-4 lg:grid-cols-12">
      <article class="lg:col-span-5 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
        <div class="mb-3 flex items-center justify-between gap-2">
          <h2 id="analysisCardTitle" class="text-sm font-semibold text-gray-800">Lote analizado</h2>
          <span id="analysisCardBadge" class="rounded-full bg-gray-100 px-2.5 py-0.5 text-[11px] font-medium uppercase tracking-wide text-gray-500">
            Lote
          </span>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <div class="rounded-xl bg-slate-100 p-2">
            <div id="analysisLotImageSlot" class="mb-2 flex h-24 items-center justify-center rounded-lg bg-slate-300 text-[11px] font-medium text-slate-700">
              Vista ortofoto lote
            </div>
            <dl class="space-y-1 text-xs text-gray-600">
              <div class="flex justify-between">
                <dt class="text-gray-500">Nombre</dt>
                <dd id="analysisLotName" class="font-medium text-gray-800">--</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Área</dt>
                <dd id="analysisLotArea" class="font-medium text-gray-800">--</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Cultivo</dt>
                <dd id="analysisLotCrop" class="font-medium text-gray-800">--</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Fecha análisis</dt>
                <dd id="analysisLotDate" class="font-medium text-gray-800">--</dd>
              </div>
            </dl>
          </div>

          <div class="space-y-2 rounded-xl bg-slate-50 p-3 text-xs">
            <h3 class="mb-1 text-[11px] font-semibold uppercase tracking-wide text-gray-600">
              Índices promedio (lote)
            </h3>
            <div class="grid grid-cols-3 gap-2 text-center">
              <div class="rounded-lg bg-white px-2 py-2 shadow-sm">
                <dt class="text-[11px] uppercase tracking-wide text-gray-500">NDVI</dt>
                <dd id="analysisNdvi" class="mt-1 text-base font-semibold text-gray-900">--</dd>
              </div>
              <div class="rounded-lg bg-white px-2 py-2 shadow-sm">
                <dt class="text-[11px] uppercase tracking-wide text-gray-500">VARI</dt>
                <dd id="analysisVari" class="mt-1 text-base font-semibold text-gray-900">--</dd>
              </div>
              <div class="rounded-lg bg-white px-2 py-2 shadow-sm">
                <dt class="text-[11px] uppercase tracking-wide text-gray-500">NBI</dt>
                <dd id="analysisNbi" class="mt-1 text-base font-semibold text-gray-900">--</dd>
              </div>
            </div>
            <p class="mt-1 text-[11px] text-gray-500">
              Valores calculados a partir de los polígonos seleccionados en la ortofoto.
            </p>
          </div>
        </div>
      </article>

      <article class="lg:col-span-5 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
        <div class="mb-3 flex items-center justify-between gap-2">
          <h2 id="referenceCardTitle" class="text-sm font-semibold text-gray-800">
            Referencia de comparación
          </h2>
          <span id="referenceCardBadge" class="rounded-full bg-indigo-50 px-2.5 py-0.5 text-[11px] font-medium uppercase tracking-wide text-indigo-700">
            --
          </span>
        </div>
        <div class="mb-3">
          <button id="changeReferenceBtn"
                  type="button"
                  class="inline-flex w-full items-center justify-center gap-1 rounded-lg border border-indigo-200 bg-indigo-50 px-3 py-1.5 text-xs font-medium text-indigo-700 shadow-sm hover:bg-indigo-100 dark:border-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-300 dark:hover:bg-indigo-900/50">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
            Cambiar referencia
          </button>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <div class="rounded-xl bg-slate-100 p-2">
            <div id="referenceImageSlot" class="mb-2 flex h-24 items-center justify-center rounded-lg bg-slate-300 text-[11px] font-medium text-slate-700">
              Vista de referencia
            </div>
            <dl class="space-y-1 text-xs text-gray-600">
              <div class="flex justify-between">
                <dt class="text-gray-500">Objetivo</dt>
                <dd id="referenceName" class="font-medium text-gray-800">--</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Fuente</dt>
                <dd id="referenceSource" class="font-medium text-gray-800">--</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Tipo</dt>
                <dd id="referenceType" class="font-medium text-gray-800">--</dd>
              </div>
            </dl>
          </div>

          <div class="space-y-2 rounded-xl bg-slate-50 p-3 text-xs">
            <h3 class="mb-1 text-[11px] font-semibold uppercase tracking-wide text-gray-600">
              Índices de referencia
            </h3>
            <div class="grid grid-cols-3 gap-2 text-center">
              <div class="rounded-lg bg-white px-2 py-2 shadow-sm">
                <dt class="text-[11px] uppercase tracking-wide text-gray-500">NDVI</dt>
                <dd id="referenceNdvi" class="mt-1 text-base font-semibold text-gray-900">--</dd>
              </div>
              <div class="rounded-lg bg-white px-2 py-2 shadow-sm">
                <dt class="text-[11px] uppercase tracking-wide text-gray-500">VARI</dt>
                <dd id="referenceVari" class="mt-1 text-base font-semibold text-gray-900">--</dd>
              </div>
              <div class="rounded-lg bg-white px-2 py-2 shadow-sm">
                <dt class="text-[11px] uppercase tracking-wide text-gray-500">NBI</dt>
                <dd id="referenceNbi" class="mt-1 text-base font-semibold text-gray-900">--</dd>
              </div>
            </div>
            <p class="mt-1 text-[11px] text-gray-500">
              Valores de referencia definidos para este objetivo de cultivo.
            </p>
          </div>
        </div>
      </article>

      <aside class="lg:col-span-2 flex flex-col gap-3 rounded-2xl border border-emerald-200 bg-emerald-50/60 p-4 shadow-sm">
        <h2 class="text-sm font-semibold text-emerald-900">Resumen de brechas</h2>
        <dl class="space-y-1 text-xs">
          <div class="flex justify-between">
            <dt class="text-emerald-900">Nutriente limitante principal</dt>
            <dd id="limitingNutrient" class="font-semibold text-red-600">--</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-emerald-900">Nutrientes en rango óptimo</dt>
            <dd id="optimalNutrients" class="text-emerald-800">--</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-emerald-900">Nutrientes en exceso</dt>
            <dd id="excessNutrients" class="text-orange-700">--</dd>
          </div>
        </dl>
        <p class="mt-2 text-[11px] text-emerald-900">
          La Ley de Mínimos se calcula con base en el nutriente más deficitario.
          Revisa la tabla detallada para ver los porcentajes de brecha por cada nutriente.
        </p>
      </aside>
    </section>

    <section class="mb-6 space-y-4">
      <article class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
        <h2 class="mb-3 text-sm font-semibold text-gray-800">Información del Cultivo (objetivo ideal)</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 text-xs">
            <thead class="bg-gray-50">
              <tr id="cropInfoHeader"></tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
              <tr id="cropInfoRow"></tr>
            </tbody>
          </table>
        </div>
      </article>

      <article class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
        <h2 class="mb-3 text-sm font-semibold text-gray-800">Información del Análisis</h2>
        <p id="analysisMeta" class="mb-3 text-xs text-gray-500">--</p>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 text-xs">
            <thead class="bg-gray-50">
              <tr id="analysisInfoHeader"></tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
              <tr id="analysisInfoRow"></tr>
            </tbody>
          </table>
        </div>
      </article>

      <article class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
        <h2 class="mb-3 text-sm font-semibold text-gray-800">CV por nutriente</h2>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 text-xs">
            <thead class="bg-gray-50">
              <tr id="cvInfoHeader"></tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
              <tr id="cvInfoRow"></tr>
            </tbody>
          </table>
        </div>
      </article>
    </section>

    <section class="mb-8 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
      <div class="mb-3 flex items-center justify-between gap-2">
        <h2 class="text-sm font-semibold text-gray-800">Tabla de Cálculos – Ley de Mínimos</h2>
        <span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-[11px] text-gray-600">
          Valores expresados en % respecto al objetivo
        </span>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-xs">
          <thead class="bg-gray-50">
            <tr id="lawTableHeader"></tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white" id="lawTableBody"></tbody>
        </table>
      </div>
      <p class="mt-3 text-[11px] text-gray-600">
        El nutriente limitante principal es aquel con mayor déficit porcentual negativo.
        La recomendación de formulación se calculará tomando como base dicho nutriente y
        ajustando el resto de aportes para mantener los rangos óptimos.
      </p>
    </section>

    <section class="mb-8 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-sm font-semibold text-gray-800">Balance de Minerales</h2>
        <span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-[11px] text-gray-600">
          Déficits convertidos a kg/ha según el aforo
        </span>
      </div>
      <div class="mb-3 grid grid-cols-4 divide-x divide-gray-200 overflow-hidden rounded-lg border border-gray-200">
        <div class="bg-gray-100 px-3 py-2 text-center">
          <div class="flex items-center justify-center gap-1.5">
            <dt class="text-[11px] uppercase tracking-wide text-gray-500">Proteína objetivo</dt>
            <label class="relative inline-flex cursor-pointer items-center" title="Editar proteína objetivo">
              <input type="checkbox" id="balanceProteinEditToggle" class="peer sr-only" />
              <div class="h-4 w-7 rounded-full bg-gray-300 transition-colors after:absolute after:start-0.5 after:top-0.5 after:h-3 after:w-3 after:rounded-full after:bg-white after:shadow after:transition-all after:content-[''] peer-checked:bg-emerald-500 peer-checked:after:translate-x-3"></div>
            </label>
          </div>
          <dd id="balanceProteinObj" class="mt-1 text-sm font-semibold text-gray-900">--</dd>
          <input id="balanceProteinObjInput"
                 type="number"
                 min="0"
                 step="0.01"
                 class="mx-auto mt-1 hidden w-24 rounded-lg border border-gray-300 px-2 py-1 text-center text-sm font-semibold text-gray-900 focus:border-emerald-500 focus:ring-emerald-500" />
        </div>
        <div class="bg-gray-100 px-3 py-2 text-center">
          <dt class="text-[11px] uppercase tracking-wide text-gray-500">Aforo objetivo</dt>
          <dd id="balanceAforoObj" class="mt-1 text-sm font-semibold text-gray-900">--</dd>
        </div>
        <div class="bg-gray-200 px-3 py-2 text-center">
          <dt class="text-[11px] uppercase tracking-wide text-gray-500">Proteína actual</dt>
          <dd id="balanceProteinAct" class="mt-1 text-sm font-semibold text-gray-900">--</dd>
        </div>
        <div class="bg-gray-200 px-3 py-2 text-center">
          <dt class="text-[11px] uppercase tracking-wide text-gray-500">Aforo actual</dt>
          <dd id="balanceAforoAct" class="mt-1 text-sm font-semibold text-gray-900">--</dd>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-xs">
          <thead class="bg-gray-50">
            <tr id="balanceTableHeader"></tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white" id="balanceTableBody"></tbody>
        </table>
      </div>
      <p class="mt-3 text-[11px] text-gray-600">
        Objetivo se expresa en kg/ha con el aforo objetivo y Actual con el
        aforo actual (macros: % × aforo × 100; micros: ppm × aforo ÷ 100).
        La Diferencia solo refleja déficits (excedentes se truncan a 0).
        El Grado de fórmula es la participación porcentual de cada déficit
        en el total requerido (columna Total), y Nano es la cantidad de
        producto de la línea nanotecnológica a aplicar según su
        concentración (N 16, P 11, K 19, resto 40).
      </p>
      <p id="balanceAforoFallbackNote" class="mt-1 hidden text-[11px] font-medium text-amber-700">
        Nota: no existe aforo actual; la fila Actual (kg/ha) se convirtió
        con el aforo objetivo.
      </p>
    </section>

    <section class="flex flex-wrap items-center justify-between gap-3 border-t border-gray-200 pt-4">
      <div class="text-[11px] text-gray-500">
        Revisa los resultados antes de generar el informe definitivo o guardar la formulación propuesta.
      </div>
      <div class="flex flex-wrap gap-2">
        <button id="exportPdfBtn"
                type="button"
                class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-3 py-2 text-xs font-medium text-gray-700 shadow-sm hover:bg-gray-50">
          Exportar PDF
        </button>
        <button id="previewReportBtn"
                type="button"
                class="inline-flex items-center rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-2 text-xs font-semibold text-emerald-700 shadow-sm hover:bg-emerald-100">
          Vista previa de recomendación
        </button>
        <button id="saveReportBtn"
                type="button"
                class="inline-flex items-center rounded-lg bg-emerald-600 px-4 py-2 text-xs font-semibold text-white shadow-sm hover:bg-emerald-700">
          Guardar como informe
        </button>
      </div>
    </section>
  </div>
</div>

<!-- Modal de vista previa de recomendación (C4) -->
<div id="previewModal" class="hidden fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center px-4 py-6">
  <div class="w-full max-w-3xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl max-h-[90vh] overflow-y-auto">
    <div class="flex items-start justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
      <div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Vista previa de recomendación</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Diagnóstico nutricional y balance de minerales antes de guardar.</p>
      </div>
      <button type="button" id="previewModalClose" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    <div class="px-5 py-4 space-y-4">
      <div class="border-b border-gray-200 pb-3 dark:border-gray-700">
        <nav class="flex gap-2" role="tablist" aria-label="Pestañas de vista previa">
          <button type="button"
                  id="previewTabDiagnosis"
                  role="tab"
                  class="inline-flex items-center rounded-lg border border-emerald-600 bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm">
            Diagnóstico
          </button>
          <button type="button"
                  id="previewTabBalance"
                  role="tab"
                  class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50">
            Balance
          </button>
        </nav>
      </div>
      <div id="previewPanelDiagnosis" class="space-y-4">
        <div id="previewDiagnosis" class="text-sm text-gray-700 dark:text-gray-300"></div>
        <div id="previewTable" class="overflow-x-auto"></div>
        <div id="previewProducts" class="text-sm text-gray-700 dark:text-gray-300"></div>
        <div id="previewCost" class="text-sm font-semibold text-emerald-700 dark:text-emerald-400"></div>
        <div id="previewWarnings" class="text-sm text-orange-600 dark:text-orange-400"></div>
      </div>
      <div id="previewPanelBalance" class="hidden space-y-4">
        <div id="previewBalanceMeta" class="grid grid-cols-4 divide-x divide-gray-200 overflow-hidden rounded-lg border border-gray-200 text-center"></div>
        <div id="previewBalanceTable" class="overflow-x-auto"></div>
      </div>
      <div class="flex justify-end gap-2 pt-2 border-t border-gray-200 dark:border-gray-700">
        <button type="button" id="previewModalCloseBtn"
                class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-4 py-2 text-xs font-medium text-gray-700 shadow-sm hover:bg-gray-50">
          Cerrar
        </button>
        <button type="button" id="previewSaveBtn"
                class="inline-flex items-center rounded-lg bg-emerald-600 px-4 py-2 text-xs font-semibold text-white shadow-sm hover:bg-emerald-700">
          Confirmar y guardar
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal de cambio de referencia (C-ref) -->
<div id="referenceModal" class="hidden fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center px-4 py-6">
  <div class="w-full max-w-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl max-h-[80vh] overflow-y-auto">
    <div class="flex items-start justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
      <div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Cambiar referencia de comparación</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Selecciona un objetivo ideal o secundario para reformular los resultados.</p>
      </div>
      <button type="button" id="referenceModalClose" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    <div class="px-5 py-4 space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1 text-gray-900 dark:text-gray-100">Objetivos de cultivo</label>
        <select id="refModalCropObjective"
                class="w-full border p-2 rounded dark:bg-gray-700 dark:border-gray-600 text-sm">
          <option value="">Selecciona un objetivo de cultivo...</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1 text-gray-900 dark:text-gray-100">Objetivos secundarios</label>
        <select id="refModalSecondaryObjective"
                class="w-full border p-2 rounded dark:bg-gray-700 dark:border-gray-600 text-sm">
          <option value="">Selecciona un objetivo secundario...</option>
        </select>
      </div>
      <div id="referenceModalError" class="hidden text-sm text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 rounded p-2"></div>
      <div class="flex justify-end gap-2 pt-2 border-t border-gray-200 dark:border-gray-700">
        <button type="button" id="referenceModalCancel"
                class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-4 py-2 text-xs font-medium text-gray-700 shadow-sm hover:bg-gray-50">
          Cancelar
        </button>
        <button type="button" id="referenceModalApply"
                class="inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white shadow-sm hover:bg-indigo-700"
                disabled>
          Aplicar referencia
        </button>
      </div>
    </div>
  </div>
</div>

