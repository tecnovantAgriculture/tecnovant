      referenceModalCancel: document.getElementById("referenceModalCancel"),
      referenceModalApply: document.getElementById("referenceModalApply"),
      refModalCropObjective: document.getElementById("refModalCropObjective"),
      refModalSecondaryObjective: document.getElementById("refModalSecondaryObjective"),
      referenceModalError: document.getElementById("referenceModalError"),
    };

    const ENDPOINTS = {
      analyses: "{{ url_for('foliage_report_api.get_analyses') }}",
      cv: "{{ url_for('foliage_report_api.get_cv_nutrients') }}",
      objectives: "{{ url_for('foliage_api.objectives', id=0) }}",
      secondaryObjectives: "{{ url_for('agrovista_api.get_secondary_objective', objective_id=0) }}",
      secondaryObjectivesList: "{{ url_for('agrovista_api.list_secondary_objectives') }}",
      lots: "{{ url_for('foliage_api.lots_view', id=0) }}",
      lotCrops: "{{ url_for('foliage_api.lot_crops') }}",
      generateReport: "{{ url_for('foliage_report_api.generate_report') }}",
      reportView: "{{ url_for('foliage_report.vista_reporte', report_id=0) }}",
      mineralBalance: "{{ url_for('agrovista_api.mineral_balance') }}",
      lotSnapshot: "{{ url_for('agrovista_api.get_lot_snapshot', common_analysis_id=0) }}",
    };

    let payload = null;
    let analysisData = null;
    let objectiveData = null;
    let objectiveType = null;
    let referenceProtein = null;
    let referenceAforo = null;
    let cvData = {};
    let nutrientOrder = [];
    let targetValues = {};
    let actualValues = {};
    let minimumLawPayload = {};
    let lotCrops = [];
    let currentAnalysisMeta = {
      farmName: "",
      lotName: "",
      area: "",
      cropName: "",
      analysisDate: "",
      username: "",
      orgName: "",
    };

    function showError(message){
      if(!el.error){
        return;
      }
      el.error.textContent = message;
      el.error.classList.remove("hidden");
    }

    function setText(node, value, fallback = "--"){
      if(!node){
        return;
      }
      const text = value == null || value === "" ? fallback : value;
      node.textContent = text;
    }

    function formatNumber(value, decimals = 2){
      if(typeof value === "number" && isFinite(value)){
        return value.toFixed(decimals);
      }
      if(typeof value === "string" && value.trim() !== "" && !isNaN(value)){
        return Number(value).toFixed(decimals);
      }
      return "--";
    }

    function getCsrfToken(){
      const value = `; ${document.cookie}`;
      const parts = value.split("; csrf_access_token=");
      if(parts.length === 2){
        return parts.pop().split(";").shift();
      }
      return "";
    }

    function parseUrlParams(){
      const params = new URLSearchParams(window.location.search);
      const mode = params.get("mode");
      if(!mode){
        return null;
      }
      if(mode === "lot_vs_objective"){
        const lotId = params.get("lot_id");
        const commonAnalysisId = params.get("common_analysis_id");
        const objectiveId = params.get("objective_id");
        const objectiveType = params.get("objective_type") || "crop";
        const objectiveLabel = params.get("objective_label") || "";
        const lotLabel = params.get("lot_label") || "";
        if(!lotId || !objectiveId){
          return null;
        }
        return {
          mode: "lot_vs_objective",
          lot_id: Number(lotId),
          common_analysis_id: Number(commonAnalysisId || 0),
          objective: {
            type: objectiveType,
            id: Number(objectiveId),
            label: objectiveLabel,
          },
          lot_label: lotLabel,
        };
      }
      if(mode === "lot_vs_lot"){
        const token = params.get("token");
        if(token){
          const raw = sessionStorage.getItem(`agrovista_comparison_${token}`);
          if(raw){
            try{
              return JSON.parse(raw);
            }catch(err){
              console.error(err);
            }
          }
        }
        // Fallback: build minimal payload from URL params
        const lotAId = params.get("lot_a_id");
        const lotBId = params.get("lot_b_id");
        const linkedLotId = params.get("linked_lot_id");
        const linkedCommonId = params.get("linked_common_analysis_id");
        if(!lotAId || !linkedLotId){
          return null;
        }
        return {
          mode: "lot_vs_lot",
          lot_a: {
            id: Number(lotAId),
            name: params.get("lot_a_name") || "",
            area_ha: params.get("lot_a_area_ha") ? Number(params.get("lot_a_area_ha")) : null,
            stats: {},
            area_stats: { nutrients: [] },
            linked_lot_id: params.get("lot_a_linked_lot_id")
              ? Number(params.get("lot_a_linked_lot_id"))
              : null,
            linked_common_analysis_id: params.get("lot_a_linked_common_analysis_id")
              ? Number(params.get("lot_a_linked_common_analysis_id"))
              : null,
          },
          lot_b: {
            id: Number(lotBId),
            name: params.get("lot_b_name") || "",
            area_ha: params.get("lot_b_area_ha") ? Number(params.get("lot_b_area_ha")) : null,
            stats: {},
            area_stats: { nutrients: [] },
            linked_lot_id: Number(linkedLotId),
            linked_common_analysis_id: linkedCommonId ? Number(linkedCommonId) : null,
            linked_lot_name: params.get("linked_lot_name") || "",
          },
        };
      }
      return null;
    }

    function parseTokenPayload(){
      // Primary: read from URL params (C1 — reliable navigation)
      const fromUrl = parseUrlParams();
      if(fromUrl){
        return fromUrl;
      }
      // Fallback: legacy sessionStorage method
      const params = new URLSearchParams(window.location.search);
      const token = params.get("token");
      if(!token){
        return null;
      }
      const raw = sessionStorage.getItem(`agrovista_comparison_${token}`);
      if(!raw){
        return null;
      }
      try{
        return JSON.parse(raw);
      }catch(err){
        console.error(err);
        return null;
      }
    }

    async function fetchJson(url, options = {}){
      const res = await fetch(url, { credentials: "include", ...options });
      const data = await res.json().catch(() => ({}));
      if(!res.ok){
        const message = data?.description || data?.error || data?.message || "Solicitud fallida";
        throw new Error(message);
      }
      return data;
    }

    async function fetchLotCrops(){
      if(lotCrops.length){
        return lotCrops;
      }
      try{
        lotCrops = await fetchJson(ENDPOINTS.lotCrops);
      }catch(err){
        console.error("lot-crops", err);
        lotCrops = [];
      }
      return lotCrops;
    }

    function resolveCropNameForLot(lotId){
      const items = lotCrops.filter(item => Number(item?.lot_id) === Number(lotId));
      if(!items.length){
        return null;
      }
      const active = items.find(item => !item?.end_date);
      if(active && active.crop_name){
        return active.crop_name;
      }
      items.sort((a, b) => {
        const dateA = Date.parse(a?.start_date || "") || 0;
        const dateB = Date.parse(b?.start_date || "") || 0;
        return dateB - dateA;
      });
      return items[0]?.crop_name || null;
    }

    function resolveCropIdForLot(lotId){
      const items = lotCrops.filter(item => Number(item?.lot_id) === Number(lotId));
      if(!items.length){
        return null;
      }
      const active = items.find(item => !item?.end_date);
      if(active && active.crop_id){
        return active.crop_id;
      }
      items.sort((a, b) => {
        const dateA = Date.parse(a?.start_date || "") || 0;
        const dateB = Date.parse(b?.start_date || "") || 0;
        return dateB - dateA;
      });
      return items[0]?.crop_id || null;
    }

    function resolveAnyCropId(){
      if(!Array.isArray(lotCrops) || !lotCrops.length){
        return null;
      }
      const sorted = [...lotCrops].sort((a, b) => {
        const dateA = Date.parse(a?.start_date || "") || 0;
        const dateB = Date.parse(b?.start_date || "") || 0;
        return dateB - dateA;
      });
      const active = sorted.find(item => !item?.end_date && item?.crop_id);
      return active?.crop_id || sorted.find(item => item?.crop_id)?.crop_id || null;
    }

    function pickAnalysis(list, preferredId){
      if(!Array.isArray(list) || list.length === 0){
        return null;
      }
      if(preferredId){
        const found = list.find(item => Number(item?.id) === Number(preferredId));
        if(found){
          return found;
        }
      }
      return list.slice().sort((a, b) => {
        const aDate = Date.parse(a?.date || "") || 0;
        const bDate = Date.parse(b?.date || "") || 0;
        return bDate - aDate;
      })[0];
    }

    function collectActualValues(analysis){
      const values = {};
      if(!analysis || !analysis.leaf_analysis || !Array.isArray(analysis.leaf_analysis.nutrients)){
        return values;
      }
      analysis.leaf_analysis.nutrients.forEach(item => {
        if(!item){
          return;
        }
        values[item.nutrient_name] = Number(item.value);
      });
      return values;
    }

    function collectTargetValuesFromObjective(objective){
      const values = {};
      if(!objective){
        return values;
      }
      const targets = Array.isArray(objective.nutrient_targets) ? objective.nutrient_targets : [];
      targets.forEach(item => {
        if(!item){
          return;
        }
        values[item.nutrient_name] = Number(item.target_value);
      });
      return values;
    }

    function collectTargetValuesFromSecondaryObjective(objective){
      const values = {};
      if(!objective){
        return values;
      }
      const targets = Array.isArray(objective.nutrient_targets) ? objective.nutrient_targets : [];
      targets.forEach(item => {
        if(!item){
          return;
        }
        values[item.nutrient_name || item.nutrient_symbol] = Number(item.target_value);
      });
      return values;
    }

    function collectTargetValuesFromStats(stats){
      const values = {};
      if(!stats || !Array.isArray(stats.nutrients)){
        return values;
      }
      stats.nutrients.forEach(item => {
        if(!item){
          return;
        }
        values[item.nutrient_name || item.nutrient_symbol] = Number(item.target_value);
      });
      return values;
    }

    function buildNutrientOrder(){
      const order = Object.keys(targetValues);
      if(order.length){
        return order;
      }
      return Object.keys(actualValues);
    }

    function renderHeaderRow(target, labels, prefix = ""){
      if(!target){
        return;
      }
      target.innerHTML = "";
      labels.forEach(label => {
        const th = document.createElement("th");
        th.className = "px-3 py-2 text-left font-semibold text-gray-600";
        th.textContent = `${prefix}${label}`.trim();
        target.appendChild(th);
      });
    }

    function renderRow(target, values, prefix = ""){
      if(!target){
        return;
      }
      target.innerHTML = "";
      values.forEach(value => {
        const td = document.createElement("td");
        td.className = "px-3 py-2 text-gray-700";
        td.textContent = `${prefix}${value}`.trim();
        target.appendChild(td);
      });
    }

    function renderCropInfo(cropId, cropName){
      const order = nutrientOrder;
      const headers = ["ID", "Cultivo", ...order];
      const row = [
        cropId ? String(cropId) : "--",
        cropName || "--",
        ...order.map(n => formatNumber(targetValues[n], 2)),
      ];
      renderHeaderRow(el.cropInfoHeader, headers);
      renderRow(el.cropInfoRow, row);
    }

    function renderAnalysisInfo(analysis){
      const order = nutrientOrder;
      const headers = order;
      const row = order.map(n => formatNumber(actualValues[n], 2));
      renderHeaderRow(el.analysisInfoHeader, headers);
      renderRow(el.analysisInfoRow, row);
      if(analysis){
        setText(el.analysisMeta, `Análisis N° ${analysis.id} — ${analysis.date}`);
      }
    }

    function renderCvInfo(){
      const order = nutrientOrder;
      const headers = order;
      const row = order.map(n => formatNumber(cvData[n], 2));
      renderHeaderRow(el.cvInfoHeader, headers);
      renderRow(el.cvInfoRow, row);
    }

    function computeMinimumLaw(){
      const order = nutrientOrder;
      minimumLawPayload = {};
      const rows = [];

      const buildRow = (label, values, className = "") => {
        rows.push({ label, values, className });
      };

      // Row 1: %P — porcentaje de suficiencia
      const pRow = order.map(n => {
        const act = actualValues[n];
        const targ = targetValues[n];
        if(act == null || targ == null || targ === 0){
          return null;
        }
        return (act / targ) * 100;
      });
      buildRow("%P", pRow);

      // Row 2: I — índice de ajuste (todos los nutrientes)
      const iRow = order.map(n => {
        const act = actualValues[n];
        const targ = targetValues[n];
        const cv = cvData[n];
        if(act == null || targ == null || targ === 0 || cv == null) return null;
        const p = (act / targ) * 100;
        return Math.abs(p - 100) * cv / 100;
      });
      buildRow("I", iRow, "bg-yellow-50");

      // Row 3: R — nivel corregido (todos los nutrientes)
      const rRow = order.map(n => {
        const act = actualValues[n];
        const targ = targetValues[n];
        const cv = cvData[n];
        if(act == null || targ == null || targ === 0 || cv == null) return null;
        const p = (act / targ) * 100;
        const i = Math.abs(p - 100) * cv / 100;
        let r = p > 100 ? p - i : p + i;
        if(r < 88) r = 88;
        if(r > 108) r = 108;
        return r;
      });
      buildRow("R", rRow, "bg-blue-50");

      // Row 4: Diferencia
      const diffRow = order.map(n => {
        const act = actualValues[n];
        const targ = targetValues[n];
        if(act == null || targ == null || targ === 0){
          return null;
        }
        const p = (act / targ) * 100;
        return p - 100;
      });
      buildRow("Diferencia", diffRow, "bg-red-50");

      // Build minimumLawPayload for backend — must mirror the rendered
      // rows (I and R for every nutrient, same formula as iRow/rRow)
      order.forEach(nutrient => {
        const act = actualValues[nutrient];
        const targ = targetValues[nutrient];
        const cv = cvData[nutrient];
        if(act == null || targ == null || targ === 0){
          return;
        }
        const p = (act / targ) * 100;
        const i = cv != null ? Math.abs(p - 100) * cv / 100 : null;
        let r = null;
        if(i != null){
          r = p > 100 ? p - i : p + i;
          if(r < 88) r = 88;
          if(r > 108) r = 108;
        }
        minimumLawPayload[nutrient] = {
          "%P": p.toFixed(2),
          "I": i != null ? i.toFixed(2) : "-",
          "R": r != null ? r.toFixed(2) : "-",
          "Diferencia": (p - 100).toFixed(2),
        };
      });

      renderMinimumLawTable(order, rows);
      updateSummary(order);
    }

    function renderMinimumLawTable(order, rows){
      if(!el.lawTableHeader || !el.lawTableBody){
        return;
      }
      el.lawTableHeader.innerHTML = "";
      const headLabel = document.createElement("th");
      headLabel.className = "px-3 py-2 text-left font-semibold text-gray-600";
      headLabel.textContent = "Fila";
      el.lawTableHeader.appendChild(headLabel);

      order.forEach(n => {
        const th = document.createElement("th");
        th.className = "px-3 py-2 text-left font-semibold text-gray-600";
        th.textContent = n;
        el.lawTableHeader.appendChild(th);
      });

      el.lawTableBody.innerHTML = "";
      rows.forEach((row, idx) => {
        const tr = document.createElement("tr");
        if(row.className){
          tr.className = row.className;
        }
        const th = document.createElement("td");
        th.className = "whitespace-nowrap px-3 py-2 font-medium text-gray-800";
        th.textContent = row.label;
        tr.appendChild(th);
        row.values.forEach(value => {
          const td = document.createElement("td");
          td.className = "px-3 py-2 text-gray-700";
          if(value == null || Number.isNaN(value)){
            td.textContent = "—";
            td.classList.add("text-gray-400");
          }else{
            td.textContent = value.toFixed(2);
            // Color coding
            if(row.label === "%P"){
              if(value < 88) td.classList.add("text-red-600", "font-semibold");
              else if(value > 108) td.classList.add("text-orange-600");
              else td.classList.add("text-green-600");
            }else if(row.label === "Diferencia"){
              if(value < 0) td.classList.add("text-red-600");
              else if(value > 0) td.classList.add("text-orange-600");
            }
          }
          tr.appendChild(td);
        });
        el.lawTableBody.appendChild(tr);
      });
    }

    function updateSummary(order){
      const entries = order.map(name => {
        const act = actualValues[name];
        const targ = targetValues[name];
        if(act == null || targ == null){
          return null;
        }
        const p = (act / targ) * 100;
        return { name, p };
      }).filter(Boolean);
      if(entries.length === 0){
        setText(el.limitingNutrient, "--");
        setText(el.optimalNutrients, "--");
        setText(el.excessNutrients, "--");
        return;
      }
      entries.sort((a, b) => a.p - b.p);
      const limiting = entries[0];
      const optimal = entries.filter(item => item.p >= 88 && item.p <= 108).map(item => item.name);
      const excess = entries.filter(item => item.p > 108).map(item => item.name);
      setText(el.limitingNutrient, limiting ? limiting.name : "--");
      setText(el.optimalNutrients, optimal.length ? optimal.join(", ") : "—");
      setText(el.excessNutrients, excess.length ? excess.join(", ") : "—");
    }

    // ---- Balance de Minerales (port del FRM_Balance de Foliar Digital.xlsm) ----
    // Los cálculos viven en el backend (POST /api/agrovista/mineral-balance,
    // requiere sesión); aquí solo se arma la petición y se pinta la respuesta.
    let editedProtein = null;
    let balanceFetchSeq = 0;

    async function computeMineralBalance(){
      if(!el.balanceTableHeader || !el.balanceTableBody){
        return;
      }
      // Cabecera: proteína/aforo de la referencia (objetivo o lote A) y
      // del análisis del lote, como en el FRM_Balance del Excel
      // (P_Objetivo, A_Objetivo, P_Actual, A_Actual)
      const aforoObj = Number(referenceAforo ?? objectiveData?.target_value);
      const proteinObj = editedProtein != null
        ? editedProtein
        : Number(referenceProtein ?? objectiveData?.protein);
      const aforoAct = Number(analysisData?.yield_estimate);
      const proteinAct = Number(analysisData?.protein);
      setText(el.balanceProteinObj, proteinObj > 0 ? formatNumber(proteinObj, 2) : "--");
      setText(el.balanceAforoObj, aforoObj > 0 ? formatNumber(aforoObj, 2) : "--");
      setText(el.balanceProteinAct, proteinAct > 0 ? formatNumber(proteinAct, 2) : "--");
      setText(el.balanceAforoAct, aforoAct > 0 ? formatNumber(aforoAct, 2) : "--");

      // El backend convierte con el aforo objetivo y cae al actual; si
      // viaja protein (editada por el usuario), deriva los objetivos
      // desde esa proteína con las regresiones calibradas
      const body = {
        order: nutrientOrder,
        targets: targetValues,
        actuals: actualValues,
        aforo_objective: aforoObj > 0 ? aforoObj : null,
        aforo_actual: aforoAct > 0 ? aforoAct : null,
        protein: editedProtein,
      };
      const seq = ++balanceFetchSeq;
      let data;
      try{
        data = await fetchJson(ENDPOINTS.mineralBalance, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-TOKEN": getCsrfToken() || "",
          },
          body: JSON.stringify(body),
        });
      }catch(err){
        console.error("mineral-balance", err);
        return;
      }
      if(seq !== balanceFetchSeq){
        return; // hay una petición más reciente en vuelo
      }
      // Con proteína editada el backend deriva también el aforo objetivo
      if(data.aforo_objective != null){
        setText(el.balanceAforoObj, formatNumber(data.aforo_objective, 2));
      }
      renderMineralBalance(data);
    }

    function renderMineralBalance(data){
      const entries = Array.isArray(data?.entries) ? data.entries : [];
      const total = typeof data?.total_kg_ha === "number" ? data.total_kg_ha : null;

      if(el.balanceAforoFallbackNote){
        const usedFallback = entries.length > 0 && data?.aforo_actual_fallback === true;
        el.balanceAforoFallbackNote.classList.toggle("hidden", !usedFallback);
      }

      // Mismo orden visual que el FRM_Balance del Excel: % del objetivo,
      // su conversión a kilos, % del foliar actual, su conversión, y
      // luego diferencia / grado / nano. Cada bloque con fondo propio.
      const rows = [
        { label: "Objetivo (% · ppm)", values: entries.map(e => e.objective_raw), kind: "plain", className: "bg-indigo-50", total: null },
        { label: "Objetivo (kg/ha)", values: entries.map(e => e.objective_kg), kind: "plain", className: "bg-indigo-50", total: null },
        { label: "Actual (% · ppm)", values: entries.map(e => e.actual_raw), kind: "plain", className: "bg-sky-50", total: null },
        { label: "Actual (kg/ha)", values: entries.map(e => e.actual_kg), kind: "plain", className: "bg-sky-50", total: null },
        { label: "Diferencia (kg/ha)", values: entries.map(e => e.difference_kg), kind: "diff", className: "bg-red-50", total: null },
        { label: "Grado fórmula (%)", values: entries.map(e => e.grade_pct), kind: "plain", className: "bg-yellow-50", total: total },
        { label: "Nano (kg/ha)", values: entries.map(e => e.nano_kg), kind: "nano", className: "bg-emerald-50", total: null },
      ];

      el.balanceTableHeader.innerHTML = "";
      const headLabel = document.createElement("th");
      headLabel.className = "px-3 py-2 text-left font-semibold text-gray-600";
      headLabel.textContent = "Concepto";
      el.balanceTableHeader.appendChild(headLabel);
      entries.forEach(entry => {
        const th = document.createElement("th");
        th.className = "px-3 py-2 text-left font-semibold text-gray-600";
        th.textContent = entry.name;
        el.balanceTableHeader.appendChild(th);
      });
      const thTotal = document.createElement("th");
      thTotal.className = "px-3 py-2 text-left font-semibold text-gray-600";
      thTotal.textContent = "Total";
      el.balanceTableHeader.appendChild(thTotal);

      el.balanceTableBody.innerHTML = "";
      rows.forEach(row => {
        const tr = document.createElement("tr");
        if(row.className) tr.className = row.className;
        const tdLabel = document.createElement("td");
        tdLabel.className = "whitespace-nowrap px-3 py-2 font-medium text-gray-800";
        tdLabel.textContent = row.label;
        tr.appendChild(tdLabel);
        row.values.forEach(value => {
          const td = document.createElement("td");
          td.className = "px-3 py-2 text-gray-700";
          if(value == null || Number.isNaN(value)){
            td.textContent = "—";
            td.classList.add("text-gray-400");
          }else{
            td.textContent = value.toFixed(2);
            if(row.kind === "diff" && value < 0){
              td.classList.add("text-red-600", "font-semibold");
            }
            if(row.kind === "nano" && value > 0){
              td.classList.add("text-emerald-700", "font-semibold");
            }
          }
          tr.appendChild(td);
        });
        const tdTotal = document.createElement("td");
        tdTotal.className = "px-3 py-2 whitespace-nowrap";
        if(row.total != null){
          tdTotal.textContent = `${row.total.toFixed(2)} kg/ha`;
          tdTotal.classList.add("font-semibold", "text-gray-900");
        }else{
          tdTotal.textContent = "—";
          tdTotal.classList.add("text-gray-400");
        }
        tr.appendChild(tdTotal);
        el.balanceTableBody.appendChild(tr);
      });
    }

    async function setupLotVsObjective(data){
      const lotId = data.lot_id;
      const objectiveId = data.objective?.id || data.objective_id;
      const objectiveKind = data.objective?.type || "crop";
      if(!lotId || !objectiveId){
        throw new Error("No se encontraron los parámetros de comparación.");
      }
      const [analyses, lotInfo] = await Promise.all([
        fetchJson(`${ENDPOINTS.analyses}?lot_id=${lotId}`),
        fetchJson(ENDPOINTS.lots.replace("0", lotId)),
      ]);
      analysisData = pickAnalysis(analyses, data.common_analysis_id);
      objectiveType = objectiveKind;
      if(objectiveKind === "secondary"){
        objectiveData = await fetchJson(ENDPOINTS.secondaryObjectives.replace("0", objectiveId));
      }else{
        objectiveData = await fetchJson(ENDPOINTS.objectives.replace("0", objectiveId));
      }
      await fetchLotCrops();

      const secondaryCropName = objectiveData?.analysis_crop?.name || "--";
      const cropName = objectiveKind === "secondary"
        ? secondaryCropName
        : (objectiveData?.crop_name || resolveCropNameForLot(lotId) || "--");
      setText(el.analysisLotName, lotInfo?.name || data.lot_label);
      setText(el.analysisLotArea, lotInfo?.area ? `${formatNumber(lotInfo.area, 2)} ha` : "--");
      setText(el.analysisLotCrop, cropName);
      setText(el.analysisLotDate, analysisData?.date || "--");

      // Store analysis metadata for PDF export
      const lotLabel = data.lot_label || "";
      const parts = lotLabel.split(" · ");
      currentAnalysisMeta.farmName = parts[0] ? parts[0].trim() : (lotInfo?.farm_name || "");
      currentAnalysisMeta.lotName = parts.length > 1 ? parts.slice(1).join(" · ").trim() : (lotInfo?.name || "");
      currentAnalysisMeta.area = lotInfo?.area ? `${formatNumber(lotInfo.area, 2)} ha` : "--";
      currentAnalysisMeta.cropName = cropName;
      currentAnalysisMeta.analysisDate = analysisData?.date || "--";
      currentAnalysisMeta.username = document.getElementById("meta-username")?.textContent?.trim() || "Sistema";
      currentAnalysisMeta.orgName = document.getElementById("meta-orgname")?.textContent?.trim() || "";

      // Populate NDVI/VARI/NBI from payload stats if available (C2)
      const payloadStats = payload?.stats || {};
      if(payloadStats && payloadStats.ndvi != null){
        setText(el.analysisNdvi, formatMetric(payloadStats.ndvi, 2));
        setText(el.analysisVari, formatMetric(payloadStats.vari, 2));
        setText(el.analysisNbi, formatMetric(payloadStats.nbi, 2));
      }else{
        setText(el.analysisNdvi, "--");
        setText(el.analysisVari, "--");
        setText(el.analysisNbi, "--");
      }

      setText(el.referenceName, data.objective?.label || `${cropName} · ID ${objectiveId}`);
      setText(el.referenceSource, objectiveKind === "secondary" ? "Objetivo secundario" : "Tabla de objetivos");
      setText(el.referenceType, objectiveKind === "secondary" ? "Objetivo secundario" : "Ideal de cultivo");
      setText(el.referenceNdvi, "--");
      setText(el.referenceVari, "--");
      setText(el.referenceNbi, "--");

      actualValues = collectActualValues(analysisData);
      targetValues = objectiveKind === "secondary"
        ? collectTargetValuesFromSecondaryObjective(objectiveData)
        : collectTargetValuesFromObjective(objectiveData);
      // Proteína/aforo de la referencia (Objective.protein / target_value;
      // los secundarios exponen protein_average)
      referenceProtein = Number(objectiveData?.protein ?? objectiveData?.protein_average) || null;
      referenceAforo = Number(objectiveData?.target_value) || null;
      nutrientOrder = buildNutrientOrder();
      const cropIdValue = objectiveKind === "secondary" ? objectiveData?.analysis_crop_id : objectiveData?.crop_id;
      renderCropInfo(cropIdValue, cropName);
    }

    async function setupLotVsLot(data){
      const lotA = data.lot_a;
      const lotB = data.lot_b;
      if(!lotA || !lotB){
        throw new Error("No se encontró la comparación lote vs lote.");
      }
      if(!lotB.linked_lot_id){
        throw new Error("El lote B no tiene un análisis foliar guardado. Guarde un análisis desde el NDVI Tool antes de comparar.");
      }
      await fetchLotCrops();
      const analyses = await fetchJson(`${ENDPOINTS.analyses}?lot_id=${lotB.linked_lot_id}`);
      analysisData = pickAnalysis(analyses, lotB.linked_common_analysis_id);
      if(!analysisData){
        throw new Error("No se encontró un análisis de follaje válido para el Lote B. Guarde un análisis desde el NDVI Tool antes de comparar.");
      }

      const lotInfo = await fetchJson(ENDPOINTS.lots.replace("0", lotB.linked_lot_id));
      const cropName = resolveCropNameForLot(lotB.linked_lot_id) || "--";

      el.analysisCardTitle.textContent = "Lote analizado";
      el.analysisCardBadge.textContent = "Lote B";
      setText(el.analysisLotName, lotB.linked_lot_name || lotInfo?.name || lotB.name);
      setText(el.analysisLotArea, lotB.area_ha ? `${formatNumber(lotB.area_ha, 2)} ha` : (lotInfo?.area ? `${formatNumber(lotInfo.area, 2)} ha` : "--"));
      setText(el.analysisLotCrop, cropName);
      setText(el.analysisLotDate, analysisData?.date || "--");

      // Store analysis metadata for PDF export (lot_vs_lot mode)
      currentAnalysisMeta.farmName = lotInfo?.farm_name || "";
      currentAnalysisMeta.lotName = lotB.linked_lot_name || lotInfo?.name || lotB.name || "";
      currentAnalysisMeta.area = lotB.area_ha ? `${formatNumber(lotB.area_ha, 2)} ha` : (lotInfo?.area ? `${formatNumber(lotInfo.area, 2)} ha` : "--");
      currentAnalysisMeta.cropName = cropName;
      currentAnalysisMeta.analysisDate = analysisData?.date || "--";
      currentAnalysisMeta.username = document.getElementById("meta-username")?.textContent?.trim() || "Sistema";
      currentAnalysisMeta.orgName = document.getElementById("meta-orgname")?.textContent?.trim() || "";

      // NDVI/VARI/NBI: prefer payload stats, fallback to fetched data
      if(lotB.stats && lotB.stats.ndvi != null){
        setText(el.analysisNdvi, formatNumber(lotB.stats.ndvi, 2));
        setText(el.analysisVari, formatNumber(lotB.stats.vari, 2));
        setText(el.analysisNbi, formatNumber(lotB.stats.nbi, 2));
      }else{
        setText(el.analysisNdvi, "--");
        setText(el.analysisVari, "--");
        setText(el.analysisNbi, "--");
      }

      el.referenceCardBadge.textContent = "Lote A";
      setText(el.referenceName, lotA.name || "Lote A");
      setText(el.referenceSource, "Lote comparativo");
      setText(el.referenceType, "Ideal por lote");
      if(lotA.stats && lotA.stats.ndvi != null){
        setText(el.referenceNdvi, formatNumber(lotA.stats.ndvi, 2));
        setText(el.referenceVari, formatNumber(lotA.stats.vari, 2));
        setText(el.referenceNbi, formatNumber(lotA.stats.nbi, 2));
      }else{
        setText(el.referenceNdvi, "--");
        setText(el.referenceVari, "--");
        setText(el.referenceNbi, "--");
      }

      actualValues = collectActualValues(analysisData);

      // Proteína/aforo de la referencia = los del lote A. Prioridad: su
      // análisis foliar guardado; fallback al estimado por imagen
      // (area_stats.protein / bromatologia.aforo_ua_ha)
      referenceProtein = null;
      referenceAforo = null;
      if(lotA.linked_lot_id){
        try{
          const refAnalyses = await fetchJson(`${ENDPOINTS.analyses}?lot_id=${lotA.linked_lot_id}`);
          const refAnalysis = pickAnalysis(refAnalyses, lotA.linked_common_analysis_id);
          if(refAnalysis){
            referenceProtein = Number(refAnalysis.protein) || null;
            referenceAforo = Number(refAnalysis.yield_estimate) || null;
          }
        }catch(err){
          console.warn("No se pudo cargar el análisis del lote A:", err);
        }
      }
      if(referenceProtein == null){
        referenceProtein = Number(lotA.area_stats?.protein) || null;
      }
      if(referenceAforo == null){
        referenceAforo = Number(lotA.area_stats?.bromatologia?.aforo_ua_ha) || null;
      }

      // If area_stats is missing or empty, use objective targets as fallback
      if(lotA.area_stats && Array.isArray(lotA.area_stats.nutrients) && lotA.area_stats.nutrients.length > 0){
        targetValues = collectTargetValuesFromStats(lotA.area_stats);
      }else{
        // Try to fetch crop objective for this lot
        const cropId = resolveCropIdForLot(lotB.linked_lot_id);
        if(cropId){
          try{
            objectiveData = await fetchJson(ENDPOINTS.objectives.replace("0", cropId));
            targetValues = collectTargetValuesFromObjective(objectiveData);
          }catch(err){
            console.warn("No se pudo cargar objetivo del cultivo para comparación lot-vs-lot:", err);
            targetValues = {};
          }
        }else{
          targetValues = {};
        }
      }
      nutrientOrder = buildNutrientOrder();
      renderCropInfo(resolveCropIdForLot(lotB.linked_lot_id), cropName);
    }

    async function fetchCvValues(lotId){
      try{
        cvData = await fetchJson(`${ENDPOINTS.cv}?lot_id=${lotId}`);
      }catch(err){
        console.error("cv", err);
        cvData = {};
      }
    }

    async function handleSaveReport(){
      if(!analysisData){
        showError("No se pudo cargar la información del análisis.");
        return;
      }
      if(!payload){
        showError("No se encontró el contexto de la comparación.");
        return;
      }
      let objectiveId = payload.objective?.id || payload.objective_id;
      let lotId = payload.lot_id;
      let title = "Comparación nutricional";
      // Etiqueta de la referencia para el encabezado del informe:
      // lote A en modo lot_vs_lot, "Datos cultivo ideal <crop>" en modo objetivo.
      let comparisonLabel = currentAnalysisMeta.cropName && currentAnalysisMeta.cropName !== "--"
        ? `Datos cultivo ideal ${currentAnalysisMeta.cropName}`
        : (el.referenceName?.textContent?.trim() || "Referencia personalizada");
      if(payload.mode === "lot_vs_lot"){
        const lotB = payload.lot_b;
        lotId = lotB?.linked_lot_id;
        title = `Comparación nutricional · ${lotB?.linked_lot_name || lotB?.name || "Lote"}`;
        comparisonLabel = payload.lot_a?.name || el.referenceName?.textContent?.trim() || "Lote de referencia";
        await fetchLotCrops();
        let cropId = resolveCropIdForLot(lotId);
        if(!cropId && payload.lot_id){
          cropId = resolveCropIdForLot(payload.lot_id);
        }
        if(!cropId && payload.objective?.crop_id){
          cropId = Number(payload.objective.crop_id) || null;
        }
        if(!cropId){
          cropId = resolveAnyCropId();
        }
        if(!cropId){
          showError("No hay cultivos registrados. Cree al menos un cultivo en el sistema para poder generar el informe.");
          return;
        }
        objectiveId = await findObjectiveForCrop(cropId);
        if(!objectiveId){
          showError("No existe un objetivo nutricional para este cultivo. Créelo desde Objetivos → Gestión de objetivos antes de generar el informe.");
          return;
        }
      }else if(payload.objective?.type === "secondary"){
        await fetchLotCrops();
        const cropId = resolveCropIdForLot(lotId);
        if(!cropId){
          showError("No se encontró el cultivo asociado al lote.");
          return;
        }
        objectiveId = await findObjectiveForCrop(cropId);
        if(!objectiveId){
          showError("No existe un objetivo nutricional para este cultivo. Créelo desde Objetivos → Gestión de objetivos antes de generar el informe.");
          return;
        }
      }
      if(!objectiveId){
        showError("No se encontró el objetivo ideal para generar el informe.");
        return;
      }
      const payloadReport = {
        lot_id: Number(lotId),
        common_analysis_id: Number(analysisData.id),
        objective_id: Number(objectiveId),
        title,
        comparison_label: comparisonLabel,
        minimum_law_analyses: JSON.stringify(minimumLawPayload),
      };
      const csrf = getCsrfToken();
      el.saveReportBtn.disabled = true;
      el.saveReportBtn.textContent = "Generando...";
      try{
        const res = await fetch(ENDPOINTS.generateReport, {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-TOKEN": csrf || "",
          },
          body: JSON.stringify(payloadReport),
        });
        const body = await res.json().catch(() => ({}));
        if(!res.ok || !body?.report_id){
          const message = body?.error || body?.message || body?.description || "No se pudo generar el reporte.";
          throw new Error(message);
        }
        window.location.href = ENDPOINTS.reportView.replace("0", body.report_id);
      }catch(err){
        showError(err?.message || "Error al generar el reporte.");
      }finally{
        el.saveReportBtn.disabled = false;
        el.saveReportBtn.textContent = "Guardar como informe";
      }
    }

    async function findObjectiveForCrop(cropId){
      if(!cropId) return null;
      try{
        const list = await fetchJson("{{ url_for('foliage_report_api.get_all_objectives') }}");
        if(!Array.isArray(list)) return null;
        const match = list.find(obj => Number(obj?.crop_id) === Number(cropId));
        return match ? Number(match.id) : null;
      }catch(err){
        console.error("findObjectiveForCrop", err);
        return null;
      }
    }

    function exportPdf(){
      const { jsPDF } = window.jspdf || {};
      if(!jsPDF){
        showError("No se pudo cargar el exportador PDF.");
        return;
      }

      const doc = new jsPDF("p", "mm", "a4");
      const W = doc.internal.pageSize.getWidth();   // 210
      const H = doc.internal.pageSize.getHeight();   // 297
      const ML = 16;  // margin left
      const MR = 16;  // margin right
      const CW = W - ML - MR;  // content width
      let y = 16;

      // ---- helpers ----
      const checkPage = (needed) => { if(y + needed > H - 20){ doc.addPage(); y = 20; } };
      const sectionH = (title) => {
        checkPage(12);
        doc.setFontSize(10);
        doc.setFont(undefined, "bold");
        doc.setTextColor(16, 185, 129);
        doc.text(title, ML, y);
        y += 6;
        doc.setTextColor(0, 0, 0);
      };

      // ---- Data extraction (early, reused throughout) ----
      const now = new Date();
      const fechaInforme = now.toLocaleDateString("es-CO", { day: "2-digit", month: "long", year: "numeric" });
      const finca = currentAnalysisMeta.farmName || "--";
      const loteNombre = currentAnalysisMeta.lotName || el.analysisLotName?.textContent?.trim() || "--";
      const area = currentAnalysisMeta.area || el.analysisLotArea?.textContent?.trim() || "--";
      const cultivo = currentAnalysisMeta.cropName || el.analysisLotCrop?.textContent?.trim() || "--";
      const fechaAnalisis = currentAnalysisMeta.analysisDate || el.analysisLotDate?.textContent?.trim() || "--";
      const refObjetivo = el.referenceName?.textContent?.trim() || "--";
      const autor = currentAnalysisMeta.username || "Sistema";
      const orgName = currentAnalysisMeta.orgName || "";

      // ---- Compact header (24 mm band) ----
      doc.setFillColor(16, 185, 129);
      doc.rect(0, 0, W, 24, "F");
      doc.setTextColor(255, 255, 255);
      doc.setFontSize(14);
      doc.setFont(undefined, "bold");
      doc.text("COMPARACIÓN NUTRICIONAL", ML, 12);
      doc.setFontSize(7);
      doc.setFont(undefined, "normal");
      const modeText = payload?.mode === "lot_vs_lot" ? "Lote vs Lote" : "Lote vs Objetivo";
      doc.text(`${modeText}  ·  ${fechaInforme}`, ML, 19);
      const headerRight = orgName ? `TecnoAgro  ·  ${orgName}` : "TecnoAgro";
      doc.text(headerRight, W - MR, 19, { align: "right" });
      doc.setTextColor(0, 0, 0);
      y = 30;

      // ---- KPI cards (2 rows × 3 columns) ----
      const cardW = (CW - 8) / 3;
      const cardH = 16;
      const cardGap = 4;

      function drawKpiCard(x, yy, label, value, rgb){
        doc.setFillColor(rgb[0], rgb[1], rgb[2]);
        doc.rect(x, yy, cardW, cardH, "F");
        doc.setFontSize(6);
        doc.setFont(undefined, "bold");
        doc.setTextColor(255, 255, 255);
        doc.text(label.toUpperCase(), x + 3, yy + 6);
        doc.setFontSize(9);
        const displayVal = String(value || "--");
        const maxW = cardW - 6;
        let valText = displayVal;
        while(doc.getTextWidth(valText) > maxW && valText.length > 3){
          valText = valText.slice(0, -4) + "\u2026";
        }
        doc.text(valText, x + 3, yy + 13);
        doc.setTextColor(0, 0, 0);
      }

      const row1y = y;
      drawKpiCard(ML, row1y, "Finca", finca, [5, 150, 105]);
      drawKpiCard(ML + cardW + cardGap, row1y, "Lote", loteNombre, [20, 184, 166]);
      drawKpiCard(ML + 2 * (cardW + cardGap), row1y, "Cultivo", cultivo, [13, 148, 136]);
      y += cardH + cardGap;

      drawKpiCard(ML, y, "\u00c1rea", area, [79, 70, 229]);
      drawKpiCard(ML + cardW + cardGap, y, "Fecha an\u00e1lisis", fechaAnalisis, [99, 102, 241]);
      drawKpiCard(ML + 2 * (cardW + cardGap), y, "Referencia", refObjetivo, [16, 185, 129]);
      y += cardH + 6;

      // Vegetation indices — compact inline if any value exists
      const ndvi = el.analysisNdvi?.textContent?.trim() || "--";
      const vari = el.analysisVari?.textContent?.trim() || "--";
      const nbi = el.analysisNbi?.textContent?.trim() || "--";
      const refNdvi = el.referenceNdvi?.textContent?.trim() || "--";
      const refVari = el.referenceVari?.textContent?.trim() || "--";
      const refNbi = el.referenceNbi?.textContent?.trim() || "--";
      const hasIndices = ndvi !== "--" || vari !== "--" || nbi !== "--" ||
                         refNdvi !== "--" || refVari !== "--" || refNbi !== "--";
      if(hasIndices){
        sectionH("\u00cdndices vegetacionales");
        doc.setFontSize(7);
        const half = ML + CW / 2;
        doc.setFont(undefined, "bold");
        doc.setTextColor(107, 114, 128);
        doc.text("Lote analizado", ML, y);
        doc.text("Referencia", half, y);
        y += 4;
        doc.setFont(undefined, "normal");
        const drawIdx = (label, a, b) => {
          doc.setTextColor(156, 163, 175);
          doc.text(label, ML, y);
          doc.setTextColor(17, 24, 39);
          doc.setFont(undefined, "bold");
          doc.text(String(a), ML + 14, y);
          doc.setTextColor(156, 163, 175);
          doc.setFont(undefined, "normal");
          doc.text(String(b), half + 14, y);
          y += 4;
        };
        drawIdx("NDVI", ndvi, refNdvi);
        drawIdx("VARI", vari, refVari);
        drawIdx("NBI", nbi, refNbi);
        doc.setTextColor(0, 0, 0);
        y += 2;
      }

      // ---- Executive summary panel ----
      sectionH("Estado nutricional");
      const limitante = el.limitingNutrient?.textContent?.trim() || "--";
      const optimos = el.optimalNutrients?.textContent?.trim() || "--";
      const exceso = el.excessNutrients?.textContent?.trim() || "--";

      // Count optimal nutrients to build an equilibrium index
      const optCount = optimos !== "--" ? optimos.split(",").length : 0;
      const excCount = exceso !== "--" ? exceso.split(",").length : 0;
      const totalMentioned = (limitante !== "--" ? 1 : 0) + optCount + excCount;
      const eqIdx = totalMentioned > 0 ? Math.round((optCount / totalMentioned) * 100) : 0;

      // Panel background
      const panelY = y;
      const panelH = 32;
      doc.setFillColor(240, 253, 244);  // green-50
      doc.rect(ML, panelY, CW, panelH, "F");
      doc.setDrawColor(16, 185, 129);
      doc.setLineWidth(0.5);
      doc.rect(ML, panelY, CW, panelH);

      // Status indicators (colored circles + labels)
      doc.setFontSize(8);
      const indY = panelY + 10;
      // Limiting (red)
      doc.setFillColor(220, 38, 38);
      doc.circle(ML + 10, indY - 1, 2.5, "F");
      doc.setFont(undefined, "bold");
      doc.setTextColor(17, 24, 39);
      doc.text(`Limitante: ${limitante}`, ML + 17, indY);
      // Optimal (green)
      doc.setFillColor(22, 163, 74);
      doc.circle(ML + 90, indY - 1, 2.5, "F");
      doc.setFont(undefined, "normal");
      doc.text(`\u00d3ptimos: ${optCount} nutrientes`, ML + 97, indY);
      // Excess (amber)
      doc.setFillColor(234, 88, 12);
      doc.circle(ML + 10, indY + 9, 2.5, "F");
      doc.text(`Exceso: ${exceso !== "--" ? exceso : "ninguno"}`, ML + 17, indY + 9);
      // Equilibrium index
      doc.setFillColor(79, 70, 229);
      doc.circle(ML + 90, indY + 9, 2.5, "F");
      doc.text(`Equilibrio: ${eqIdx}%`, ML + 97, indY + 9);

      doc.setLineWidth(0);
      doc.setTextColor(0, 0, 0);
      y = panelY + panelH + 8;

      // ---- Ley de Mínimos table ----
      sectionH("Ley de M\u00ednimos");
      doc.setFontSize(7);
      doc.setFont(undefined, "normal");
      doc.setTextColor(107, 114, 128);
      doc.text("% respecto al objetivo ideal", ML, y);
      y += 5;
      doc.setTextColor(0, 0, 0);

      const tableBody = el.lawTableBody;
      const tableHeaders = el.lawTableHeader?.querySelectorAll("th");
      if(!tableBody || !tableHeaders || tableHeaders.length < 2){
        doc.setFontSize(9);
        doc.text("Sin datos disponibles.", ML, y);
        y += 6;
      }else{
        const colNames = [];
        for(let i = 1; i < tableHeaders.length; i++){
          colNames.push(tableHeaders[i].textContent.trim());
        }
        const rows = [];
        tableBody.querySelectorAll("tr").forEach(tr => {
          const cells = tr.querySelectorAll("td");
          const rowData = [];
          cells.forEach(td => rowData.push(td.textContent.trim()));
          rows.push(rowData);
        });

        const nCols = colNames.length;
        const colW = CW / (nCols + 1);
        const rowH = 6;

        // Solid header row
        doc.setFontSize(7);
        doc.setFont(undefined, "bold");
        doc.setFillColor(16, 185, 129);
        doc.rect(ML, y, CW, rowH, "F");
        doc.setTextColor(255, 255, 255);
        doc.text("", ML + 1, y + rowH - 2); // label column header empty
        colNames.forEach((name, i) => {
          doc.text(name, ML + colW * (i + 1) + 1, y + rowH - 2);
        });
        y += rowH;

        // Data rows
        rows.forEach((rowData, ri) => {
          checkPage(rowH + 4);
          if(ri % 2 === 0){
            doc.setFillColor(248, 250, 252);
            doc.rect(ML, y, CW, rowH, "F");
          }
          const label = rowData[0] || "";
          if(label.includes("D\u00e9ficit") || label.includes("Diferencia")){
            doc.setFont(undefined, "bold");
          }else{
            doc.setFont(undefined, "normal");
          }
          doc.setTextColor(55, 65, 81);
          doc.text(label, ML + 1, y + rowH - 2);

          rowData.slice(1).forEach((val, ci) => {
            if(val === "\u2014" || val === "-") return;
            const num = parseFloat(val);
            const display = isNaN(num) ? val : num.toFixed(2);
            const cellX = ML + colW * (ci + 1);
            const textX = cellX + colW - 1;

            if(label === "%P"){
              // Progress bar + colored value
              const pct = Math.min(Math.max(num, 0), 150) / 150;
              const barW = colW - 4;
              // Background track
              doc.setFillColor(229, 231, 235);
              doc.rect(cellX + 1, y + 1.5, barW, 3, "F");
              // Fill
              if(num < 88){
                doc.setFillColor(220, 38, 38);
              }else if(num > 108){
                doc.setFillColor(234, 88, 12);
              }else{
                doc.setFillColor(22, 163, 74);
              }
              doc.rect(cellX + 1, y + 1.5, barW * pct, 3, "F");
              // Value text on top
              doc.setTextColor(17, 24, 39);
              doc.setFont(undefined, "bold");
              doc.text(display, textX, y + rowH - 2, { align: "right" });
            }else if(label === "Diferencia"){
              if(num < 0) doc.setTextColor(220, 38, 38);
              else if(num > 0) doc.setTextColor(234, 88, 12);
              else doc.setTextColor(0, 0, 0);
              doc.text(display, textX, y + rowH - 2, { align: "right" });
            }else{
              doc.setTextColor(0, 0, 0);
              doc.text(display, textX, y + rowH - 2, { align: "right" });
            }
          });
          doc.setTextColor(0, 0, 0);
          y += rowH;
        });
      }
      y += 4;

      // ---- Auto-interpretation ----
      checkPage(20);
      doc.setFontSize(8);
      doc.setFont(undefined, "bold");
      doc.setTextColor(16, 185, 129);
      doc.text("Interpretaci\u00f3n", ML, y);
      y += 6;

      // Build interpretation from available data
      const parts = [];
      if(limitante !== "--"){
        parts.push(`El cultivo presenta una deficiencia de ${limitante} como principal nutriente limitante.`);
      }
      if(optCount > 0){
        parts.push(`${optCount} nutriente(s) se encuentran en rango \u00f3ptimo.`);
      }
      if(excCount > 0){
        parts.push(`Se observa exceso relativo de ${exceso}, lo cual puede interferir con la absorci\u00f3n de otros elementos.`);
      }
      if(eqIdx < 50){
        parts.push(`El \u00edndice de equilibrio nutricional es bajo (${eqIdx}%). Se recomienda priorizar la correcci\u00f3n del nutriente limitante antes de ajustar otros elementos.`);
      }else if(eqIdx >= 80){
        parts.push(`El \u00edndice de equilibrio nutricional es alto (${eqIdx}%). El lote se encuentra cercano al perfil objetivo.`);
      }
      if(parts.length === 0){
        parts.push("No hay datos suficientes para generar una interpretaci\u00f3n autom\u00e1tica.");
      }

      const interpText = parts.join(" ");
      doc.setFontSize(7);
      doc.setFont(undefined, "italic");
      doc.setTextColor(75, 85, 99);
      const interpLines = doc.splitTextToSize(interpText, CW);
      doc.text(interpLines, ML, y);
      y += interpLines.length * 4 + 4;

      // ---- Section: Balance de Minerales ----
      checkPage(30);
      doc.setFontSize(12);
      doc.setFont(undefined, "bold");
      doc.setTextColor(16, 185, 129);
      doc.text("Balance de Minerales", ML, y);
      y += 3;

      // Metadata: proteína y aforo objetivo/actual
      const protObj = el.balanceProteinObj?.textContent?.trim() || "--";
      const aforoObj = el.balanceAforoObj?.textContent?.trim() || "--";
      const protAct = el.balanceProteinAct?.textContent?.trim() || "--";
      const aforoAct = el.balanceAforoAct?.textContent?.trim() || "--";
      doc.setFontSize(7);
      doc.setFont(undefined, "normal");
      doc.setTextColor(107, 114, 128);
      doc.text(
        `Proteína objetivo: ${protObj}  |  Aforo objetivo: ${aforoObj}  |  Proteína actual: ${protAct}  |  Aforo actual: ${aforoAct}`,
        ML, y
      );
      y += 6;
      doc.setTextColor(0, 0, 0);

      const balHeader = el.balanceTableHeader;
      const balBody = el.balanceTableBody;
      if(!balBody || !balHeader || balHeader.querySelectorAll("th").length < 2){
        doc.setFontSize(9);
        doc.text("Sin datos de balance disponibles.", ML, y);
        y += 6;
      }else{
        const balCols = [];
        balHeader.querySelectorAll("th").forEach(th => balCols.push(th.textContent.trim()));
        const balRows = [];
        balBody.querySelectorAll("tr").forEach(tr => {
          const cells = tr.querySelectorAll("td");
          const rowData = [];
          cells.forEach(td => rowData.push(td.textContent.trim()));
          balRows.push(rowData);
        });

        // ---- Dynamic column widths ----
        doc.setFontSize(7);
        doc.setFont(undefined, "normal");
        const PAD = 3; // horizontal padding per cell (mm)

        // Measure header widths
        const colWidths = balCols.map(name => doc.getTextWidth(name) + PAD);

        // Measure max data width per column
        balRows.forEach(rowData => {
          rowData.forEach((val, ci) => {
            if(!val || val === "—") return;
            const num = parseFloat(val);
            const display = isNaN(num) ? val.replace(" kg/ha", "") : num.toFixed(2);
            const w = doc.getTextWidth(display) + PAD;
            if(w > colWidths[ci]) colWidths[ci] = w;
          });
        });

        // Minimum widths: "Concepto" (idx 0) and "Total" (last)
        colWidths[0] = Math.max(colWidths[0], 36);
        const lastIdx = colWidths.length - 1;
        colWidths[lastIdx] = Math.max(colWidths[lastIdx], 17);

        // Build cumulative x-positions
        const colX = [ML];
        for(let i = 0; i < colWidths.length; i++){
          colX.push(colX[i] + colWidths[i]);
        }
        let totalReq = colX[colX.length - 1] - ML;

        // Scale down proportionally if needed
        if(totalReq > CW){
          const scale = CW / totalReq;
          for(let i = 0; i < colWidths.length; i++){
            colWidths[i] *= scale;
          }
          // Recompute cumulative positions
          colX.length = 1; // keep colX[0] = ML
          for(let i = 0; i < colWidths.length; i++){
            colX.push(colX[i] + colWidths[i]);
          }
          totalReq = colX[colX.length - 1] - ML;
        }

        const balRowH = 6;

        // Header row
        doc.setFont(undefined, "bold");
        doc.setFillColor(243, 244, 246);
        doc.rect(ML, y, CW, balRowH, "F");
        doc.setTextColor(55, 65, 81);
        for(let i = 0; i < balCols.length; i++){
          const alignX = i === 0 ? colX[i] + 1 : colX[i + 1] - 1; // left for Concepto, right for others
          doc.text(balCols[i], alignX, y + balRowH - 2, { align: i === 0 ? "left" : "right" });
        }
        doc.setTextColor(0, 0, 0);
        y += balRowH;

        // Data rows
        doc.setFont(undefined, "normal");
        balRows.forEach((rowData, ri) => {
          checkPage(balRowH + 4);
          if(ri % 2 === 0){
            doc.setFillColor(249, 250, 251);
            doc.rect(ML, y, CW, balRowH, "F");
          }
          const label = rowData[0] || "";
          if(label.includes("Diferencia") || label.includes("Grado")){
            doc.setFont(undefined, "bold");
          }

          // "Concepto" column: left-aligned
          doc.text(label, colX[0] + 1, y + balRowH - 2, { align: "left" });

          // Numeric columns: right-aligned
          for(let ci = 1; ci < rowData.length; ci++){
            const val = rowData[ci];
            if(val === "—" || val === "") continue;
            const num = parseFloat(val);
            const display = isNaN(num) ? val.replace(" kg/ha", "") : num.toFixed(2);
            if(label.includes("Diferencia") && num < 0){
              doc.setTextColor(220, 38, 38);        // red-600
            }else if(label.includes("Nano") && num > 0){
              doc.setTextColor(5, 150, 105);         // emerald-700
            }else{
              doc.setTextColor(0, 0, 0);
            }
            doc.text(display, colX[ci + 1] - 1, y + balRowH - 2, { align: "right" });
          }
          doc.setTextColor(0, 0, 0);
          doc.setFont(undefined, "normal");
          y += balRowH;
        });
      }
      y += 4;

      // ---- Signature block ----
      checkPage(25);
      doc.setDrawColor(209, 213, 219);
      doc.setLineWidth(0.3);
      doc.line(ML, y, W - MR, y);
      doc.setLineWidth(0);
      y += 8;
      doc.setFontSize(7);
      doc.setFont(undefined, "normal");
      doc.setTextColor(107, 114, 128);
      const sigY = y + 16;
      doc.setDrawColor(156, 163, 175);
      doc.setLineWidth(0.3);
      doc.line(ML, sigY, ML + 55, sigY);
      doc.line(ML + 70, sigY, ML + 125, sigY);
      doc.setLineWidth(0);
      doc.text("Firma del responsable", ML, sigY + 4);
      doc.text("Vo.Bo. Agr\u00f3nomo", ML + 70, sigY + 4);
      if(autor && autor !== "Sistema"){
        doc.setTextColor(55, 65, 81);
        doc.setFont(undefined, "bold");
        doc.text(autor, ML, sigY - 4);
      }
      doc.setTextColor(0, 0, 0);

      // ---- Professional footer on every page ----
      const pageCount = doc.internal.getNumberOfPages();
      for(let i = 1; i <= pageCount; i++){
        doc.setPage(i);
        // Separator line
        doc.setDrawColor(209, 213, 219);
        doc.setLineWidth(0.2);
        doc.line(ML, H - 14, W - MR, H - 14);
        doc.setLineWidth(0);
        // Footer text
        doc.setFontSize(6);
        doc.setTextColor(156, 163, 175);
        doc.setFont(undefined, "normal");
        doc.text(`TecnoAgro${orgName ? " \u00b7 " + orgName : ""}`, ML, H - 9);
        doc.text(`P\u00e1gina ${i} de ${pageCount}`, W / 2, H - 9, { align: "center" });
        doc.text(fechaInforme, W - MR, H - 9, { align: "right" });
        // Green accent line at bottom
        doc.setDrawColor(16, 185, 129);
        doc.setLineWidth(0.6);
        doc.line(ML, H - 5, W - MR, H - 5);
        doc.setLineWidth(0);
        doc.setTextColor(0, 0, 0);
      }

      doc.save(`comparacion_nutricional_${loteNombre.replace(/[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ ]/g, "").trim()}_${now.toISOString().slice(0, 10)}.pdf`);
    }

    async function loadSnapshotInto(slotId, commonAnalysisId){
      // Snapshot RGB del lote: opcional. Sin imagen, el placeholder queda intacto.
      if(!commonAnalysisId) return;
      const slot = document.getElementById(slotId);
      if(!slot) return;
      try{
        const res = await fetch(ENDPOINTS.lotSnapshot.replace("0", String(commonAnalysisId)), { credentials: "include" });
        if(!res.ok) return;
        const body = await res.json().catch(() => null);
        if(!body || !body.url) return;
        const img = document.createElement("img");
        img.src = body.url;
        img.alt = "Recorte del lote sobre la ortofoto";
        img.className = "h-24 w-full rounded-lg object-cover";
        img.setAttribute("data-lightbox", "");
        img.onerror = () => { img.remove(); };
        slot.classList.remove("bg-slate-300");
        slot.textContent = "";
        slot.appendChild(img);
      }catch(_e){ /* silencioso */ }
    }

    function loadSnapshotImages(p){
      if(!p) return;
      if(p.mode === "lot_vs_lot"){
        loadSnapshotInto("analysisLotImageSlot", p.lot_b?.linked_common_analysis_id);
        loadSnapshotInto("referenceImageSlot", p.lot_a?.linked_common_analysis_id);
      }else{
        loadSnapshotInto("analysisLotImageSlot", p.common_analysis_id);
      }
    }

    async function init(){
      try{
        payload = parseTokenPayload();
        if(!payload){
          throw new Error("No se encontró la comparación seleccionada. Vuelve al mapa y reintenta.");
        }
        if(payload.mode === "lot_vs_lot"){
          el.modeBadge.textContent = "Modo: Lote vs lote";
          el.referenceCardBadge.textContent = "Lote A";
          await setupLotVsLot(payload);
          await fetchCvValues(payload.lot_b?.linked_lot_id);
        }else{
          const objectiveKind = payload.objective?.type === "secondary" ? "secondary" : "crop";
          el.modeBadge.textContent = objectiveKind === "secondary"
            ? "Modo: Lote vs objetivo secundario"
            : "Modo: Lote vs objetivo ideal";
          el.referenceCardBadge.textContent = objectiveKind === "secondary" ? "Objetivo secundario" : "Objetivo ideal";
          await setupLotVsObjective(payload);
          await fetchCvValues(payload.lot_id);
        }
        renderAnalysisInfo(analysisData);
        loadSnapshotImages(payload);
        renderCvInfo();
        computeMinimumLaw();
        computeMineralBalance();
      }catch(err){
        console.error(err);
        showError(err?.message || "No se pudo cargar la comparación.");
      }
    }

    if(el.exportPdfBtn){
      el.exportPdfBtn.addEventListener("click", exportPdf);
    }
    let proteinEditDebounce = null;
    function resetProteinEditor(){
      editedProtein = null;
      if(el.balanceProteinEditToggle) el.balanceProteinEditToggle.checked = false;
      if(el.balanceProteinObjInput) el.balanceProteinObjInput.classList.add("hidden");
      if(el.balanceProteinObj) el.balanceProteinObj.classList.remove("hidden");
    }
    if(el.balanceProteinEditToggle && el.balanceProteinObjInput && el.balanceProteinObj){
      el.balanceProteinEditToggle.addEventListener("change", () => {
        const editing = el.balanceProteinEditToggle.checked;
        el.balanceProteinObj.classList.toggle("hidden", editing);
        el.balanceProteinObjInput.classList.toggle("hidden", !editing);
        if(editing){
          const current = editedProtein != null ? editedProtein : referenceProtein;
          el.balanceProteinObjInput.value = current != null ? current : "";
          el.balanceProteinObjInput.focus();
        }else if(editedProtein == null){
          // Edición cancelada sin valor válido: recalcular con la referencia
          computeMineralBalance();
        }
      });
      el.balanceProteinObjInput.addEventListener("input", () => {
        const value = parseFloat(el.balanceProteinObjInput.value);
        editedProtein = Number.isFinite(value) && value > 0 ? value : null;
        setText(el.balanceProteinObj, editedProtein != null ? formatNumber(editedProtein, 2) : "--");
        // El backend deriva los objetivos desde la proteína y recalcula
        clearTimeout(proteinEditDebounce);
        proteinEditDebounce = setTimeout(computeMineralBalance, 400);
      });
    }
    if(el.saveReportBtn){
      el.saveReportBtn.addEventListener("click", handleSaveReport);
    }

    function showPreviewModal(){
      if(!el.previewModal) return;
      // Build diagnosis text
      const entries = nutrientOrder.map(n => {
        const act = actualValues[n];
        const targ = targetValues[n];
        if(act == null || targ == null) return null;
        const p = (act / targ) * 100;
        const deficit = targ - act;
        return { name: n, act, targ, p, deficit };
      }).filter(Boolean);

      if(entries.length === 0){
        el.previewDiagnosis.innerHTML = '<p class="text-gray-500">No hay datos suficientes para generar un diagnóstico.</p>';
        el.previewTable.innerHTML = '';
        el.previewProducts.innerHTML = '';
        el.previewCost.innerHTML = '';
        el.previewWarnings.innerHTML = '';
        renderPreviewBalance();
        selectPreviewTab("diagnosis");
        el.previewModal.classList.remove("hidden");
        return;
      }

      entries.sort((a, b) => a.p - b.p);
      const limiting = entries[0];
      const deficient = entries.filter(e => e.p < 88);
      const optimal = entries.filter(e => e.p >= 88 && e.p <= 108);
      const excess = entries.filter(e => e.p > 108);

      // Diagnosis summary
      let diagnosisHtml = `
        <p class="font-semibold mb-2">Nutriente limitante: <span class="text-red-600">${limiting.name}</span> (${limiting.p.toFixed(1)}% del nivel ideal)</p>
        <div class="grid grid-cols-3 gap-2 text-xs mb-3">
          <div class="rounded bg-red-50 dark:bg-red-900/20 p-2"><span class="font-medium text-red-700 dark:text-red-400">Deficientes:</span> ${deficient.length}</div>
          <div class="rounded bg-green-50 dark:bg-green-900/20 p-2"><span class="font-medium text-green-700 dark:text-green-400">Óptimos:</span> ${optimal.length}</div>
          <div class="rounded bg-orange-50 dark:bg-orange-900/20 p-2"><span class="font-medium text-orange-700 dark:text-orange-400">Exceso:</span> ${excess.length}</div>
        </div>
      `;
      el.previewDiagnosis.innerHTML = diagnosisHtml;

      // Deficit table
      let tableHtml = '<table class="min-w-full divide-y divide-gray-200 text-xs"><thead class="bg-gray-50"><tr>';
      tableHtml += '<th class="px-3 py-2 text-left font-semibold text-gray-600">Nutriente</th>';
      tableHtml += '<th class="px-3 py-2 text-right font-semibold text-gray-600">Actual</th>';
      tableHtml += '<th class="px-3 py-2 text-right font-semibold text-gray-600">Ideal</th>';
      tableHtml += '<th class="px-3 py-2 text-right font-semibold text-gray-600">Déficit</th>';
      tableHtml += '<th class="px-3 py-2 text-right font-semibold text-gray-600">% Suficiencia</th>';
      tableHtml += '</tr></thead><tbody class="divide-y divide-gray-100 bg-white">';
      entries.forEach(e => {
        const rowClass = e.p < 88 ? 'bg-red-50' : (e.p > 108 ? 'bg-orange-50' : '');
        tableHtml += `<tr class="${rowClass}">`;
        tableHtml += `<td class="px-3 py-2 font-medium text-gray-800">${e.name}</td>`;
        tableHtml += `<td class="px-3 py-2 text-right">${formatNumber(e.act, 2)}</td>`;
        tableHtml += `<td class="px-3 py-2 text-right">${formatNumber(e.targ, 2)}</td>`;
        tableHtml += `<td class="px-3 py-2 text-right ${e.deficit > 0 ? 'text-red-600' : 'text-green-600'}">${formatNumber(e.deficit, 2)}</td>`;
        tableHtml += `<td class="px-3 py-2 text-right ${e.p < 88 ? 'text-red-600 font-semibold' : ''}">${e.p.toFixed(1)}%</td>`;
        tableHtml += '</tr>';
      });
      tableHtml += '</tbody></table>';
      el.previewTable.innerHTML = tableHtml;

      // Products note
      el.previewProducts.innerHTML = `
        <p class="text-gray-500 dark:text-gray-400 italic">
          Los productos recomendados se calcularán al guardar el informe usando el optimizador de costos.
          El sistema seleccionará la combinación más económica que cubra los déficits mostrados arriba.
        </p>
      `;

      // Warnings
      const warnings = [];
      if(deficient.length > 5) warnings.push(`Hay ${deficient.length} nutrientes deficientes — considere revisar el plan de fertilización completo.`);
      if(limiting.p < 30) warnings.push(`El nutriente limitante (${limiting.name}) está muy por debajo del nivel ideal. Puede requerir aplicaciones escalonadas.`);
      if(excess.length > 0) warnings.push(`Nutrientes en exceso: ${excess.map(e => e.name).join(", ")}. No aplicar adicionalmente.`);
      el.previewWarnings.innerHTML = warnings.length > 0
        ? '<div class="space-y-1">' + warnings.map(w => `<p>⚠ ${w}</p>`).join('') + '</div>'
        : '';

      el.previewCost.innerHTML = '';
      renderPreviewBalance();
      selectPreviewTab("diagnosis");
      el.previewModal.classList.remove("hidden");
    }

    function hidePreviewModal(){
      if(el.previewModal) el.previewModal.classList.add("hidden");
    }

    // ---- Tabs del modal de vista previa (Diagnóstico | Balance) ----
    // Estilo botón: activo = sólido esmeralda, inactivo = blanco con borde
    function setPreviewTabActive(button, active){
      if(!button) return;
      button.classList.toggle("border-emerald-600", active);
      button.classList.toggle("bg-emerald-600", active);
      button.classList.toggle("text-white", active);
      button.classList.toggle("border-gray-200", !active);
      button.classList.toggle("bg-white", !active);
      button.classList.toggle("text-gray-700", !active);
      button.classList.toggle("hover:bg-gray-50", !active);
      button.setAttribute("aria-selected", active ? "true" : "false");
    }

    function selectPreviewTab(tab){
      const isBalance = tab === "balance";
      if(el.previewPanelDiagnosis) el.previewPanelDiagnosis.classList.toggle("hidden", isBalance);
      if(el.previewPanelBalance) el.previewPanelBalance.classList.toggle("hidden", !isBalance);
      setPreviewTabActive(el.previewTabDiagnosis, !isBalance);
      setPreviewTabActive(el.previewTabBalance, isBalance);
    }

    // Copia de solo lectura del Balance de Minerales ya ajustado
    // (incluye derivaciones por proteína editada si las hubo)
    function renderPreviewBalance(){
      if(!el.previewBalanceTable) return;
      const sourceTable = el.balanceTableBody ? el.balanceTableBody.closest("table") : null;
      el.previewBalanceTable.innerHTML = "";
      if(sourceTable && el.balanceTableBody.children.length){
        el.previewBalanceTable.appendChild(sourceTable.cloneNode(true));
      }else{
        el.previewBalanceTable.innerHTML = '<p class="text-sm text-gray-500">Sin datos de balance disponibles.</p>';
      }
      if(el.previewBalanceMeta){
        const read = node => node?.textContent?.trim() || "--";
        const cells = [
          ["Proteína objetivo", read(el.balanceProteinObj), "bg-gray-100"],
          ["Aforo objetivo", read(el.balanceAforoObj), "bg-gray-100"],
          ["Proteína actual", read(el.balanceProteinAct), "bg-gray-200"],
          ["Aforo actual", read(el.balanceAforoAct), "bg-gray-200"],
        ];
        el.previewBalanceMeta.innerHTML = cells.map(([label, value, bg]) => `
          <div class="${bg} px-3 py-2">
            <dt class="text-[11px] uppercase tracking-wide text-gray-500">${label}</dt>
            <dd class="mt-1 text-sm font-semibold text-gray-900">${value}</dd>
          </div>
        `).join("");
      }
    }

    if(el.previewTabDiagnosis){
      el.previewTabDiagnosis.addEventListener("click", () => selectPreviewTab("diagnosis"));
    }
    if(el.previewTabBalance){
      el.previewTabBalance.addEventListener("click", () => selectPreviewTab("balance"));
    }

    if(el.previewReportBtn){
      el.previewReportBtn.addEventListener("click", showPreviewModal);
    }
    if(el.previewModalClose){
      el.previewModalClose.addEventListener("click", hidePreviewModal);
    }
    if(el.previewModalCloseBtn){
      el.previewModalCloseBtn.addEventListener("click", hidePreviewModal);
    }
    if(el.previewSaveBtn){
      el.previewSaveBtn.addEventListener("click", () => {
        hidePreviewModal();
        handleSaveReport();
      });
    }

    // --- Reference change modal (C-ref) ---
    let refCropObjectives = [];
    let refSecondaryObjectives = [];

    async function loadReferenceOptions(){
      refCropObjectives = [];
      refSecondaryObjectives = [];
      // Load crop objectives
      try{
        const allObjectives = await fetchJson("{{ url_for('foliage_api.objectives') }}");
        // Filter unique by crop_id
        const seen = new Set();
        for(const obj of allObjectives){
          if(!obj || seen.has(obj.crop_id)) continue;
          seen.add(obj.crop_id);
          refCropObjectives.push(obj);
        }
      }catch(err){
        console.error("Failed to load crop objectives:", err);
      }
      // Load secondary objectives
      try{
        refSecondaryObjectives = await fetchJson(ENDPOINTS.secondaryObjectivesList);
        if(!Array.isArray(refSecondaryObjectives)) refSecondaryObjectives = [];
      }catch(err){
        console.error("Failed to load secondary objectives:", err);
      }
      // Populate selects
      if(el.refModalCropObjective){
        const opts = ['<option value="">Selecciona un objetivo de cultivo...</option>'];
        refCropObjectives.forEach(obj => {
          opts.push(`<option value="crop:${obj.id}">${obj.crop_name || "Cultivo"} · ID ${obj.id} · Target ${obj.target_value ?? "-"}</option>`);
        });
        el.refModalCropObjective.innerHTML = opts.join("");
      }
      if(el.refModalSecondaryObjective){
        const opts = ['<option value="">Selecciona un objetivo secundario...</option>'];
        refSecondaryObjectives.forEach(obj => {
          const cropName = obj?.analysis_crop?.name || `Objetivo ${obj?.id}`;
          opts.push(`<option value="secondary:${obj.id}">${cropName} · Secundario #${obj?.id ?? ""}</option>`);
        });
        el.refModalSecondaryObjective.innerHTML = opts.join("");
      }
      // If no objectives loaded, show a hint
      if(refCropObjectives.length === 0 && refSecondaryObjectives.length === 0){
        if(el.referenceModalError){
          el.referenceModalError.textContent = "No se encontraron objetivos configurados. Configure objetivos de cultivo primero.";
          el.referenceModalError.classList.remove("hidden");
        }
      }
    }

    function showReferenceModal(){
      if(!el.referenceModal) return;
      el.referenceModalError.classList.add("hidden");
      if(el.refModalCropObjective) el.refModalCropObjective.value = "";
      if(el.refModalSecondaryObjective) el.refModalSecondaryObjective.value = "";
      if(el.referenceModalApply) el.referenceModalApply.disabled = true;
      loadReferenceOptions();
      el.referenceModal.classList.remove("hidden");
    }

    function hideReferenceModal(){
      if(el.referenceModal) el.referenceModal.classList.add("hidden");
    }

    async function applyNewReference(valueStr){
      if(!valueStr) return;
      const [type, idStr] = valueStr.split(":");
      const objectiveId = Number(idStr);
      if(!objectiveId) return;

      hideReferenceModal();
      const kind = type === "secondary" ? "secondary" : "crop";

      // Update payload
      payload.objective = {
        type: kind,
        id: objectiveId,
        label: kind === "secondary"
          ? (el.refModalSecondaryObjective?.options[el.refModalSecondaryObjective.selectedIndex]?.textContent || "").trim()
          : (el.refModalCropObjective?.options[el.refModalCropObjective.selectedIndex]?.textContent || "").trim(),
      };

      // Re-run setup
      try{
        await setupLotVsObjective(payload);
        await fetchCvValues(payload.lot_id);
        renderAnalysisInfo(analysisData);
        renderCvInfo();
        computeMinimumLaw();
        resetProteinEditor();
        computeMineralBalance();
        // Update badge
        el.modeBadge.textContent = kind === "secondary"
          ? "Modo: Lote vs objetivo secundario"
          : "Modo: Lote vs objetivo ideal";
        el.referenceCardBadge.textContent = kind === "secondary" ? "Objetivo secundario" : "Objetivo ideal";
      }catch(err){
        console.error(err);
        showError(err?.message || "No se pudo cargar la nueva referencia.");
      }
    }

    if(el.changeReferenceBtn){
      el.changeReferenceBtn.addEventListener("click", showReferenceModal);
    }
    if(el.referenceModalClose){
      el.referenceModalClose.addEventListener("click", hideReferenceModal);
    }
    if(el.referenceModalCancel){
      el.referenceModalCancel.addEventListener("click", hideReferenceModal);
    }
    // Enable apply button when a selection is made
    function updateRefApplyState(){
      const cropVal = el.refModalCropObjective?.value || "";
      const secVal = el.refModalSecondaryObjective?.value || "";
      if(el.referenceModalApply){
        el.referenceModalApply.disabled = !(cropVal || secVal);
      }
      // Deselect the other when one is chosen
      if(cropVal && el.refModalSecondaryObjective){
        el.refModalSecondaryObjective.value = "";
      }
      if(secVal && el.refModalCropObjective){
        el.refModalCropObjective.value = "";
      }
    }
    if(el.refModalCropObjective){
      el.refModalCropObjective.addEventListener("change", updateRefApplyState);
    }
    if(el.refModalSecondaryObjective){
      el.refModalSecondaryObjective.addEventListener("change", updateRefApplyState);
    }
    if(el.referenceModalApply){
      el.referenceModalApply.addEventListener("click", () => {
        const cropVal = el.refModalCropObjective?.value || "";
        const secVal = el.refModalSecondaryObjective?.value || "";
        applyNewReference(cropVal || secVal);
      });
    }
    // Close modal on backdrop click
    if(el.referenceModal){
      el.referenceModal.addEventListener("click", (e) => {
        if(e.target === el.referenceModal) hideReferenceModal();
      });
    }

    init();
  })();
</script>
{% endblock %}
