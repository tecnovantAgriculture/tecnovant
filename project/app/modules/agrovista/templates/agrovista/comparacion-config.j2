      try{
        cvData = await fetchJson(`${ENDPOINTS.cv}?lot_id=${lotId}`);
      }catch(err){
        console.error("cv", err);
        cvData = {};
      }
    }

    async function handleSaveReport(){
      if(!analysisData){
        showError("No se pudo cargar la información del análisis.");
        return;
      }
      if(!payload){
        showError("No se encontró el contexto de la comparación.");
        return;
      }
      let objectiveId = payload.objective?.id || payload.objective_id;
      let lotId = payload.lot_id;
      let title = "Comparación nutricional";
      if(payload.mode === "lot_vs_lot"){
        const lotB = payload.lot_b;
        lotId = lotB?.linked_lot_id;
        title = `Comparación nutricional · ${lotB?.linked_lot_name || lotB?.name || "Lote"}`;
        const cropId = resolveCropIdForLot(lotId);
        if(!cropId){
          showError("No se encontró el cultivo asociado al lote B.");
          return;
        }
        try{
          objectiveId = await createObjectiveFromStats(payload.lot_a?.area_stats, cropId);
        }catch(err){
          showError(err?.message || "No se pudo crear el objetivo ideal.");
          return;
        }
      }else if(payload.objective?.type === "secondary"){
        await fetchLotCrops();
        const cropId = resolveCropIdForLot(lotId);
        if(!cropId){
          showError("No se encontró el cultivo asociado al lote.");
          return;
        }
        try{
          objectiveId = await createObjectiveFromSecondary(objectiveData, cropId);
        }catch(err){
          showError(err?.message || "No se pudo crear el objetivo ideal.");
          return;
        }
      }
      if(!objectiveId){
        showError("No se encontró el objetivo ideal para generar el informe.");
        return;
      }
      const payloadReport = {
        lot_id: Number(lotId),
        common_analysis_id: Number(analysisData.id),
        objective_id: Number(objectiveId),
        title,
        minimum_law_analyses: JSON.stringify(minimumLawPayload),
      };
      const csrf = getCsrfToken();
      el.saveReportBtn.disabled = true;
      el.saveReportBtn.textContent = "Generando...";
      try{
        const res = await fetch(ENDPOINTS.generateReport, {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-TOKEN": csrf || "",
          },
          body: JSON.stringify(payloadReport),
        });
        const body = await res.json().catch(() => ({}));
        if(!res.ok || !body?.report_id){
          const message = body?.error || body?.message || body?.description || "No se pudo generar el reporte.";
          throw new Error(message);
        }
        window.location.href = ENDPOINTS.reportView.replace("0", body.report_id);
      }catch(err){
        showError(err?.message || "Error al generar el reporte.");
      }finally{
        el.saveReportBtn.disabled = false;
        el.saveReportBtn.textContent = "Guardar como informe";
      }
    }

    async function createObjectiveFromStats(areaStats, cropId){
      if(!areaStats || !Array.isArray(areaStats.nutrients) || !cropId){
        throw new Error("No se encontraron datos del lote A para crear el objetivo.");
      }
      const payloadObjective = {
        crop_id: Number(cropId),
        target_value: 0,
      };
      areaStats.nutrients.forEach(item => {
        const nutrientId = item?.nutrient_id;
        const value = parseFloat(item?.target_value);
        if(!nutrientId || !Number.isFinite(value)){
          return;
        }
        payloadObjective[`nutrient_${nutrientId}`] = value;
      });
      const csrf = getCsrfToken();
      const res = await fetch("{{ url_for('foliage_api.objectives') }}", {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-TOKEN": csrf || "",
        },
        body: JSON.stringify(payloadObjective),
      });
      const body = await res.json().catch(() => ({}));
      if(!res.ok){
        const message = body?.description || body?.error || "No se pudo crear el objetivo.";
        throw new Error(message);
      }
      return body.id || body?.data?.id;
    }

