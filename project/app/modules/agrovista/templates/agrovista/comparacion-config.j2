      const payloadObjective = {
        crop_id: Number(cropId),
        target_value: 0,
      };
      secondaryObjective.nutrient_targets.forEach(item => {
        const nutrientId = item?.nutrient_id;
        const value = parseFloat(item?.target_value);
        if(!nutrientId || !Number.isFinite(value)){
          return;
        }
        payloadObjective[`nutrient_${nutrientId}`] = value;
      });
      const csrf = getCsrfToken();
      const res = await fetch("{{ url_for('foliage_api.objectives') }}", {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-TOKEN": csrf || "",
        },
        body: JSON.stringify(payloadObjective),
      });
      const body = await res.json().catch(() => ({}));
      if(!res.ok){
        const message = body?.description || body?.error || "No se pudo crear el objetivo.";
        throw new Error(message);
      }
      return body.id || body?.data?.id;
    }

    function exportPdf(){
      const { jsPDF } = window.jspdf || {};
      if(!jsPDF){
        showError("No se pudo cargar el exportador PDF.");
        return;
      }

      const doc = new jsPDF("p", "mm", "a4");
      const W = doc.internal.pageSize.getWidth();   // 210
      const H = doc.internal.pageSize.getHeight();   // 297
      const ML = 16;  // margin left
      const MR = 16;  // margin right
      const CW = W - ML - MR;  // content width
      let y = 16;

      // ---- helpers ----
      const checkPage = (needed) => { if(y + needed > H - 20){ doc.addPage(); y = 20; } };
      const drawLine = () => {
        doc.setDrawColor(229, 231, 235);
        doc.line(ML, y, W - MR, y);
        y += 3;
      };
      const drawField = (label, value, indent = ML) => {
        if(!value || value === "--" || value === "") return;
        doc.setFontSize(8);
        doc.setFont(undefined, "normal");
        doc.setTextColor(107, 114, 128);  // gray-500
        doc.text(`${label}:`, indent, y);
        const labelW = doc.getTextWidth(`${label}:  `);
        doc.setTextColor(17, 24, 39);  // gray-900
        doc.setFont(undefined, "bold");
        doc.text(String(value), indent + labelW, y);
        doc.setTextColor(107, 114, 128);
        doc.setFont(undefined, "normal");
        y += 5;
      };

      // ---- header ----
      doc.setFillColor(16, 185, 129);  // emerald-600
      doc.rect(0, 0, W, 36, "F");
      doc.setTextColor(255, 255, 255);
      doc.setFontSize(16);
      doc.setFont(undefined, "bold");
      doc.text("Comparación nutricional", ML, 18);
      doc.setFontSize(8);
      doc.setFont(undefined, "normal");
      const now = new Date();
      const fechaInforme = now.toLocaleDateString("es-CO", { day: "2-digit", month: "long", year: "numeric" });
      const horaInforme = now.toLocaleTimeString("es-CO", { hour: "2-digit", minute: "2-digit" });
      doc.text(`Informe generado: ${fechaInforme} – ${horaInforme}`, W - MR, 18, { align: "right" });
      // Subtitle
      doc.setFontSize(9);
      const modeText = payload?.mode === "lot_vs_lot" ? "Lote vs Lote" : "Lote vs Objetivo";
      doc.text(modeText, ML, 30);
      doc.setTextColor(200, 200, 200);
      doc.text(`TecnoAgro · ${now.getFullYear()}`, W - MR, 30, { align: "right" });
      doc.setTextColor(0, 0, 0);
      y = 42;

      // ---- Section: Identificación ----
      checkPage(50);
      doc.setFontSize(12);
      doc.setFont(undefined, "bold");
      doc.setTextColor(16, 185, 129);
      doc.text("Identificación", ML, y);
      y += 8;
      doc.setTextColor(0, 0, 0);

      // Use stored metadata (populated during page load)
      const finca = currentAnalysisMeta.farmName || "--";
      const loteNombre = currentAnalysisMeta.lotName || el.analysisLotName?.textContent?.trim() || "--";
      const area = currentAnalysisMeta.area || el.analysisLotArea?.textContent?.trim() || "--";
      const cultivo = currentAnalysisMeta.cropName || el.analysisLotCrop?.textContent?.trim() || "--";
      const fechaAnalisis = currentAnalysisMeta.analysisDate || el.analysisLotDate?.textContent?.trim() || "--";
      const refObjetivo = el.referenceName?.textContent?.trim() || "--";
      const refFuente = el.referenceSource?.textContent?.trim() || "--";
      const refTipo = el.referenceType?.textContent?.trim() || "--";
      const autor = currentAnalysisMeta.username || "Sistema";

      drawField("Finca", finca);
      drawField("Lote", loteNombre);
      drawField("Área", area);
      drawField("Cultivo", cultivo);
      drawField("Fecha de análisis", fechaAnalisis);
      y += 2;
      drawLine();
      drawField("Referencia", refObjetivo);
      drawField("Fuente", refFuente);
      drawField("Tipo", refTipo);
      y += 2;
      drawLine();
      drawField("Autor del informe", autor);
      if(currentAnalysisMeta.orgName){
        drawField("Organización", currentAnalysisMeta.orgName);
      }
      y += 4;

      // ---- Section: Índices vegetacionales ----
      checkPage(25);
      doc.setFontSize(12);
      doc.setFont(undefined, "bold");
      doc.setTextColor(16, 185, 129);
      doc.text("Índices vegetacionales", ML, y);
      y += 8;
      doc.setTextColor(0, 0, 0);

      const ndvi = el.analysisNdvi?.textContent?.trim() || "--";
      const vari = el.analysisVari?.textContent?.trim() || "--";
      const nbi = el.analysisNbi?.textContent?.trim() || "--";
      const refNdvi = el.referenceNdvi?.textContent?.trim() || "--";
      const refVari = el.referenceVari?.textContent?.trim() || "--";
      const refNbi = el.referenceNbi?.textContent?.trim() || "--";

      // Two columns
      const colMid = ML + CW / 2;
      doc.setFontSize(8);
      doc.setFont(undefined, "bold");
      doc.text("Lote analizado", ML, y);
      doc.text("Referencia", colMid, y);
      y += 5;
      doc.setFont(undefined, "normal");
      drawField("NDVI", ndvi);
      doc.setTextColor(17, 24, 39);
      doc.text(String(refNdvi), colMid + 2, y - 5);
      doc.setTextColor(107, 114, 128);
      drawField("VARI", vari);
      doc.setTextColor(17, 24, 39);
      doc.text(String(refVari), colMid + 2, y - 5);
      doc.setTextColor(107, 114, 128);
      drawField("NBI", nbi);
      doc.setTextColor(17, 24, 39);
      doc.text(String(refNbi), colMid + 2, y - 5);
      doc.setTextColor(107, 114, 128);
      y += 2;
      drawLine();

      // ---- Section: Resumen de brechas ----
      checkPage(20);
      doc.setFontSize(12);
      doc.setFont(undefined, "bold");
      doc.setTextColor(16, 185, 129);
      doc.text("Resumen de brechas", ML, y);
      y += 8;
      doc.setTextColor(0, 0, 0);

      const limitante = el.limitingNutrient?.textContent?.trim() || "--";
      const optimos = el.optimalNutrients?.textContent?.trim() || "--";
      const exceso = el.excessNutrients?.textContent?.trim() || "--";

      drawField("Nutriente limitante", limitante);
      drawField("Nutrientes en rango óptimo", optimos);
      drawField("Nutrientes en exceso", exceso);
      y += 2;
      drawLine();

      // ---- Section: Ley de Mínimos ----
      checkPage(30);
      doc.setFontSize(12);
      doc.setFont(undefined, "bold");
      doc.setTextColor(16, 185, 129);
      doc.text("Tabla de Cálculos – Ley de Mínimos", ML, y);
      y += 3;
      doc.setFontSize(7);
      doc.setFont(undefined, "normal");
      doc.setTextColor(107, 114, 128);
      doc.text("Valores expresados en porcentaje respecto al objetivo ideal", ML, y);
      y += 5;
      doc.setTextColor(0, 0, 0);

      const tableBody = el.lawTableBody;
      const tableHeaders = el.lawTableHeader?.querySelectorAll("th");
      if(!tableBody || !tableHeaders || tableHeaders.length < 2){
        doc.setFontSize(9);
        doc.text("Sin datos disponibles.", ML, y);
        y += 6;
      }else{
        const colNames = [];
        for(let i = 1; i < tableHeaders.length; i++){
          colNames.push(tableHeaders[i].textContent.trim());
        }
        const rows = [];
        tableBody.querySelectorAll("tr").forEach(tr => {
          const cells = tr.querySelectorAll("td");
          const rowData = [];
          cells.forEach(td => rowData.push(td.textContent.trim()));
          rows.push(rowData);
        });

        const nCols = colNames.length;
        const colW = CW / (nCols + 1);
        const rowH = 6;

        // Header
        doc.setFontSize(7);
        doc.setFont(undefined, "bold");
        doc.setFillColor(243, 244, 246);
        doc.rect(ML, y, CW, rowH, "F");
        doc.setTextColor(55, 65, 81);
        doc.text("Fila", ML + 1, y + rowH - 2);
        colNames.forEach((name, i) => {
          doc.text(name, ML + colW * (i + 1) + 1, y + rowH - 2);
        });
        doc.setTextColor(0, 0, 0);
        y += rowH;

        // Rows
        rows.forEach((rowData, ri) => {
          checkPage(rowH + 4);
          if(ri % 2 === 0){
            doc.setFillColor(249, 250, 251);
            doc.rect(ML, y, CW, rowH, "F");
          }
          const label = rowData[0] || "";
          if(label.includes("Déficit") || label.includes("Diferencia")){
            doc.setFont(undefined, "bold");
          }else{
            doc.setFont(undefined, "normal");
          }
          doc.text(label, ML + 1, y + rowH - 2);
          rowData.slice(1).forEach((val, ci) => {
            if(val === "—") return;
            const num = parseFloat(val);
            const display = isNaN(num) ? val : num.toFixed(2);
            if(label === "%P"){
              if(num < 88) doc.setTextColor(220, 38, 38);
              else if(num > 108) doc.setTextColor(234, 88, 12);
              else doc.setTextColor(22, 163, 74);
            }else if(label === "Diferencia"){
              if(num < 0) doc.setTextColor(220, 38, 38);
              else if(num > 0) doc.setTextColor(234, 88, 12);
              else doc.setTextColor(0, 0, 0);
            }else{
              doc.setTextColor(0, 0, 0);
            }
            doc.text(display, ML + colW * (ci + 1) + 1, y + rowH - 2);
          });
          doc.setTextColor(0, 0, 0);
          y += rowH;
        });
      }
      y += 4;

      // ---- Note ----
      checkPage(20);
      doc.setFontSize(7);
      doc.setFont(undefined, "italic");
      doc.setTextColor(107, 114, 128);
      const note = "El nutriente limitante principal es aquel con mayor déficit porcentual. " +
                   "La recomendación de formulación se calculará tomando como base dicho nutriente y " +
                   "ajustando el resto de aportes para mantener los rangos óptimos.";
      const noteLines = doc.splitTextToSize(note, CW);
      doc.text(noteLines, ML, y);
      y += noteLines.length * 4 + 4;

      // ---- Signature block ----
      checkPage(30);
      drawLine();
      y += 10;
      doc.setFontSize(8);
      doc.setFont(undefined, "normal");
      doc.setTextColor(55, 65, 81);
      const sigY = y + 20;
      doc.setDrawColor(107, 114, 128);
      doc.line(ML, sigY, ML + 60, sigY);
      doc.text("Firma del responsable", ML, sigY + 5);
      doc.line(ML + 80, sigY, ML + 140, sigY);
      doc.text("Vo.Bo. Agrónomo", ML + 80, sigY + 5);

      // ---- Footer ----
      const pageCount = doc.internal.getNumberOfPages();
      for(let i = 1; i <= pageCount; i++){
        doc.setPage(i);
        doc.setFontSize(7);
        doc.setTextColor(156, 163, 175);
        doc.text(
          `Comparación nutricional · Página ${i} de ${pageCount}`,
          W / 2, H - 10, { align: "center" }
        );
        doc.setTextColor(0, 0, 0);
      }

      doc.save(`comparacion_nutricional_${loteNombre.replace(/[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ ]/g, "").trim()}_${now.toISOString().slice(0, 10)}.pdf`);
    }

    async function init(){
      try{
        payload = parseTokenPayload();
        if(!payload){
          throw new Error("No se encontró la comparación seleccionada. Vuelve al mapa y reintenta.");
        }
        if(payload.mode === "lot_vs_lot"){
          el.modeBadge.textContent = "Modo: Lote vs lote";
          el.referenceCardBadge.textContent = "Lote A";
          await setupLotVsLot(payload);
          await fetchCvValues(payload.lot_b?.linked_lot_id);
        }else{
          const objectiveKind = payload.objective?.type === "secondary" ? "secondary" : "crop";
          el.modeBadge.textContent = objectiveKind === "secondary"
            ? "Modo: Lote vs objetivo secundario"
            : "Modo: Lote vs objetivo ideal";
          el.referenceCardBadge.textContent = objectiveKind === "secondary" ? "Objetivo secundario" : "Objetivo ideal";
          await setupLotVsObjective(payload);
          await fetchCvValues(payload.lot_id);
        }
        renderAnalysisInfo(analysisData);
        renderCvInfo();
        computeMinimumLaw();
      }catch(err){
        console.error(err);
        showError(err?.message || "No se pudo cargar la comparación.");
      }
    }

    if(el.exportPdfBtn){
      el.exportPdfBtn.addEventListener("click", exportPdf);
    }
    if(el.saveReportBtn){
      el.saveReportBtn.addEventListener("click", handleSaveReport);
    }

    function showPreviewModal(){
      if(!el.previewModal) return;
      // Build diagnosis text
      const entries = nutrientOrder.map(n => {
        const act = actualValues[n];
        const targ = targetValues[n];
        if(act == null || targ == null) return null;
        const p = (act / targ) * 100;
        const deficit = targ - act;
        return { name: n, act, targ, p, deficit };
      }).filter(Boolean);

      if(entries.length === 0){
        el.previewDiagnosis.innerHTML = '<p class="text-gray-500">No hay datos suficientes para generar un diagnóstico.</p>';
        el.previewTable.innerHTML = '';
        el.previewProducts.innerHTML = '';
        el.previewCost.innerHTML = '';
        el.previewWarnings.innerHTML = '';
        el.previewModal.classList.remove("hidden");
        return;
      }

      entries.sort((a, b) => a.p - b.p);
      const limiting = entries[0];
      const deficient = entries.filter(e => e.p < 88);
      const optimal = entries.filter(e => e.p >= 88 && e.p <= 108);
      const excess = entries.filter(e => e.p > 108);

      // Diagnosis summary
      let diagnosisHtml = `
        <p class="font-semibold mb-2">Nutriente limitante: <span class="text-red-600">${limiting.name}</span> (${limiting.p.toFixed(1)}% del nivel ideal)</p>
        <div class="grid grid-cols-3 gap-2 text-xs mb-3">
          <div class="rounded bg-red-50 dark:bg-red-900/20 p-2"><span class="font-medium text-red-700 dark:text-red-400">Deficientes:</span> ${deficient.length}</div>
          <div class="rounded bg-green-50 dark:bg-green-900/20 p-2"><span class="font-medium text-green-700 dark:text-green-400">Óptimos:</span> ${optimal.length}</div>
          <div class="rounded bg-orange-50 dark:bg-orange-900/20 p-2"><span class="font-medium text-orange-700 dark:text-orange-400">Exceso:</span> ${excess.length}</div>
        </div>
      `;
      el.previewDiagnosis.innerHTML = diagnosisHtml;

      // Deficit table
      let tableHtml = '<table class="min-w-full divide-y divide-gray-200 text-xs"><thead class="bg-gray-50"><tr>';
      tableHtml += '<th class="px-3 py-2 text-left font-semibold text-gray-600">Nutriente</th>';
      tableHtml += '<th class="px-3 py-2 text-right font-semibold text-gray-600">Actual</th>';
      tableHtml += '<th class="px-3 py-2 text-right font-semibold text-gray-600">Ideal</th>';
      tableHtml += '<th class="px-3 py-2 text-right font-semibold text-gray-600">Déficit</th>';
      tableHtml += '<th class="px-3 py-2 text-right font-semibold text-gray-600">% Suficiencia</th>';
      tableHtml += '</tr></thead><tbody class="divide-y divide-gray-100 bg-white">';
      entries.forEach(e => {
        const rowClass = e.p < 88 ? 'bg-red-50' : (e.p > 108 ? 'bg-orange-50' : '');
        tableHtml += `<tr class="${rowClass}">`;
        tableHtml += `<td class="px-3 py-2 font-medium text-gray-800">${e.name}</td>`;
        tableHtml += `<td class="px-3 py-2 text-right">${formatNumber(e.act, 2)}</td>`;
        tableHtml += `<td class="px-3 py-2 text-right">${formatNumber(e.targ, 2)}</td>`;
        tableHtml += `<td class="px-3 py-2 text-right ${e.deficit > 0 ? 'text-red-600' : 'text-green-600'}">${formatNumber(e.deficit, 2)}</td>`;
        tableHtml += `<td class="px-3 py-2 text-right ${e.p < 88 ? 'text-red-600 font-semibold' : ''}">${e.p.toFixed(1)}%</td>`;
        tableHtml += '</tr>';
      });
      tableHtml += '</tbody></table>';
      el.previewTable.innerHTML = tableHtml;

      // Products note
      el.previewProducts.innerHTML = `
        <p class="text-gray-500 dark:text-gray-400 italic">
          Los productos recomendados se calcularán al guardar el informe usando el optimizador de costos.
          El sistema seleccionará la combinación más económica que cubra los déficits mostrados arriba.
        </p>
      `;

      // Warnings
      const warnings = [];
      if(deficient.length > 5) warnings.push(`Hay ${deficient.length} nutrientes deficientes — considere revisar el plan de fertilización completo.`);
      if(limiting.p < 30) warnings.push(`El nutriente limitante (${limiting.name}) está muy por debajo del nivel ideal. Puede requerir aplicaciones escalonadas.`);
      if(excess.length > 0) warnings.push(`Nutrientes en exceso: ${excess.map(e => e.name).join(", ")}. No aplicar adicionalmente.`);
      el.previewWarnings.innerHTML = warnings.length > 0
        ? '<div class="space-y-1">' + warnings.map(w => `<p>⚠ ${w}</p>`).join('') + '</div>'
        : '';

      el.previewCost.innerHTML = '';
      el.previewModal.classList.remove("hidden");
    }

    function hidePreviewModal(){
      if(el.previewModal) el.previewModal.classList.add("hidden");
    }

    if(el.previewReportBtn){
      el.previewReportBtn.addEventListener("click", showPreviewModal);
    }
    if(el.previewModalClose){
      el.previewModalClose.addEventListener("click", hidePreviewModal);
    }
    if(el.previewModalCloseBtn){
      el.previewModalCloseBtn.addEventListener("click", hidePreviewModal);
    }
    if(el.previewSaveBtn){
      el.previewSaveBtn.addEventListener("click", () => {
        hidePreviewModal();
        handleSaveReport();
      });
    }

    // --- Reference change modal (C-ref) ---
    let refCropObjectives = [];
    let refSecondaryObjectives = [];

    async function loadReferenceOptions(){
      refCropObjectives = [];
      refSecondaryObjectives = [];
      // Load crop objectives
      try{
        const allObjectives = await fetchJson("{{ url_for('foliage_api.objectives') }}");
        // Filter unique by crop_id
        const seen = new Set();
        for(const obj of allObjectives){
          if(!obj || seen.has(obj.crop_id)) continue;
          seen.add(obj.crop_id);
          refCropObjectives.push(obj);
        }
      }catch(err){
        console.error("Failed to load crop objectives:", err);
      }
      // Load secondary objectives
      try{
        refSecondaryObjectives = await fetchJson(ENDPOINTS.secondaryObjectivesList);
        if(!Array.isArray(refSecondaryObjectives)) refSecondaryObjectives = [];
      }catch(err){
        console.error("Failed to load secondary objectives:", err);
      }
      // Populate selects
      if(el.refModalCropObjective){
        const opts = ['<option value="">Selecciona un objetivo de cultivo...</option>'];
        refCropObjectives.forEach(obj => {
          opts.push(`<option value="crop:${obj.id}">${obj.crop_name || "Cultivo"} · ID ${obj.id} · Target ${obj.target_value ?? "-"}</option>`);
        });
        el.refModalCropObjective.innerHTML = opts.join("");
      }
      if(el.refModalSecondaryObjective){
        const opts = ['<option value="">Selecciona un objetivo secundario...</option>'];
        refSecondaryObjectives.forEach(obj => {
          const cropName = obj?.analysis_crop?.name || `Objetivo ${obj?.id}`;
          opts.push(`<option value="secondary:${obj.id}">${cropName} · Secundario #${obj?.id ?? ""}</option>`);
        });
        el.refModalSecondaryObjective.innerHTML = opts.join("");
      }
      // If no objectives loaded, show a hint
      if(refCropObjectives.length === 0 && refSecondaryObjectives.length === 0){
        if(el.referenceModalError){
          el.referenceModalError.textContent = "No se encontraron objetivos configurados. Configure objetivos de cultivo primero.";
          el.referenceModalError.classList.remove("hidden");
        }
      }
    }

    function showReferenceModal(){
      if(!el.referenceModal) return;
      el.referenceModalError.classList.add("hidden");
      if(el.refModalCropObjective) el.refModalCropObjective.value = "";
      if(el.refModalSecondaryObjective) el.refModalSecondaryObjective.value = "";
      if(el.referenceModalApply) el.referenceModalApply.disabled = true;
      loadReferenceOptions();
      el.referenceModal.classList.remove("hidden");
    }

    function hideReferenceModal(){
      if(el.referenceModal) el.referenceModal.classList.add("hidden");
    }

    async function applyNewReference(valueStr){
      if(!valueStr) return;
      const [type, idStr] = valueStr.split(":");
      const objectiveId = Number(idStr);
      if(!objectiveId) return;

      hideReferenceModal();
      const kind = type === "secondary" ? "secondary" : "crop";

      // Update payload
      payload.objective = {
        type: kind,
        id: objectiveId,
        label: kind === "secondary"
          ? (el.refModalSecondaryObjective?.options[el.refModalSecondaryObjective.selectedIndex]?.textContent || "").trim()
          : (el.refModalCropObjective?.options[el.refModalCropObjective.selectedIndex]?.textContent || "").trim(),
      };

      // Re-run setup
      try{
        await setupLotVsObjective(payload);
        await fetchCvValues(payload.lot_id);
        renderAnalysisInfo(analysisData);
        renderCvInfo();
        computeMinimumLaw();
        // Update badge
        el.modeBadge.textContent = kind === "secondary"
          ? "Modo: Lote vs objetivo secundario"
          : "Modo: Lote vs objetivo ideal";
        el.referenceCardBadge.textContent = kind === "secondary" ? "Objetivo secundario" : "Objetivo ideal";
      }catch(err){
        console.error(err);
        showError(err?.message || "No se pudo cargar la nueva referencia.");
      }
    }

    if(el.changeReferenceBtn){
      el.changeReferenceBtn.addEventListener("click", showReferenceModal);
    }
    if(el.referenceModalClose){
      el.referenceModalClose.addEventListener("click", hideReferenceModal);
    }
    if(el.referenceModalCancel){
      el.referenceModalCancel.addEventListener("click", hideReferenceModal);
    }
    // Enable apply button when a selection is made
    function updateRefApplyState(){
      const cropVal = el.refModalCropObjective?.value || "";
      const secVal = el.refModalSecondaryObjective?.value || "";
      if(el.referenceModalApply){
        el.referenceModalApply.disabled = !(cropVal || secVal);
      }
      // Deselect the other when one is chosen
      if(cropVal && el.refModalSecondaryObjective){
        el.refModalSecondaryObjective.value = "";
      }
      if(secVal && el.refModalCropObjective){
        el.refModalCropObjective.value = "";
      }
    }
    if(el.refModalCropObjective){
      el.refModalCropObjective.addEventListener("change", updateRefApplyState);
    }
    if(el.refModalSecondaryObjective){
      el.refModalSecondaryObjective.addEventListener("change", updateRefApplyState);
    }
    if(el.referenceModalApply){
      el.referenceModalApply.addEventListener("click", () => {
        const cropVal = el.refModalCropObjective?.value || "";
        const secVal = el.refModalSecondaryObjective?.value || "";
        applyNewReference(cropVal || secVal);
      });
    }
    // Close modal on backdrop click
    if(el.referenceModal){
      el.referenceModal.addEventListener("click", (e) => {
        if(e.target === el.referenceModal) hideReferenceModal();
      });
    }

    init();
  })();
</script>
{% endblock %}
