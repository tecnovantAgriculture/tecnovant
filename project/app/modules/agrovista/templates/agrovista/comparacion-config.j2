    function computeMinimumLaw(){
      const order = nutrientOrder;
      minimumLawPayload = {};
      const rows = [];

      const buildRow = (label, values, className = "") => {
        rows.push({ label, values, className });
      };

      // Row 1: %P — porcentaje de suficiencia
      const pRow = order.map(n => {
        const act = actualValues[n];
        const targ = targetValues[n];
        if(act == null || targ == null || targ === 0){
          return null;
        }
        return (act / targ) * 100;
      });
      buildRow("%P", pRow);

      // Row 2: I — índice de ajuste (todos los nutrientes)
      const iRow = order.map(n => {
        const act = actualValues[n];
        const targ = targetValues[n];
        const cv = cvData[n];
        if(act == null || targ == null || targ === 0 || cv == null) return null;
        const p = (act / targ) * 100;
        return Math.abs(p - 100) * cv / 100;
      });
      buildRow("I", iRow, "bg-yellow-50");

      // Row 3: R — nivel corregido (todos los nutrientes)
      const rRow = order.map(n => {
        const act = actualValues[n];
        const targ = targetValues[n];
        const cv = cvData[n];
        if(act == null || targ == null || targ === 0 || cv == null) return null;
        const p = (act / targ) * 100;
        const i = Math.abs(p - 100) * cv / 100;
        let r = p > 100 ? p - i : p + i;
        if(r < 88) r = 88;
        if(r > 108) r = 108;
        return r;
      });
      buildRow("R", rRow, "bg-blue-50");

      // Row 4: Diferencia
      const diffRow = order.map(n => {
        const act = actualValues[n];
        const targ = targetValues[n];
        if(act == null || targ == null || targ === 0){
          return null;
        }
        const p = (act / targ) * 100;
        return p - 100;
      });
      buildRow("Diferencia", diffRow, "bg-red-50");

      // Build minimumLawPayload for backend
      order.forEach(nutrient => {
        const act = actualValues[nutrient];
        const targ = targetValues[nutrient];
        const cv = cvData[nutrient];
        if(act == null || targ == null || targ === 0){
          return;
        }
        const p = (act / targ) * 100;
        const isLimiting = nutrient === limitingNutrient;
        const i = (cv != null && isLimiting) ? Math.abs(p - 100) * cv / 100 : null;
        let r = null;
        if(i != null){
          r = p > 100 ? p - i : p + i;
          if(r < 88) r = 88;
          if(r > 108) r = 108;
        }
        minimumLawPayload[nutrient] = {
          "%P": p != null ? p.toFixed(2) : "-",
          "I": i != null ? i.toFixed(2) : "-",
          "R": r != null ? r.toFixed(2) : "-",
          "Diferencia": (p - 100).toFixed(2),
        };
      });

      renderMinimumLawTable(order, rows);
      updateSummary(order);
    }

    function renderMinimumLawTable(order, rows){
      if(!el.lawTableHeader || !el.lawTableBody){
        return;
      }
      el.lawTableHeader.innerHTML = "";
      const headLabel = document.createElement("th");
      headLabel.className = "px-3 py-2 text-left font-semibold text-gray-600";
      headLabel.textContent = "Fila";
      el.lawTableHeader.appendChild(headLabel);

      // Row descriptions for header
      const rowDescriptions = ["% Suficiencia", "Índice de ajuste", "Nivel corregido", "Déficit/Exceso (%)"];
      order.forEach(n => {
        const th = document.createElement("th");
        th.className = "px-3 py-2 text-left font-semibold text-gray-600";
        th.textContent = n;
        el.lawTableHeader.appendChild(th);
      });

      el.lawTableBody.innerHTML = "";
      rows.forEach((row, idx) => {
        const tr = document.createElement("tr");
        if(row.className){
          tr.className = row.className;
        }
        const th = document.createElement("td");
        th.className = "whitespace-nowrap px-3 py-2 font-medium text-gray-800";
        th.textContent = row.label;
        tr.appendChild(th);
        row.values.forEach(value => {
          const td = document.createElement("td");
          td.className = "px-3 py-2 text-gray-700";
          if(value == null || Number.isNaN(value)){
            td.textContent = "—";
            td.classList.add("text-gray-400");
          }else{
            td.textContent = value.toFixed(2);
            // Color coding
            if(row.label === "%P"){
              if(value < 88) td.classList.add("text-red-600", "font-semibold");
              else if(value > 108) td.classList.add("text-orange-600");
              else td.classList.add("text-green-600");
            }else if(row.label === "Diferencia"){
              if(value < 0) td.classList.add("text-red-600");
              else if(value > 0) td.classList.add("text-orange-600");
            }
          }
          tr.appendChild(td);
        });
        el.lawTableBody.appendChild(tr);
      });
    }

    function updateSummary(order){
      const entries = order.map(name => {
        const act = actualValues[name];
        const targ = targetValues[name];
        if(act == null || targ == null){
          return null;
        }
        const p = (act / targ) * 100;
        return { name, p };
      }).filter(Boolean);
      if(entries.length === 0){
        setText(el.limitingNutrient, "--");
        setText(el.optimalNutrients, "--");
        setText(el.excessNutrients, "--");
        return;
      }
      entries.sort((a, b) => a.p - b.p);
      const limiting = entries[0];
      const optimal = entries.filter(item => item.p >= 88 && item.p <= 108).map(item => item.name);
      const excess = entries.filter(item => item.p > 108).map(item => item.name);
      setText(el.limitingNutrient, limiting ? limiting.name : "--");
      setText(el.optimalNutrients, optimal.length ? optimal.join(", ") : "—");
      setText(el.excessNutrients, excess.length ? excess.join(", ") : "—");
    }

    async function setupLotVsObjective(data){
      const lotId = data.lot_id;
      const objectiveId = data.objective?.id || data.objective_id;
      const objectiveKind = data.objective?.type || "crop";
      if(!lotId || !objectiveId){
        throw new Error("No se encontraron los parámetros de comparación.");
      }
      const [analyses, lotInfo] = await Promise.all([
        fetchJson(`${ENDPOINTS.analyses}?lot_id=${lotId}`),
        fetchJson(ENDPOINTS.lots.replace("0", lotId)),
      ]);
      analysisData = pickAnalysis(analyses, data.common_analysis_id);
      objectiveType = objectiveKind;
      if(objectiveKind === "secondary"){
        objectiveData = await fetchJson(ENDPOINTS.secondaryObjectives.replace("0", objectiveId));
      }else{
        objectiveData = await fetchJson(ENDPOINTS.objectives.replace("0", objectiveId));
      }
      await fetchLotCrops();

      const secondaryCropName = objectiveData?.analysis_crop?.name || "--";
      const cropName = objectiveKind === "secondary"
        ? secondaryCropName
        : (objectiveData?.crop_name || resolveCropNameForLot(lotId) || "--");
      setText(el.analysisLotName, lotInfo?.name || data.lot_label);
      setText(el.analysisLotArea, lotInfo?.area ? `${formatNumber(lotInfo.area, 2)} ha` : "--");
      setText(el.analysisLotCrop, cropName);
      setText(el.analysisLotDate, analysisData?.date || "--");

      // Store analysis metadata for PDF export
      const lotLabel = data.lot_label || "";
      const parts = lotLabel.split(" · ");
      currentAnalysisMeta.farmName = parts[0] ? parts[0].trim() : (lotInfo?.farm_name || "");
      currentAnalysisMeta.lotName = parts.length > 1 ? parts.slice(1).join(" · ").trim() : (lotInfo?.name || "");
      currentAnalysisMeta.area = lotInfo?.area ? `${formatNumber(lotInfo.area, 2)} ha` : "--";
      currentAnalysisMeta.cropName = cropName;
      currentAnalysisMeta.analysisDate = analysisData?.date || "--";
      currentAnalysisMeta.username = document.getElementById("meta-username")?.textContent?.trim() || "Sistema";
      currentAnalysisMeta.orgName = document.getElementById("meta-orgname")?.textContent?.trim() || "";

      // Populate NDVI/VARI/NBI from payload stats if available (C2)
      const payloadStats = payload?.stats || {};
      if(payloadStats && payloadStats.ndvi != null){
        setText(el.analysisNdvi, formatMetric(payloadStats.ndvi, 2));
        setText(el.analysisVari, formatMetric(payloadStats.vari, 2));
        setText(el.analysisNbi, formatMetric(payloadStats.nbi, 2));
      }else{
        setText(el.analysisNdvi, "--");
        setText(el.analysisVari, "--");
        setText(el.analysisNbi, "--");
      }

      setText(el.referenceName, data.objective?.label || `${cropName} · ID ${objectiveId}`);
      setText(el.referenceSource, objectiveKind === "secondary" ? "Objetivo secundario" : "Tabla de objetivos");
      setText(el.referenceType, objectiveKind === "secondary" ? "Objetivo secundario" : "Ideal de cultivo");
      setText(el.referenceNdvi, "--");
      setText(el.referenceVari, "--");
      setText(el.referenceNbi, "--");

      actualValues = collectActualValues(analysisData);
      targetValues = objectiveKind === "secondary"
        ? collectTargetValuesFromSecondaryObjective(objectiveData)
        : collectTargetValuesFromObjective(objectiveData);
      nutrientOrder = buildNutrientOrder();
      const cropIdValue = objectiveKind === "secondary" ? objectiveData?.analysis_crop_id : objectiveData?.crop_id;
      renderCropInfo(cropIdValue, cropName);
    }

    async function setupLotVsLot(data){
      const lotA = data.lot_a;
      const lotB = data.lot_b;
      if(!lotA || !lotB){
        throw new Error("No se encontró la comparación lote vs lote.");
      }
      if(!lotB.linked_lot_id){
        throw new Error("El lote B no tiene un análisis foliar guardado. Guarde un análisis desde el NDVI Tool antes de comparar.");
      }
      await fetchLotCrops();
      const analyses = await fetchJson(`${ENDPOINTS.analyses}?lot_id=${lotB.linked_lot_id}`);
      analysisData = pickAnalysis(analyses, lotB.linked_common_analysis_id);
      if(!analysisData){
        throw new Error("No se encontró un análisis de follaje válido para el Lote B. Guarde un análisis desde el NDVI Tool antes de comparar.");
      }

      const lotInfo = await fetchJson(ENDPOINTS.lots.replace("0", lotB.linked_lot_id));
      const cropName = resolveCropNameForLot(lotB.linked_lot_id) || "--";

      el.analysisCardTitle.textContent = "Lote analizado";
      el.analysisCardBadge.textContent = "Lote B";
      setText(el.analysisLotName, lotB.linked_lot_name || lotInfo?.name || lotB.name);
      setText(el.analysisLotArea, lotB.area_ha ? `${formatNumber(lotB.area_ha, 2)} ha` : (lotInfo?.area ? `${formatNumber(lotInfo.area, 2)} ha` : "--"));
      setText(el.analysisLotCrop, cropName);
      setText(el.analysisLotDate, analysisData?.date || "--");

      // Store analysis metadata for PDF export (lot_vs_lot mode)
      currentAnalysisMeta.farmName = lotInfo?.farm_name || "";
      currentAnalysisMeta.lotName = lotB.linked_lot_name || lotInfo?.name || lotB.name || "";
      currentAnalysisMeta.area = lotB.area_ha ? `${formatNumber(lotB.area_ha, 2)} ha` : (lotInfo?.area ? `${formatNumber(lotInfo.area, 2)} ha` : "--");
      currentAnalysisMeta.cropName = cropName;
      currentAnalysisMeta.analysisDate = analysisData?.date || "--";
      currentAnalysisMeta.username = document.getElementById("meta-username")?.textContent?.trim() || "Sistema";
      currentAnalysisMeta.orgName = document.getElementById("meta-orgname")?.textContent?.trim() || "";

      // NDVI/VARI/NBI: prefer payload stats, fallback to fetched data
      if(lotB.stats && lotB.stats.ndvi != null){
        setText(el.analysisNdvi, formatNumber(lotB.stats.ndvi, 2));
        setText(el.analysisVari, formatNumber(lotB.stats.vari, 2));
        setText(el.analysisNbi, formatNumber(lotB.stats.nbi, 2));
      }else{
        setText(el.analysisNdvi, "--");
        setText(el.analysisVari, "--");
        setText(el.analysisNbi, "--");
      }

      el.referenceCardBadge.textContent = "Lote A";
      setText(el.referenceName, lotA.name || "Lote A");
      setText(el.referenceSource, "Lote comparativo");
      setText(el.referenceType, "Ideal por lote");
      if(lotA.stats && lotA.stats.ndvi != null){
        setText(el.referenceNdvi, formatNumber(lotA.stats.ndvi, 2));
        setText(el.referenceVari, formatNumber(lotA.stats.vari, 2));
        setText(el.referenceNbi, formatNumber(lotA.stats.nbi, 2));
      }else{
        setText(el.referenceNdvi, "--");
        setText(el.referenceVari, "--");
        setText(el.referenceNbi, "--");
      }

      actualValues = collectActualValues(analysisData);
      // If area_stats is missing or empty, use objective targets as fallback
      if(lotA.area_stats && Array.isArray(lotA.area_stats.nutrients) && lotA.area_stats.nutrients.length > 0){
        targetValues = collectTargetValuesFromStats(lotA.area_stats);
      }else{
        // Try to fetch crop objective for this lot
        const cropId = resolveCropIdForLot(lotB.linked_lot_id);
        if(cropId){
          try{
            objectiveData = await fetchJson(ENDPOINTS.objectives.replace("0", cropId));
            targetValues = collectTargetValuesFromObjective(objectiveData);
          }catch(err){
            console.warn("No se pudo cargar objetivo del cultivo para comparación lot-vs-lot:", err);
            targetValues = {};
          }
        }else{
          targetValues = {};
        }
      }
      nutrientOrder = buildNutrientOrder();
      renderCropInfo(resolveCropIdForLot(lotB.linked_lot_id), cropName);
    }

