ENV=development
TITLE=TecnoAgro
SECRET_KEY=change_this_secret_key
SECURITY_SALT=change_this_salt
ANTHROPIC_API_KEY=anthropic_sample_key
OPENAI_API_KEY=openai_sample_key
DB_TYPE=sqlite
DB_USER=dev_user
DB_PASSWORD=change_me
DB_HOST=localhost
DB_NAME=tecnovant_db
MAIL_SERVER=smtp.example.com
MAIL_PORT=465
MAIL_USE_TLS=False
MAIL_USE_SSL=True
MAIL_USERNAME=email_user
MAIL_PASSWORD=email_pass
MAIL_DEFAULT_SENDER=no-reply@example.com
CONTACT_EMAIL=contact@example.com
CACHE_TYPE=simple
CACHE_REDIS_URL=redis://localhost:6379/0
CACHE_REDIS_PASSWORD=redis_pass
CACHE_DEFAULT_TIMEOUT=300
CACHE_THRESHOLD=1000
CACHE_IGNORE_ERRORS=True

# WebODM local:
# WEBODM_URL=http://host.docker.internal:8000
#
# WebODM en nube:
# WEBODM_URL=http://IP_PUBLICA_DE_GOOGLE:8000
# WEBODM_PUBLIC_URL=http://IP_PUBLICA_DE_GOOGLE:8000
WEBODM_URL=http://host.docker.internal:8000
WEBODM_PUBLIC_URL=
WEBODM_USERNAME=Tecnovan
WEBODM_PASSWORD=change_me
WEBODM_PROJECT_NAME=Tecnovan
WEBODM_REQUEST_TIMEOUT_SECONDS=60
WEBODM_UPLOAD_TIMEOUT_SECONDS=7200
WEBODM_PROCESSING_PROFILE=fast_2d
